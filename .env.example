# このファイルを .env という名前でコピーして、実際の値を入れてください。
# .env は .gitignore 済みなので、コミットされません。

# Google Analytics 4 の計測ID（G-XXXXXXXXXX 形式）
# 取得方法: docs/setup/11-ga4.md を参照（未設定の場合は GA スクリプトは出力されない）
PUBLIC_GA4_ID=

# 配信予定カレンダーの .ics フィードURL
# 取得方法: docs/setup/01-google-calendar.md を参照
# （Googleカレンダー → 設定 → 「カレンダーの統合」→「iCal形式の公開URL」）
ICS_URL=

# YouTube Data API v3 のAPIキー（動画一覧・ライブ検知に使用）
# 取得方法: docs/setup/05-youtube-api.md を参照
# ※チャンネルIDは公開情報なので src/config/site.ts に書く（ここはキーのみ）
YOUTUBE_API_KEY=

# Discord通知用Webhook URL（ローカル開発では未設定でOK。CIでのみ使用）
# 取得方法: docs/setup/02-discord-webhook.md を参照
DISCORD_WEBHOOK_URL=

# --- Discord →カレンダー連携（/予定 コマンド）---------------------------------
# 下の値はサーバー側（Cloudflare Pages の環境変数）に入れる本番用。ここはローカルでの
# コマンド登録スクリプト実行と、変数名のメモ用。実際の鍵はチャット等に貼らないこと。
# 取得方法と設定先: docs/setup/07-discord-calendar.md を参照
#
# ローカルでコマンド登録スクリプトを実行するときだけ使う（node scripts/register-discord-commands.mjs）:
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
#
# 以下は Cloudflare Pages の環境変数（Secret）に設定する。.env には不要:
#   DISCORD_PUBLIC_KEY        … Discordアプリの Public Key（署名検証用）
#   DISCORD_ALLOWED_USER_IDS  … コマンドを使える人のDiscordユーザーID（カンマ区切り）
#   GOOGLE_SA_EMAIL           … サービスアカウントのメール（xxx@xxx.iam.gserviceaccount.com）
#   GOOGLE_SA_PRIVATE_KEY     … サービスアカウントの秘密鍵（PEM。改行は \n でもそのままでも可）
#   GOOGLE_CALENDAR_ID        … 書き込み先カレンダーのID（HPが読むのと同じカレンダー）

# --- 週間ポスター自動生成（/ポスター ＆ 日曜18時）-----------------------------
# 取得方法と設定先: docs/setup/08-poster.md を参照
#   GitHub Secrets（Actions用）:
#     DISCORD_POSTER_WEBHOOK_URL … ポスター画像の投稿先チャンネルのWebhook（無ければ DISCORD_WEBHOOK_URL を使用）
#     ICS_URL                    … 既存（Phase1で設定済み）
#   Cloudflare Pages の環境変数（/ポスター コマンド用）:
#     GITHUB_DISPATCH_TOKEN      … GitHub Actions を起動するトークン（fine-grained PAT／Contents:Read and write）
#     GITHUB_REPO                … owner/repo（例 WakamatsuIori/-HP）

# 以下2つは初回セットアップ（Pagesプロジェクト作成）とローカルからの手動デプロイ時のみ使用。
# 普段の自動デプロイは GitHub Secrets 側の値を使う。
# 取得方法: docs/setup/04-cloudflare-pages.md を参照
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- 独自お問い合わせフォーム（/contact/submit）------------------------------
# 取得方法と設定先: docs/setup/10-contact-form.md を参照
#   Cloudflare Pages の環境変数（Function実行時に使用）:
#     CONTACT_WEBHOOK_URL   … 問い合わせ通知を送る Discord Webhook（専用チャンネル推奨）
#     CONTACT_SHEET_ID      … 記録先 Google スプレッドシートのID（URLの /d/ と /edit の間）
#     TURNSTILE_SECRET_KEY  … Cloudflare Turnstile のシークレットキー（サーバー検証用）
#   ※ Sheets 追記は既存の GOOGLE_SA_EMAIL / GOOGLE_SA_PRIVATE_KEY（サービスアカウント）を流用。
#     対象スプレッドシートを、そのサービスアカウントのメールに「編集者」で共有すること。
#   GitHub Secrets（ビルド時にHTMLへ埋め込む公開値）:
#     PUBLIC_TURNSTILE_SITE_KEY … Turnstile のサイトキー（公開情報。フォームに埋め込まれる）
PUBLIC_TURNSTILE_SITE_KEY=

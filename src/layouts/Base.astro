---
import { site } from '../config/site';
import LastUpdated from '../components/LastUpdated.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : site.name;

// OGP/正規URL用の絶対URL（Astro.site = astro.config.mjs の site から生成）
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og.jpg', Astro.site); // SNSシェアカードの画像（横長キービジュアル）

// GA4 計測ID。GA4の測定IDはクライアントHTMLに必ず露出する「公開ID」（秘密ではない）。
// このサイトは GitHub Actions でビルドするが、CIでは env が import.meta.env に載らず
// 計測タグが出ない問題があったため、本番ビルド時は公開IDを直接埋め込む。
// import.meta.env.PROD は astro build で true / astro dev で false（Vite組み込み・確実）。
// → 本番のみ計測、ローカルdevでは出さないので自分のアクセスでGAを汚さない。
const GA4_ID = 'G-ZKZMY31TTQ';
const ga4Id = import.meta.env.PROD ? GA4_ID : '';

// 構造化データ（AEO/SEO）。sameAs で公式SNSを相互リンクし「ここが一次情報源」とAIに認識させる。
const homeURL = new URL('/', Astro.site).toString();
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  alternateName: 'WAKAMATSU IORI',
  url: homeURL,
  image: ogImageURL.toString(),
  description: site.description,
  sameAs: [site.links.youtube, site.links.x, site.links.booth],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: homeURL,
  inLanguage: 'ja',
};

// ナビの現在地判定（現在ページのリンクに下線を付ける）
const currentPath = Astro.url.pathname;
const isActiveNav = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

// トップは1ページ縦スクロールのLP。ナビは画面内アンカーへ（他ページからはトップの該当位置へ戻る）。
const nav = [
  { href: '/', label: 'トップ' },
  { href: '/#profile', label: 'プロフィール' },
  { href: '/#schedule', label: 'スケジュール' },
  { href: '/#videos', label: '動画' },
  { href: '/#goods', label: 'ストア' },
  { href: '/#work', label: 'お仕事依頼' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#1b110a" />
    <script is:inline>
      // 初回訪問のみ紋章スプラッシュを表示（同一セッションの2回目以降は出さない）。
      // FOUC防止のため head 先頭で判定し、既訪問なら描画前に隠す。
      if (sessionStorage.getItem('iori-seen')) {
        document.documentElement.classList.add('no-splash');
      } else {
        sessionStorage.setItem('iori-seen', '1');
        // 立ち絵を主役にするので、読み込み後さらに少し溜めてからフェードアウト（一瞬で消えない）。
        addEventListener('load', () => setTimeout(() => document.getElementById('splash')?.classList.add('done'), 1000));
      }
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Google Search Console 所有権確認（公開トークン。秘密情報ではない） */}
    <meta name="google-site-verification" content="Niz9u2WNP30ET3pUZPzJFh2H0dDQTavjxbIGF_Jv_WM" />

    {/* Google Analytics 4（PUBLIC_GA4_ID が設定されている場合のみ出力） */}
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
        <script define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id);
        </script>
      </>
    )}

    {/* OGP / Twitter カード（SNSシェア時のカード表示。画像は全ページ共通のキービジュアル） */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* 構造化データ（JSON-LD）：人物＋サイト。AI/検索に「公式の一次情報」と認識させる */}
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {/* ページ個別の JSON-LD（FAQPage等）を各ページから slot="head" で差し込む受け口 */}
    <slot name="head" />

    {/* 見出し・ロゴ用の明朝（サブセット済み・全ページのヘッダーで使うため先読み）。
        現在の見出しは しっぽり明朝。Zen Old Mincho はフォールバックとして @font-face のみ保持。 */}
    <link
      rel="preload"
      href="/fonts/shippori-mincho-medium.subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    {/* 欧文ロゴ用 Cinzel（サブセット 7.6KB・ヒーロー/見出しの英字に使うため先読み） */}
    <link
      rel="preload"
      href="/fonts/cinzel-500.subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    {/* 初回のみのスプラッシュ：黒地に屋号だけのタイトルカード。判定スクリプトは head 先頭。 */}
    <div id="splash" aria-hidden="true">
      <p class="splash__name">{site.name}</p>
      <p class="splash__en">WAKAMATSU IORI</p>
    </div>
    <header class="site-header">
      <a class="brand" href="/">{site.name}</a>
      <nav aria-label="メインメニュー">
        <ul>
          {nav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActiveNav(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <nav class="foot-nav" aria-label="セクション">
        <a class="foot-diamond" href="/#profile"><span>PROFILE</span></a>
        <a class="foot-diamond" href="/#information"><span>INFORMATION</span></a>
        <a class="foot-diamond" href="/#gallery"><span>GALLERY</span></a>
        <a class="foot-diamond" href="/#discography"><span>DISCOGRAPHY</span></a>
        <a class="foot-diamond" href="/#work"><span>CONTACT</span></a>
      </nav>
      <p class="foot-brand">
        <span class="foot-brand__name">{site.name}</span>
        <span class="foot-brand__en">OFFICIAL WEB SITE</span>
      </p>
      <nav class="social-icons" aria-label="公式SNS・リンク">
        <a href={site.links.youtube} rel="me noopener" target="_blank" aria-label="YouTube">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.5 15.5v-7l6.3 3.5-6.3 3.5Z"/></svg>
        </a>
        <a href={site.links.x} rel="me noopener" target="_blank" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18.2 2.3h3.3l-7.2 8.2L22.8 22h-6.6l-5.2-6.8L4.9 22H1.6l7.7-8.8L1.2 2.3h6.8l4.7 6.2 5.5-6.2Zm-1.2 17.7h1.8L7.1 4.2H5.2L17 20Z"/></svg>
        </a>
        <a href={site.links.booth} rel="me noopener" target="_blank" aria-label="BOOTH（ストア）">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M6 7.5h12l-1 12.5H7L6 7.5Z"/><path fill="none" stroke="currentColor" stroke-width="1.8" d="M9 9V6.2a3 3 0 0 1 6 0V9"/></svg>
        </a>
        <a href={site.links.marshmallow} rel="noopener" target="_blank" aria-label="マシュマロ（匿名メッセージ）">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M4.5 5h15v10.5H9.5L5.5 19v-3.5h-1V5Z"/></svg>
        </a>
      </nav>
      <p class="footer-nav">
        <a href="/#guideline">ガイドライン</a>
        <a href="/privacy">プライバシーポリシー</a>
      </p>
      <LastUpdated />
      <p class="foot-copy">© {site.name}</p>
    </footer>
  </body>
</html>

<style is:global>
  /* 見出し・ロゴ専用の明朝（使う文字だけのサブセット woff2・約50KB）。
     本文はシステムフォントのまま＝軽量維持。再生成は scripts/subset_fonts.py。 */
  /* 現在の見出し＝しっぽり明朝（耽美寄りの明朝・サブセット約43KB） */
  @font-face {
    font-family: 'Shippori Mincho';
    src: url('/fonts/shippori-mincho-medium.subset.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  /* フォールバック兼・見比べ用に Zen Old Mincho も保持（--font-serif の2番手。未参照なら読み込まれない） */
  @font-face {
    font-family: 'Zen Old Mincho';
    src: url('/fonts/zen-old-mincho-medium.subset.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap; /* 読み込み中はシステム明朝で即表示→差し替え（描画ブロックなし） */
  }
  /* 欧文ロゴ専用の Cinzel（基本ラテンだけのサブセット woff2・約7.6KB）。
     ローマ字ロゴ・英字ディスプレイ見出しに使用。和文は持たないので明朝にフォールバック。 */
  @font-face {
    font-family: 'Cinzel';
    src: url('/fonts/cinzel-500.subset.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  :root {
    --bg: #faf9f6;
    --text: #423f38;
    --muted: #6e6855; /* 二次テキスト：白/帯/地色いずれでもWCAG AA(4.5:1)以上を満たす濃さ */
    --accent: #9c8f6b;        /* くすみ金：見出し装飾・大きいアクセント用 */
    --accent-strong: #6f6444; /* 濃い金：本文リンク等の小さい文字用（白背景でAAコントラスト確保） */
    --line: #e7e3d9;
    --card: #ffffff;
    --font-serif: 'Shippori Mincho', 'Zen Old Mincho', 'Hiragino Mincho ProN', 'Yu Mincho', 'Noto Serif JP', serif;
    --font-logo: 'Cinzel', var(--font-serif); /* 欧文ロゴ・英字ディスプレイ用（未読込時は明朝へ） */
  }
  * { box-sizing: border-box; }
  html { color-scheme: light; overflow-x: clip; } /* 100vwのフルブリードで横スクロールを出さない（縦は保持） */

  /* ===== 初回のみ スプラッシュ（屋号だけのタイトルカード） ===== */
  #splash {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    background: radial-gradient(120% 100% at 50% 35%, #2a2118, #120c07 72%);
    z-index: 9999;
  }
  .splash__name {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 8vw, 3.4rem);
    letter-spacing: 0.3em;
    color: #e8cf95;
    animation: splashRise 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .splash__en {
    margin: 0;
    font-family: var(--font-logo);
    font-size: clamp(0.72rem, 2.5vw, 0.92rem);
    letter-spacing: 0.42em;
    color: rgba(232, 207, 149, 0.6);
    animation: splashFade 0.9s ease 0.3s both;
  }
  #splash.done {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0s 0.8s;
  }
  .no-splash #splash { display: none; }
  @keyframes splashRise {
    from { opacity: 0; transform: translateY(24px) scale(0.98); }
    to { opacity: 1; transform: none; }
  }
  @keyframes splashFade { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) {
    .splash__name, .splash__en { animation: none; }
    #splash.done { transition: none; }
  }
  /* LPの画面内アンカー移動をなめらかに（動きが苦手な設定の人には無効） */
  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }
  body {
    margin: 0;
    font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', 'Yu Gothic', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
    letter-spacing: 0.02em;
    overflow-x: clip;
  }
  a { color: var(--accent-strong); }

  /* テキスト選択：既定の青ではなく、ブランドのくすみ金トーンで上品に */
  ::selection { background: rgba(156, 143, 107, 0.28); color: var(--text); }

  /* キーボード操作時のフォーカス表示（マウス操作には出ない）。
     金の細いリングで、世界観を崩さずアクセシビリティを担保。 */
  :where(a, button, input, textarea, select, summary, [tabindex]):focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* 日本語の不自然な改行を抑える：文節区切りで改行（auto-phrase・対応ブラウザ）＋
     孤立行/短い末行を避ける（pretty）／短い見出し・リード文は行頭末を均す（balance）。
     未対応ブラウザは従来の折返しに無害劣化。 */
  p, li, dd { text-wrap: pretty; word-break: auto-phrase; }
  h1, h2, h3, .sec-lead, .guide-text, .about__catch { text-wrap: balance; word-break: auto-phrase; }

  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.75rem 1.25rem 3.5rem;
  }
  h1, h2, h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1.5;
  }
  h1 { font-size: 1.55rem; }
  /* h2：上品な金のアクセント（細い全幅ライン＋見出し先頭の金タブ） */
  h2 {
    position: relative;
    font-size: 1.2rem;
    margin-top: 2.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--line);
  }
  h2::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 2.5rem;
    height: 2px;
    background: var(--accent);
  }

  .site-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line);
    background: var(--card);
  }
  .site-header .brand {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-decoration: none;
    color: var(--text);
  }
  .site-header nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-header nav a {
    position: relative;
    display: inline-block;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.9rem;
    padding: 0.4rem 0.15rem; /* タップ領域を確保（指で押しやすく） */
    transition: color 0.15s ease;
  }
  /* 金の下線が左から伸びるリビール（ホバー／現在ページ）。下線は文字幅に合わせて内側に */
  .site-header nav a::after {
    content: '';
    position: absolute;
    left: 0.15rem;
    right: 0.15rem;
    bottom: 0.2rem;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .site-header nav a:hover { color: var(--text); }
  .site-header nav a:hover::after,
  .site-header nav a[aria-current='page']::after { transform: scaleX(1); }
  .site-header nav a[aria-current='page'] { color: var(--text); }
  @media (prefers-reduced-motion: reduce) {
    .site-header nav a::after { transition: none; }
  }
  /* スマホはタップ領域を最低44px相当まで広げる（誤タップ防止・WCAG 2.5.5） */
  @media (max-width: 640px) {
    .site-header nav a { padding-block: 0.62rem; }
    .site-header nav a::after { bottom: 0.42rem; }
  }

  .site-footer {
    border-top: 1px solid var(--line);
    padding: 1.5rem 1rem 2.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .site-footer a { margin: 0 0.4rem; }

  /* ダイヤ型のセクションナビ */
  .foot-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.7rem, 2.4vw, 1.6rem);
    margin: 0.5rem auto 2.2rem;
    padding: 0.6rem 0;
  }
  .foot-diamond {
    margin: 0 !important;
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.25rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--card);
    text-decoration: none;
    transition: background 0.25s ease;
  }
  .foot-diamond span {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--accent-strong);
    white-space: nowrap;
  }
  .foot-diamond:hover {
    background: var(--accent);
  }
  .foot-diamond:hover span { color: #fffdf8; }

  .foot-brand {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    margin: 0 0 1.4rem;
  }
  /* 行灯グロー：ブランド背後に暖色の柔らかい灯り。常時は静止、画面内のときだけゆっくり明滅 */
  .foot-brand::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 46%;
    width: 230px;
    height: 130px;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(216, 170, 92, 0.20), rgba(216, 170, 92, 0) 70%);
    z-index: -1;
    pointer-events: none;
  }
  @keyframes andonGlow { 0%, 100% { opacity: 0.7; } 50% { opacity: 1; } }
  @media (prefers-reduced-motion: no-preference) {
    .foot-brand.in-view::before { animation: andonGlow 5.5s ease-in-out infinite; }
  }
  .foot-brand__name {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    letter-spacing: 0.12em;
    color: var(--text);
  }
  .foot-brand__en {
    font-family: var(--font-logo);
    font-size: 0.72rem;
    letter-spacing: 0.34em;
    color: var(--accent-strong);
  }
  @media (prefers-reduced-motion: reduce) {
    .foot-diamond { transition: none; }
  }

  /* 公式SNS（円形アイコン） */
  .social-icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin: 0 0 1.1rem;
  }
  .social-icons a {
    margin: 0 !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--accent);
    border-radius: 999px;
    background: var(--card);
    color: var(--accent-strong);
    transition: background 0.25s ease, color 0.25s ease;
  }
  .social-icons a:hover { background: var(--accent); color: #fffdf8; }
  .social-icons svg { width: 20px; height: 20px; display: block; }
  @media (prefers-reduced-motion: reduce) {
    .social-icons a { transition: none; }
  }

  .foot-copy {
    margin: 1.4rem 0 0;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .foot-copy a { margin: 0; }

  .placeholder-note {
    background: var(--card);
    border: 1px dashed var(--line);
    border-radius: 8px;
    padding: 1rem;
    color: var(--muted);
  }
</style>

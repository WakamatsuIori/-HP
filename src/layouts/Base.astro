---
import { site } from '../config/site';
import LastUpdated from '../components/LastUpdated.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} | ${site.name}` : site.name;

// OGP/正規URL用の絶対URL（Astro.site = astro.config.mjs の site から生成）
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og.jpg', Astro.site); // SNSシェアカードの画像（横長キービジュアル）

// ナビの現在地判定（現在ページのリンクに下線を付ける）
const currentPath = Astro.url.pathname;
const isActiveNav = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

// トップは1ページ縦スクロールのLP。ナビは画面内アンカーへ（他ページからはトップの該当位置へ戻る）。
const nav = [
  { href: '/', label: 'トップ' },
  { href: '/#profile', label: 'プロフィール' },
  { href: '/#schedule', label: 'スケジュール' },
  { href: '/#videos', label: '動画' },
  { href: '/#goods', label: 'グッズ' },
  { href: '/#work', label: 'お仕事依頼' },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* OGP / Twitter カード（SNSシェア時のカード表示。画像は全ページ共通のキービジュアル）
        ※ 構造化データ(JSON-LD)・GA等の本格SEOは Phase 3 で実装 */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* 見出し・ロゴ用の明朝（サブセット済み・全ページのヘッダーで使うため先読み） */}
    <link
      rel="preload"
      href="/fonts/zen-old-mincho-medium.subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">{site.name}</a>
      <nav>
        <ul>
          {nav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActiveNav(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p class="official-links">
        公式リンク：
        <a href={site.links.youtube} rel="me noopener" target="_blank">YouTube</a>
        <a href={site.links.x} rel="me noopener" target="_blank">X</a>
        <a href={site.links.booth} rel="me noopener" target="_blank">BOOTH</a>
      </p>
      <p class="footer-nav">
        <a href="/guidelines">ガイドライン</a>
        <a href="/privacy">プライバシーポリシー</a>
      </p>
      <LastUpdated />
    </footer>
  </body>
</html>

<style is:global>
  /* 見出し・ロゴ専用の明朝（使う文字だけのサブセット woff2・約50KB）。
     本文はシステムフォントのまま＝軽量維持。再生成は scripts/subset_fonts.py。 */
  @font-face {
    font-family: 'Zen Old Mincho';
    src: url('/fonts/zen-old-mincho-medium.subset.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap; /* 読み込み中はシステム明朝で即表示→差し替え（描画ブロックなし） */
  }
  :root {
    --bg: #faf9f6;
    --text: #423f38;
    --muted: #8a8474;
    --accent: #9c8f6b;        /* くすみ金：見出し装飾・大きいアクセント用 */
    --accent-strong: #6f6444; /* 濃い金：本文リンク等の小さい文字用（白背景でAAコントラスト確保） */
    --line: #e7e3d9;
    --card: #ffffff;
    --font-serif: 'Zen Old Mincho', 'Hiragino Mincho ProN', 'Yu Mincho', 'Noto Serif JP', serif;
  }
  * { box-sizing: border-box; }
  html { color-scheme: light; overflow-x: clip; } /* 100vwのフルブリードで横スクロールを出さない（縦は保持） */
  /* LPの画面内アンカー移動をなめらかに（動きが苦手な設定の人には無効） */
  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }
  body {
    margin: 0;
    font-family: 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', 'Yu Gothic', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
    letter-spacing: 0.02em;
    overflow-x: clip;
  }
  a { color: var(--accent-strong); }
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.75rem 1.25rem 3.5rem;
  }
  h1, h2, h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1.5;
  }
  h1 { font-size: 1.55rem; }
  /* h2：上品な金のアクセント（細い全幅ライン＋見出し先頭の金タブ） */
  h2 {
    position: relative;
    font-size: 1.2rem;
    margin-top: 2.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--line);
  }
  h2::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 2.5rem;
    height: 2px;
    background: var(--accent);
  }

  .site-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 1rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line);
    background: var(--card);
  }
  .site-header .brand {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-decoration: none;
    color: var(--text);
  }
  .site-header nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-header nav a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.9rem;
    padding-bottom: 2px;
    border-bottom: 1.5px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .site-header nav a:hover {
    color: var(--text);
  }
  .site-header nav a[aria-current='page'] {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .site-footer {
    border-top: 1px solid var(--line);
    padding: 1.5rem 1rem 2.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .site-footer a { margin: 0 0.4rem; }

  .placeholder-note {
    background: var(--card);
    border: 1px dashed var(--line);
    border-radius: 8px;
    padding: 1rem;
    color: var(--muted);
  }
</style>

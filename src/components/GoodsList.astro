---
import type { Goods } from '../lib/booth';

interface Props {
  goods: Goods[];
}
const { goods } = Astro.props;
---

{
  goods.length === 0 ? (
    <p class="placeholder-note">
      現在掲載できるグッズがありません。BOOTHに商品が並ぶと自動で表示されます。
    </p>
  ) : (
    <ul class="goods-grid">
      {goods.map((g) => (
        <li class="goods-card">
          <a href={g.url} rel="noopener" target="_blank">
            <span class="goods-thumb">
              {g.imageUrl ? (
                <img src={g.imageUrl} alt="" loading="lazy" decoding="async" />
              ) : (
                <span class="goods-noimg" aria-hidden="true">No Image</span>
              )}
            </span>
            <span class="goods-title">{g.title}</span>
            {g.price && <span class="goods-price">{g.price}</span>}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .goods-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .goods-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
  }
  .goods-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--text);
  }
  .goods-thumb {
    display: block;
    aspect-ratio: 1 / 1;
    background: var(--bg);
  }
  .goods-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .goods-noimg {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--muted);
    font-size: 0.8rem;
  }
  .goods-title {
    padding: 0.5rem 0.6rem 0;
    font-size: 0.85rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .goods-price {
    padding: 0.15rem 0.6rem 0.6rem;
    margin-top: auto;
    color: var(--accent-strong);
    font-weight: 600;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
</style>

---
/**
 * セクション見出し（大きな英字のウォーターマーク＋日本語サブ＋アールデコ調の金の区切り）。
 * index.astro の各セクションで使う共通見出し。
 */
interface Props {
  kicker: string; // 大英字（例: SCHEDULE）
  title: string;  // 日本語サブ（例: 今週の予定）
}
const { kicker, title } = Astro.props;
// 区切り線の金グラデ用に、セクションごとに一意なグラデIDを作る（同一ページ内のid重複を回避）
const gradId = `dl-gold-${kicker.replace(/[^a-zA-Z0-9]/g, '') || 'x'}`;
---

<div class="section-head">
  <p class="section-kicker">{kicker}</p>
  <h2>{title}</h2>
  <span class="section-divider-wrap" aria-hidden="true">
    <svg class="section-divider" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 40">
      <defs>
        <!-- 金グラデ罫：中央が濃く、外へ向かうほど淡く溶ける（上品な底上げ・両モード共通） -->
        <linearGradient id={gradId} x1="0" y1="0" x2="400" y2="0" gradientUnits="userSpaceOnUse">
          <stop offset="0" stop-color="#c2a86b" stop-opacity="0.12"/>
          <stop offset="0.5" stop-color="#cda14e"/>
          <stop offset="1" stop-color="#c2a86b" stop-opacity="0.12"/>
        </linearGradient>
      </defs>
      <!-- 左線：x1=165→x2=0 で中央から外へ描画 -->
      <line class="dl" x1="165" y1="20" x2="0" y2="20"
            stroke={`url(#${gradId})`} stroke-width="1.4" pathLength="1"/>
      <!-- 右線：x1=235→x2=400 で中央から外へ描画 -->
      <line class="dl" x1="235" y1="20" x2="400" y2="20"
            stroke={`url(#${gradId})`} stroke-width="1.4" pathLength="1"/>
      <!-- 中央装飾：少し遅れてフェードイン -->
      <g class="dl-center">
        <circle cx="178" cy="20" r="2.2" fill="#c2a86b"/>
        <circle cx="222" cy="20" r="2.2" fill="#c2a86b"/>
        <g transform="translate(200,20)">
          <path d="M0 -11 L9 0 L0 11 L-9 0 Z" fill="#c2a86b" stroke="#c2a86b" stroke-width="1.2"/>
          <circle cx="0" cy="0" r="2.5" fill="#1b110a" stroke="none"/>
        </g>
      </g>
    </svg>
  </span>
</div>

<style>
  .section-head {
    position: relative;
    text-align: center;
    margin: 0 auto 1.15rem;
    line-height: 1;
  }

  /* ── clip-path reveal 初期状態 ── */
  .section-kicker {
    margin: 0;
    font-family: var(--font-logo);
    font-size: clamp(2.05rem, 7.5vw, 3.6rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 1;
    color: rgba(156, 143, 107, 0.55);
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.65s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .section-head h2 {
    display: block;
    margin: 0.2rem 0 0;
    padding: 0;
    border-bottom: none;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: var(--text);
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.12s;
  }
  .section-head h2::after { content: none; }

  /* ── .is-visible で全演出を起動 ── */
  .section-head.is-visible .section-kicker {
    clip-path: inset(0 0% 0 0);
  }
  .section-head.is-visible h2 {
    clip-path: inset(0 0% 0 0);
  }

  /* 区切り線ラッパー */
  .section-divider-wrap {
    display: block;
    text-align: center;
    margin-top: 0.4rem;
    line-height: 0;
  }
  .section-divider {
    width: 172px;
    height: 17px;
    overflow: visible;
  }

  /* SVG ドロー演出（.section-head.is-visible から発火） */
  .dl {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 0.75s ease-out 0.2s;
  }
  .dl-center {
    opacity: 0;
    transition: opacity 0.3s ease 0.75s;
  }
  .section-head.is-visible .dl {
    stroke-dashoffset: 0;
  }
  .section-head.is-visible .dl-center {
    opacity: 1;
  }

  /* 動きを減らす設定のユーザーには即表示 */
  @media (prefers-reduced-motion: reduce) {
    .section-kicker,
    .section-head h2 { clip-path: none; transition: none; }
    .dl { transition: none; stroke-dashoffset: 0; }
    .dl-center { transition: none; opacity: 1; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.4 }
  );
  document.querySelectorAll('.section-head').forEach((el) => observer.observe(el));
</script>

---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ScheduleList from '../components/ScheduleList.astro';
import { site } from '../config/site';
import { loadSchedule } from '../lib/loadSchedule';
import heroArt from '../assets/Wakamatsu_full_size.png';

const events = await loadSchedule();
const next = events[0] ?? null;
const next3 = events.slice(0, 3);
---

<Base>
  <section class="hero">
    <Image
      class="hero-art"
      src={heroArt}
      width={520}
      alt={`${site.name}の立ち絵`}
      loading="eager"
    />
    <div class="hero-info">
      <p class="hero-name">{site.name}</p>
      {
        next ? (
          <div class="countdown" data-start={next.start.toISOString()}>
            <p class="cd-label">次の配信まで</p>
            <p class="cd-time" data-cd>—</p>
            <p class="cd-next-title">{next.title}</p>
          </div>
        ) : (
          <p class="cd-label">次の配信は調整中です</p>
        )
      }
    </div>
  </section>

  <h2>次の配信</h2>
  <ScheduleList events={next3} />
  <p class="more-link"><a href="/schedule">スケジュールをすべて見る →</a></p>

  <h2>最新動画</h2>
  <p class="placeholder-note">最新動画の自動表示は準備中です（Phase 2で実装）。</p>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    padding: 1rem 0 1.5rem;
  }
  .hero-art {
    width: min(72%, 300px);
    height: auto;
  }
  .hero-info {
    width: 100%;
  }
  .hero-name {
    font-family: var(--font-serif);
    font-size: 1.45rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    margin: 0 0 0.85rem;
  }
  .countdown {
    display: inline-block;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.8rem 1.6rem;
  }
  .cd-label {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .cd-time {
    margin: 0.15rem 0;
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .cd-next-title {
    margin: 0;
    font-size: 0.95rem;
  }
  .more-link {
    text-align: right;
  }
  @media (min-width: 640px) {
    .hero {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      text-align: left;
      gap: 2rem;
    }
    .hero-info {
      width: auto;
    }
  }
</style>

<script>
  // 次の配信開始までのカウントダウン（情報表示。1分ごとに更新）
  const el = document.querySelector<HTMLElement>('.countdown');
  const out = el?.querySelector<HTMLElement>('[data-cd]');
  const startMs = el?.dataset.start ? Date.parse(el.dataset.start) : NaN;
  let timer: ReturnType<typeof setInterval> | undefined;

  function render() {
    if (!out || Number.isNaN(startMs)) return;
    const diff = startMs - Date.now();
    if (diff <= 0) {
      out.textContent = 'まもなく';
      if (timer) clearInterval(timer); // 配信時刻を過ぎたら更新を止める
      return;
    }
    const days = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins = Math.floor((diff % 3_600_000) / 60_000);
    out.textContent = (days > 0 ? `${days}日 ` : '') + `${hours}時間 ${mins}分`;
  }

  render();
  timer = setInterval(render, 60_000);
</script>

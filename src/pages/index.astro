<script>
  // 次の配信開始までのカウントダウン（情報表示。1分ごとに更新）
  const el = document.querySelector<HTMLElement>('.countdown');
  const out = el?.querySelector<HTMLElement>('[data-cd]');
  const startMs = el?.dataset.start ? Date.parse(el.dataset.start) : NaN;
  let timer: ReturnType<typeof setInterval> | undefined;

  function render() {
    if (!out || Number.isNaN(startMs)) return;
    const diff = startMs - Date.now();
    if (diff <= 0) {
      out.textContent = 'まもなく';
      if (timer) clearInterval(timer); // 配信時刻を過ぎたら更新を止める
      return;
    }
    const days = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins = Math.floor((diff % 3_600_000) / 60_000);
    out.textContent = (days > 0 ? `${days}日 ` : '') + `${hours}時間 ${mins}分`;
  }

  render();
  timer = setInterval(render, 60_000);

  // スクロールで各セクションをふわっと表示（画面に入ったら is-visible を付与）
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if (revealEls.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    revealEls.forEach((el) => io.observe(el));
  }
</script>

---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import VideoList from '../components/VideoList.astro';
import LiveBadge from '../components/LiveBadge.astro';
import WeeklyBoard from '../components/WeeklyBoard.astro';
import { site } from '../config/site';
import { loadSchedule } from '../lib/loadSchedule';
import { loadVideos } from '../lib/loadVideos';
import type { LiveStatus, Video } from '../lib/youtube';
import type { StreamEvent } from '../lib/ics';
import keyVisual from '../assets/IMG_5833.png'; // 横長キービジュアル（グレー背景）
import heroArt from '../assets/Wakamatsu_full_size.png'; // 立ち絵（ABOUTで使用）

// レイアウト確認用の仮予定（dev かつ実データが空のときだけ表示。本番=実データのみで安全）。
function buildSampleEvents(): StreamEvent[] {
  const base = Date.now();
  const DAY = 86_400_000;
  const mk = (offDays: number, hour: number, title: string): StreamEvent => {
    const start = new Date(base + offDays * DAY);
    start.setHours(hour, 0, 0, 0);
    return { id: `sample-${offDays}-${hour}`, title, description: '', start, end: new Date(start.getTime() + 90 * 60_000) };
  };
  return [
    mk(1, 21, '【雑談】夜のカフェタイム（仮）'),
    mk(1, 23, '【ゲーム】〇〇 初見プレイ（仮）'),
    mk(3, 20, '【歌枠】まったり弾き語り（仮）'),
    mk(6, 21, '【コラボ】〇〇さんと（仮）'),
  ];
}

const events = await loadSchedule();
const previewEvents = import.meta.env.DEV && events.length === 0 ? buildSampleEvents() : [];
const allEvents = events.length ? events : previewEvents;
const next = allEvents[0] ?? null;

// 動画(YouTube)はトップの主役ではないので、未設定・取得失敗でもトップ全体は表示を続ける。
// （/videos ページは従来どおり厳格＝設定漏れはビルド失敗のまま。CLAUDE.md §4）
let latestTop: Video[] = [];
let live: LiveStatus = { isLive: false, liveVideo: null };
try {
  const v = await loadVideos();
  latestTop = v.latest.slice(0, 6);
  live = v.live;
} catch (err) {
  console.warn('[index] 動画の取得に失敗。トップは動画枠を準備中にして継続:', err instanceof Error ? err.message : err);
}
---

<Base>
  {/* JS有効時のみ出現アニメの初期非表示を効かせる（JS無効/クローラーでは内容がそのまま見える） */}
  <script is:inline>document.documentElement.classList.add('js');</script>

  {/* ===== ヒーロー：キービジュアルを主役にしたシネマティックな第一印象 ===== */}
  <section class="hero2" id="top">
    <Image
      class="hero2__bg"
      src={keyVisual}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      alt={`${site.name}のキービジュアル`}
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero2__scrim" aria-hidden="true"></div>
    <div class="hero2__sparkles" aria-hidden="true">
      <span class="spark" style="left: 14%; top: 20%;"></span>
      <span class="spark" style="left: 78%; top: 16%;"></span>
      <span class="spark" style="left: 88%; top: 52%;"></span>
      <span class="spark" style="left: 24%; top: 70%;"></span>
      <span class="spark" style="left: 62%; top: 34%;"></span>
      <span class="spark" style="left: 46%; top: 12%;"></span>
    </div>
    <div class="hero2__content">
      <div class="hero2__text">
        <p class="kicker">個人勢VTuber ・ Cafe &amp; Bar</p>
        <h1 class="hero2__name">{site.name}</h1>
        <p class="hero2__romaji">WAKAMATSU IORI</p>
        <p class="hero2__tag">雑談とゲームを肴に、ゆるりと楽しい夜を。<br />ようこそ、隠れ家カフェ＆バーへ。</p>

        <LiveBadge live={live} />
        {
          next ? (
            <div class="countdown" data-start={next.start.toISOString()}>
              <span class="cd-label">次の配信まで</span>
              <span class="cd-time" data-cd>—</span>
              <span class="cd-next-title">{next.title}</span>
            </div>
          ) : (
            <p class="cd-label cd-label--solo">次の配信は調整中です</p>
          )
        }

        <div class="hero2__cta">
          <a class="btn btn-gold" href={site.links.youtube} rel="me noopener" target="_blank">▶ 最新の配信を見る</a>
          <a class="btn btn-ghost" href="/schedule">配信スケジュール</a>
        </div>
      </div>
    </div>
  </section>

  {/* ===== PROFILE：一番の売り。誰が・何をしている人かを伝える（項目は仮・要差し替え） ===== */}
  <section class="lp-section" id="profile">
    <div class="lp-inner welcome reveal">
      <div class="welcome__art">
        <Image
          src={heroArt}
          widths={[480, 720, 960, 1320]}
          sizes="(min-width: 900px) 660px, 82vw"
          alt={`${site.name}の立ち絵`}
          loading="lazy"
        />
      </div>
      <div class="welcome__body">
        <p class="section-kicker">PROFILE</p>
        <h2>ようこそ、和香松庵へ</h2>
        <p class="welcome__lead">
          皆さん、初めまして！　カフェ＆バーの店長、個人勢VTuberの<strong>和香松 庵</strong>です。
          雑談やゲーム配信をメインに、いろいろなことに挑戦しながら、楽しさ・面白さを共有していきます。
          グラス片手に、ゆるりとお立ち寄りください。
        </p>
        <dl class="profile-list">
          <div class="profile-row"><dt>名前</dt><dd>和香松 庵（わかまつ いおり）</dd></div>
          <div class="profile-row"><dt>設定</dt><dd>カフェ＆バーの店長</dd></div>
          <div class="profile-row"><dt>誕生日</dt><dd>〇月〇日（仮）</dd></div>
          <div class="profile-row"><dt>身長</dt><dd>〇〇cm（仮）</dd></div>
          <div class="profile-row"><dt>配信内容</dt><dd>雑談・ゲーム・歌（仮）</dd></div>
          <div class="profile-row"><dt>好きなもの</dt><dd>お酒・カクテル・〇〇（仮）</dd></div>
          <div class="profile-row"><dt>ファンネーム</dt><dd>〇〇（仮）</dd></div>
          <div class="profile-row"><dt>ハッシュタグ</dt><dd>#和香松庵 ／ #〇〇（仮）</dd></div>
        </dl>
        <ul class="chips">
          <li>雑談</li>
          <li>ゲーム実況</li>
          <li>いろいろ挑戦</li>
        </ul>
        <div class="welcome__cta">
          <a class="btn btn-gold sm" href={site.links.youtube} rel="me noopener" target="_blank">チャンネル登録</a>
          <a class="btn btn-ghost-dark sm" href={site.links.x} rel="me noopener" target="_blank">Xをフォロー</a>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="schedule">
    <div class="lp-inner reveal">
      <div class="section-head"><p class="section-kicker">SCHEDULE</p><h2>今週の予定</h2></div>
    </div>
    <div class="reveal"><WeeklyBoard /></div>
    <div class="lp-inner sched-foot">
      <p class="more-link"><a href="/schedule">スケジュールをすべて見る →</a></p>
    </div>
  </section>

  <section class="lp-section" id="videos">
    <div class="lp-inner reveal">
      <div class="section-head"><p class="section-kicker">VIDEO</p><h2>最新動画</h2></div>
      {
        latestTop.length > 0 ? (
          <>
            <VideoList videos={latestTop} />
            <p class="more-link"><a href="/videos">動画をすべて見る →</a></p>
          </>
        ) : (
          <p class="placeholder-note">最新動画はまもなく表示されます。</p>
        )
      }
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="goods">
    <div class="lp-inner reveal">
      <div class="section-head"><p class="section-kicker">GOODS</p><h2>グッズ</h2></div>
      <p class="sec-lead">オリジナルグッズは BOOTH にて販売中です。（自動掲載は準備中）</p>
      <div class="sec-cta">
        <a class="btn btn-gold sm" href={site.links.booth} rel="me noopener" target="_blank">BOOTHで見る</a>
      </div>
    </div>
  </section>

  <section class="lp-section" id="follow">
    <div class="lp-inner reveal">
      <div class="section-head"><p class="section-kicker">FOLLOW</p><h2>フォロー</h2></div>
      <p class="sec-lead">配信のお知らせや日常は各SNSで。チャンネル登録・フォローで応援よろしくお願いします。</p>
      <div class="sec-cta">
        <a class="btn btn-gold sm" href={site.links.youtube} rel="me noopener" target="_blank">YouTube</a>
        <a class="btn btn-ghost-dark sm" href={site.links.x} rel="me noopener" target="_blank">X (Twitter)</a>
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="work">
    <div class="lp-inner reveal">
      <div class="section-head"><p class="section-kicker">CONTACT</p><h2>お仕事のご依頼</h2></div>
      <p class="sec-lead">コラボ・企業案件などのご相談を受け付けています。詳細・ご連絡方法はこちらから。</p>
      <div class="sec-cta">
        <a class="btn btn-ghost-dark sm" href="/work">依頼内容・ご連絡方法 →</a>
      </div>
    </div>
  </section>

  {/* スライダー式の調整パネル（dev限定・右下）。ドラッグでサイズが即変わる。本番には出ない。 */}
  {
    import.meta.env.DEV && (
      <div id="tuner" class="tuner" data-open="false">
        <button type="button" id="tuner-toggle" class="tuner__toggle">🎛 サイズ調整</button>
        <div class="tuner__panel" id="tuner-panel"></div>
        <script is:inline>
          (() => {
            const TUNE = [
              { v: '--pf-art', label: '立ち絵 幅', min: 300, max: 720, step: 10, unit: 'px' },
              { v: '--pf-max', label: 'プロフ全幅', min: 900, max: 1500, step: 20, unit: 'px' },
              { v: '--pf-gap', label: '立ち絵⇄文', min: 1, max: 6, step: 0.25, unit: 'rem' },
              { v: '--pf-drop', label: '下げる量', min: 0, max: 8, step: 0.25, unit: 'rem' },
              { v: '--pf-heading', label: '見出し', min: 1.2, max: 3.5, step: 0.05, unit: 'rem' },
              { v: '--pf-lead', label: '本文', min: 0.9, max: 2, step: 0.02, unit: 'rem' },
              { v: '--pf-label', label: '項目ラベル', min: 0.9, max: 1.6, step: 0.02, unit: 'rem' },
              { v: '--pf-value', label: '項目の値', min: 0.9, max: 1.6, step: 0.02, unit: 'rem' },
              { v: '--wb-max', label: '週間ボード幅', min: 600, max: 1200, step: 20, unit: 'px' },
            ];
            const root = document.documentElement;
            const panel = document.getElementById('tuner-panel');
            const cur = (v) => parseFloat(getComputedStyle(root).getPropertyValue(v)) || 0;
            TUNE.forEach((t) => {
              const val = cur(t.v);
              const row = document.createElement('label');
              row.className = 'tuner__row';
              row.innerHTML =
                '<span class="tuner__name">' + t.label + '</span>' +
                '<input type="range" min="' + t.min + '" max="' + t.max + '" step="' + t.step + '" value="' + val + '">' +
                '<span class="tuner__val">' + val + t.unit + '</span>';
              const input = row.querySelector('input');
              const out = row.querySelector('.tuner__val');
              input.addEventListener('input', () => {
                root.style.setProperty(t.v, input.value + t.unit);
                out.textContent = input.value + t.unit;
              });
              panel.appendChild(row);
            });
            const copy = document.createElement('button');
            copy.type = 'button';
            copy.className = 'tuner__copy';
            copy.textContent = '現在値をコピー';
            copy.addEventListener('click', () => {
              const css = TUNE.map((t) => '    ' + t.v + ': ' + (root.style.getPropertyValue(t.v) || cur(t.v) + t.unit) + ';').join('\n');
              if (navigator.clipboard) navigator.clipboard.writeText(css);
              copy.textContent = 'コピーしました！';
              setTimeout(() => { copy.textContent = '現在値をコピー'; }, 1500);
            });
            panel.appendChild(copy);
            document.getElementById('tuner-toggle').addEventListener('click', () => {
              const el = document.getElementById('tuner');
              el.dataset.open = el.dataset.open === 'true' ? 'false' : 'true';
            });
          })();
        </script>
      </div>
    )
  }
</Base>

{/* ▼▼ 調整用パラメータ：ここの数値を変えると各サイズ・位置が変わります（手で動かせます） ▼▼ */}
<style is:global>
  :root {
    /* ヒーロー */
    --hero-h: clamp(440px, 80vh, 660px); /* ヒーローの高さ */
    --hero-name: clamp(3rem, 10vw, 5.2rem); /* 名前の大きさ */
    /* プロフィール（PCの横並び時に効く） */
    --pf-art: 660px; /* 立ち絵の最大幅 */
    --pf-drop: 3.75rem; /* 立ち絵の頭からプロフィールを下げる量 */
    --pf-gap: 1.5rem; /* 立ち絵⇄文章の間隔 */
    --pf-max: 1260px; /* プロフィール全体の最大幅 */
    --pf-heading: 3.5rem; /* 「ようこそ」見出し */
    --pf-lead: 1.44rem; /* 紹介文 */
    --pf-label: 1.26rem; /* プロフィール項目のラベル */
    --pf-value: 1.38rem; /* プロフィール項目の値 */
    /* 週間ボード（SCHEDULE） */
    --wb-max: 640px; /* 週間ボードの最大幅（位置はセクション中央） */
    --wb-pad: clamp(1.3rem, 3.2vw, 2.2rem); /* 週間ボードの内側余白 */
  }

  /* スライダー式の調整パネル（dev限定・右下）。ドラッグで各サイズが即変わる。 */
  .tuner { position: fixed; right: 12px; bottom: 12px; z-index: 99999; font-size: 12px; font-family: system-ui, sans-serif; }
  .tuner__toggle { background: #2a2620; color: #f3e7cf; border: 1px solid #cda14e; border-radius: 8px; padding: 0.45rem 0.8rem; cursor: pointer; box-shadow: 0 4px 14px rgba(0,0,0,.35); }
  .tuner__panel { display: none; margin-top: 6px; width: 290px; max-height: 72vh; overflow: auto; background: #1f1b16; color: #f3e7cf; border: 1px solid #cda14e; border-radius: 10px; padding: 0.8rem; box-shadow: 0 12px 34px rgba(0,0,0,.5); }
  .tuner[data-open="true"] .tuner__panel { display: block; }
  .tuner__row { display: grid; grid-template-columns: 5rem 1fr 3.6rem; align-items: center; gap: 0.4rem; margin-bottom: 0.45rem; }
  .tuner__name { color: #c4ab7e; }
  .tuner__row input[type="range"] { width: 100%; accent-color: #cda14e; }
  .tuner__val { text-align: right; color: #e8cf95; font-variant-numeric: tabular-nums; }
  .tuner__copy { margin-top: 0.6rem; width: 100%; background: #cda14e; color: #1b110a; border: none; border-radius: 7px; padding: 0.5rem; cursor: pointer; font-weight: 700; }
</style>

<style>
  /* ===== ヒーロー（明るい上品トーン：グレー背景KV＋クリームの霞＋濃い金） ===== */
  .hero2 {
    --h-ink: #3a352d; /* 濃い文字 */
    --h-gold: #7a6c45; /* 濃い金（明るい背景でも読める） */
    --h-bg: #e9e6df; /* 画像読み込み前のフォールバック（グレー寄り） */
    position: relative;
    /* main の左右パディングと上パディングを打ち消してフルブリード＋ヘッダー直下に密着 */
    width: 100vw;
    margin: -1.75rem calc(50% - 50vw) 2.5rem;
    min-height: var(--hero-h);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--h-bg);
    isolation: isolate;
  }
  .hero2__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 18%; /* 顔（上部中央）が切れないよう上寄せ */
    z-index: 0;
  }
  .hero2__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to top, rgba(250, 249, 246, 0.97) 0%, rgba(250, 249, 246, 0.84) 26%, rgba(250, 249, 246, 0.36) 52%, rgba(250, 249, 246, 0) 78%),
      linear-gradient(to right, rgba(250, 249, 246, 0.9) 0%, rgba(250, 249, 246, 0.42) 42%, rgba(250, 249, 246, 0) 66%);
  }
  .hero2__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4.5rem) clamp(1.25rem, 5vw, 4rem);
  }
  .hero2__text { max-width: 46rem; }
  .kicker {
    margin: 0 0 1rem;
    font-size: 0.86rem;
    letter-spacing: 0.3em;
    font-weight: 600;
    color: var(--h-gold);
    text-shadow: 0 1px 10px rgba(250, 249, 246, 0.95);
  }
  .hero2__name {
    font-family: var(--font-serif);
    color: var(--h-ink);
    font-size: var(--hero-name);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.08;
    margin: 0;
    text-shadow: 0 1px 18px rgba(250, 249, 246, 0.78);
  }
  .hero2__romaji {
    margin: 0.55rem 0 1.25rem;
    font-size: 0.82rem;
    letter-spacing: 0.44em;
    color: rgba(58, 53, 45, 0.55);
  }
  .hero2__tag {
    margin: 0 0 1.7rem;
    font-size: clamp(1.05rem, 2.8vw, 1.32rem);
    line-height: 1.95;
    color: rgba(58, 53, 45, 0.92);
  }
  /* ヒーロー内カウントダウン（明るいカード） */
  .countdown {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.7rem;
    margin: 0 0 1.5rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid rgba(122, 108, 69, 0.38);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.72);
  }
  .cd-label { margin: 0; font-size: 0.78rem; letter-spacing: 0.1em; color: rgba(58, 53, 45, 0.7); }
  .cd-label--solo { margin: 0 0 1.6rem; font-size: 0.9rem; }
  .cd-time { font-size: 1.32rem; font-weight: 600; color: var(--h-gold); font-variant-numeric: tabular-nums; }
  .cd-next-title { width: 100%; font-size: 0.88rem; color: rgba(58, 53, 45, 0.82); }

  .hero2__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.82rem 1.7rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }
  .btn.sm { padding: 0.7rem 1.5rem; font-size: 1.05rem; }
  .btn-gold { background: #6f6444; color: #faf9f6; }
  .btn-gold:hover { background: #847650; transform: translateY(-1px); }
  .btn-ghost { border: 1px solid rgba(122, 108, 69, 0.55); color: var(--h-gold); background: rgba(255, 255, 255, 0.55); }
  .btn-ghost:hover { background: rgba(122, 108, 69, 0.12); transform: translateY(-1px); }
  .btn-ghost-dark { border: 1px solid var(--accent); color: var(--accent-strong); }
  .btn-ghost-dark:hover { background: rgba(156, 143, 107, 0.1); transform: translateY(-1px); }

  /* ===== ようこそ（ABOUT）：明るく読みやすく ===== */
  .welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }
  .welcome__art { width: min(80%, 400px); }
  .welcome__art :global(img) { width: 100%; height: auto; }
  .kicker--dark { color: var(--accent-strong); text-shadow: none; }
  .welcome__lead { margin: 0.7rem 0 1.8rem; line-height: 2.05; font-size: var(--pf-lead); }

  /* プロフィール項目（VTuber定番・値は仮） */
  .profile-list { margin: 0 0 1.3rem; padding: 0; text-align: left; }
  .profile-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.3rem 1.4rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
  }
  .profile-row dt {
    margin: 0;
    position: relative;
    padding-left: 1.4rem;
    color: var(--muted);
    font-size: var(--pf-label);
    white-space: nowrap;
  }
  .profile-row dt::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 0.15em;
    color: var(--accent);
    font-size: 0.66rem;
  }
  .profile-row dd { margin: 0; font-size: var(--pf-value); }
  .welcome__lead strong { font-weight: 600; }
  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 0 1.3rem;
    padding: 0;
    list-style: none;
  }
  .chips li {
    padding: 0.5rem 1.45rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-size: 1.1rem;
    color: var(--accent-strong);
    background: rgba(156, 143, 107, 0.06);
  }
  .welcome__cta { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem; }

  .more-link { text-align: right; }
  .sched-foot { margin-top: 1.2rem; }

  /* ===== LP（1ページ縦スクロール）のセクション土台 ===== */
  /* 各セクションはフルブリード。中身は .lp-inner で読みやすい幅に収める。
     交互に淡い帯（--tint）を敷いて縦のリズムを出す。 */
  .lp-section {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-block: clamp(2.75rem, 6vw, 4.5rem);
    scroll-margin-top: 1rem;
  }
  /* 帯セクション：淡い色＋琥珀色の灯りボケ（バーの照明感） */
  .lp-section--tint {
    background:
      radial-gradient(42% 55% at 14% 18%, rgba(201, 168, 105, 0.1), transparent 62%),
      radial-gradient(38% 50% at 86% 82%, rgba(201, 168, 105, 0.08), transparent 60%),
      #f3f0e7;
  }
  .lp-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  /* セクション見出し：大きな英字のウォーターマーク＋日本語サブ（参考サイトの手法を金で翻訳） */
  .section-head {
    position: relative;
    text-align: center;
    margin: 0 auto 1.7rem;
    padding-bottom: 1.3rem;
    line-height: 1;
  }
  /* アールデコ調の区切り（金の細線＋中央のひし形） */
  .section-head::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.5rem;
    transform: translateX(-50%);
    width: 76px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent) 50%, transparent);
  }
  .section-head::before {
    content: '';
    position: absolute;
    left: 50%;
    bottom: calc(0.5rem - 3.5px);
    transform: translateX(-50%) rotate(45deg);
    width: 7px;
    height: 7px;
    background: var(--accent);
    z-index: 1;
  }
  .section-kicker {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 9vw, 4.6rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 1;
    color: rgba(156, 143, 107, 0.38); /* 薄い金のウォーターマーク */
  }
  .section-head h2 {
    display: block;
    margin: 0.35rem 0 0;
    padding: 0;
    border-bottom: none;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: var(--text);
  }
  .section-head h2::after { content: none; } /* 大英字がアクセントなのでグローバルの金タブは消す */

  /* ようこそ(ABOUT)の見出しも同じ大英字スタイルに揃える（左寄せ） */
  .welcome__body h2 {
    margin: 0.4rem 0 1rem;
    padding: 0;
    border-bottom: none;
    font-size: var(--pf-heading);
  }
  .welcome__body h2::after { content: none; }

  .sec-lead { text-align: center; margin: 0 auto 1.1rem; max-width: 34rem; }
  .sec-cta { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem; }

  @media (min-width: 900px) {
    .welcome {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: var(--pf-gap);
      max-width: var(--pf-max);
    }
    .welcome__art { flex-shrink: 0; width: min(48%, var(--pf-art)); }
    .welcome__body { margin-top: var(--pf-drop); }
    .chips, .welcome__cta { justify-content: flex-start; }
  }

  /* ===== 控えめな登場アニメ（トップのみ・reduced-motionで無効） ===== */
  @media (prefers-reduced-motion: no-preference) {
    .hero2__text > * { animation: fadeUp 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
    .hero2__text > :nth-child(2) { animation-delay: 0.06s; }
    .hero2__text > :nth-child(3) { animation-delay: 0.12s; }
    .hero2__text > :nth-child(4) { animation-delay: 0.18s; }
    .hero2__text > :nth-child(5) { animation-delay: 0.24s; }
    .hero2__text > :nth-child(6) { animation-delay: 0.3s; }
    .hero2__text > :nth-child(7) { animation-delay: 0.36s; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* ===== スクロールで現れる（JS有効時のみ初期非表示／JS無効・クローラーでは内容そのまま） ===== */
  :global(html.js) .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :global(html.js) .reveal.is-visible { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .reveal { opacity: 1; transform: none; transition: none; }
  }

  /* ===== ヒーローの金のきらめき（控えめ・reduced-motionでは消灯） ===== */
  .hero2__sparkles { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  .spark {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201, 168, 105, 0.95) 0%, rgba(201, 168, 105, 0) 70%);
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .spark { animation: twinkle 4.5s ease-in-out infinite; }
    .spark:nth-child(2) { animation-delay: 0.7s; }
    .spark:nth-child(3) { animation-delay: 1.5s; }
    .spark:nth-child(4) { animation-delay: 2.2s; }
    .spark:nth-child(5) { animation-delay: 3s; }
    .spark:nth-child(6) { animation-delay: 3.8s; }
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 0.85; transform: scale(1); }
  }
</style>

<script>
  // 次の配信開始までのカウントダウン（情報表示。1分ごとに更新）
  const el = document.querySelector<HTMLElement>('.countdown');
  const out = el?.querySelector<HTMLElement>('[data-cd]');
  const startMs = el?.dataset.start ? Date.parse(el.dataset.start) : NaN;
  let timer: ReturnType<typeof setInterval> | undefined;

  function render() {
    if (!out || Number.isNaN(startMs)) return;
    const diff = startMs - Date.now();
    if (diff <= 0) {
      out.textContent = 'まもなく';
      if (timer) clearInterval(timer); // 配信時刻を過ぎたら更新を止める
      return;
    }
    const days = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins = Math.floor((diff % 3_600_000) / 60_000);
    out.textContent = (days > 0 ? `${days}日 ` : '') + `${hours}時間 ${mins}分`;
  }

  render();
  timer = setInterval(render, 60_000);

  // スクロールで各セクションをふわっと表示（画面に入ったら is-visible を付与）
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if (revealEls.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    revealEls.forEach((el) => io.observe(el));
  }
</script>

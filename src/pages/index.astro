---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import VideoList from '../components/VideoList.astro';
import LiveBadge from '../components/LiveBadge.astro';
import WeeklyBoard from '../components/WeeklyBoard.astro';
import SectionHead from '../components/SectionHead.astro';
import { site } from '../config/site';
import { loadSchedule, loadWeekEvents } from '../lib/loadSchedule';
import { loadVideos } from '../lib/loadVideos';
import type { LiveStatus, Video } from '../lib/youtube';
import type { StreamEvent } from '../lib/ics';
import { buildWeek } from '../lib/weekly';
import { externalAttrs } from '../lib/links';
import { intro, profile } from '../config/profile';
import { information } from '../config/information';
import { featuredLabels } from '../config/featured';
import keyVisual from '../assets/IMG_5833.png'; // 横長キービジュアル（グレー背景）
import heroArt from '../assets/Wakamatsu_full_size.png'; // 立ち絵（PROFILEで使用）
import barArt from '../assets/wakamatsusan_.png'; // トレイ＆カクテルの立ち絵（ABOUTで使用）

// レイアウト確認用の仮予定（dev かつ実データが空のときだけ表示。本番=実データのみで安全）。
function buildSampleEvents(): StreamEvent[] {
  const base = Date.now();
  const DAY = 86_400_000;
  const mk = (offDays: number, hour: number, title: string): StreamEvent => {
    const start = new Date(base + offDays * DAY);
    start.setHours(hour, 0, 0, 0);
    return { id: `sample-${offDays}-${hour}`, title, description: '', start, end: new Date(start.getTime() + 90 * 60_000) };
  };
  return [
    mk(1, 21, '【雑談】夜のカフェタイム（仮）'),
    mk(1, 23, '【ゲーム】〇〇 初見プレイ（仮）'),
    mk(3, 20, '【歌枠】まったり弾き語り（仮）'),
    mk(6, 21, '【コラボ】〇〇さんと（仮）'),
  ];
}

// カウントダウン「次の配信」用＝これから先の予定だけ（従来どおり）。
const events = await loadSchedule();
const previewEvents = import.meta.env.DEV && events.length === 0 ? buildSampleEvents() : [];
const allEvents = events.length ? events : previewEvents;
const next = allEvents[0] ?? null;

// 週間ボード用＝今週の月曜〜来週の日曜の全予定（過去日も残す＝消化済みが「休業」に化けない）。
const weekEvents = await loadWeekEvents();
// devで実データが空のときだけ、ボードの既定サンプルでレイアウト確認できるようにする。
const showSample = import.meta.env.DEV && weekEvents.length === 0;
const nowDate = new Date();
const weekData = showSample ? null : buildWeek(weekEvents, nowDate, 0);
const nextWeekData = showSample ? null : buildWeek(weekEvents, nowDate, 1);

// 動画(YouTube)はトップの主役ではないので、未設定・取得失敗でもトップ全体は表示を続ける。
// （/videos ページは従来どおり厳格＝設定漏れはビルド失敗のまま。CLAUDE.md §4）
let latestTop: Video[] = [];
let live: LiveStatus = { isLive: false, liveVideo: null };
// おすすめ（PICK UP）：固定指定があればその動画、無ければ最新上位3本（loadVideos側で決定）
let featured: Video[] = [];
try {
  const v = await loadVideos();
  latestTop = v.latest.slice(0, 4);
  live = v.live;
  featured = v.featured;
} catch (err) {
  console.warn('[index] 動画の取得に失敗。トップは動画枠を準備中にして継続:', err instanceof Error ? err.message : err);
}
---

<Base>
  {/* JS有効時のみ出現アニメの初期非表示を効かせる（JS無効/クローラーでは内容がそのまま見える） */}
  <script is:inline>document.documentElement.classList.add('js');</script>

  {/* ===== ヒーロー：キービジュアルを主役にしたシネマティックな第一印象 ===== */}
  <section class="hero2" id="top">
    <Image
      class="hero2__bg"
      src={keyVisual}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      alt={`${site.name}のキービジュアル`}
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero2__scrim" aria-hidden="true"></div>
    <div class="hero2__sparkles" aria-hidden="true">
      {/* 位置はCSSの :nth-child で指定（インラインstyleを使わない） */}
      <span class="spark"></span>
      <span class="spark"></span>
      <span class="spark"></span>
      <span class="spark"></span>
      <span class="spark"></span>
      <span class="spark"></span>
    </div>
    {/* 掛軸風の縦書きアクセント（装飾・デスクトップのみ。読み上げは主見出しがあるので除外） */}
    <p class="hero2__vertical" aria-hidden="true">和香松庵</p>
    <div class="hero2__content">
      <div class="hero2__text">
        <p class="kicker">Cafe &amp; Bar の店長 ・ 個人勢VTuber</p>
        <h1 class="hero2__name">{site.name}</h1>
        <p class="hero2__romaji">WAKAMATSU IORI</p>
        <p class="hero2__tag">雑談とゲームを肴に、ゆるりと楽しい夜を。<br />ようこそ、隠れ家カフェ＆バーへ。</p>

        <LiveBadge live={live} />
        {
          /* 配信中はカウントダウンを出さない（「配信中」と「次の配信まで」の二重表示を防ぐ） */
          !live.isLive &&
            (next ? (
              <div class="countdown" data-start={next.start.toISOString()}>
                <span class="cd-label">次の配信まで</span>
                <span class="cd-time" data-cd>—</span>
                <span class="cd-next-title">{next.title}</span>
              </div>
            ) : (
              <p class="cd-label cd-label--solo">次の配信は調整中です</p>
            ))
        }

        <div class="hero2__cta">
          {/* 主CTA＝今週の予定（来店感・押し売りにならない導線）。フォロー導線はFOLLOW/フッターに集約 */}
          <a class="btn btn-gold" href="#schedule">今週の予定を見る ↓</a>
          <a class="btn btn-ghost" href={site.links.youtube} rel="me noopener" target="_blank">YouTubeチャンネルへ</a>
        </div>
      </div>
    </div>
  </section>

  {/* ヒーロー直下：最新お知らせ1件の細いバー（押すと下のお知らせ欄へスクロール） */}
  {
    information.length > 0 && (
      <a class="newsbar" href="#information">
        <span class="newsbar__tag">✦ NEW</span>
        <time class="newsbar__date">{information[0]?.date}</time>
        <span class="newsbar__title">{information[0]?.title}</span>
        <span class="newsbar__more">お知らせへ <span aria-hidden="true">→</span></span>
      </a>
    )
  }

  {/* ===== PROFILE：プロフィール項目（表）＋ごあいさつ（テキスト左＋立ち絵右） ===== */}
  <section class="lp-section" id="profile">
    {/* プロフィール項目（立ち絵左＋表右） */}
    <div class="profile reveal">
      <div class="profile__art">
        <Image
          src={heroArt}
          widths={[480, 720, 960, 1320]}
          sizes="(min-width: 900px) 660px, 82vw"
          alt={`${site.name}の立ち絵`}
          loading="lazy"
        />
      </div>
      <div class="profile__body">
        <p class="section-kicker">PROFILE</p>
        <dl class="profile-list">
          {profile.rows.map((row) => (
            <div class="profile-row"><dt>{row.label}</dt><dd>{row.value}</dd></div>
          ))}
        </dl>
        <ul class="chips">
          {profile.chips.map((chip) => (<li>{chip}</li>))}
        </ul>
      </div>
    </div>

    {/* ごあいさつ（テキスト左＋立ち絵右） */}
    <div class="about reveal">
      <div class="about__body">
        <h2 class="about__catch">{intro.catchLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</h2>
        <p class="about__catch-en">{intro.catchEn}</p>
        <span class="about__rule" aria-hidden="true"></span>
        <div class="about__story">
          {intro.story.map((para) => (<p>{para}</p>))}
        </div>
      </div>
      <div class="about__art">
        <Image
          src={barArt}
          widths={[480, 720, 960, 1320]}
          sizes="(min-width: 900px) 500px, 86vw"
          alt={`${site.name}の立ち絵（カクテルをお届け）`}
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="schedule">
    <div class="lp-inner reveal">
      <SectionHead kicker="SCHEDULE" title="今週の予定" />
    </div>
    <div class="sched-grid reveal">
      <div class="sched-col">
        {
          weekData ? (
            <WeeklyBoard label="今週" month={weekData.month} range={weekData.range} days={weekData.days} />
          ) : (
            <WeeklyBoard label="今週" />
          )
        }
      </div>
      <div class="sched-col">
        {
          nextWeekData ? (
            <WeeklyBoard label="来週" month={nextWeekData.month} range={nextWeekData.range} days={nextWeekData.days} />
          ) : (
            <WeeklyBoard label="来週" />
          )
        }
      </div>
    </div>
    <div class="lp-inner sched-foot">
      <p class="more-link"><a href="/schedule">スケジュールをすべて見る →</a></p>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="lp-section" id="pickup">
        <div class="lp-inner reveal">
          <SectionHead kicker="PICK UP" title="おすすめ" />
        </div>
        <ul class="pickup-grid reveal">
            {featured.map((v, i) => (
              <li class="pickup-card">
                <a href={v.url} rel="noopener" target="_blank">
                  <span class="pickup-bubble">{featuredLabels[i] ?? 'おすすめ！'}</span>
                  <span class="pickup-thumb">
                    <img src={v.thumbnailUrl} alt="" loading="lazy" decoding="async" />
                  </span>
                  <span class="pickup-title">
                    {v.title} <span class="pickup-arrow" aria-hidden="true">→</span>
                  </span>
                </a>
              </li>
            ))}
        </ul>
      </section>
    )
  }

  <section class="lp-section lp-section--tint" id="videos">
    <div class="lp-inner reveal">
      <SectionHead kicker="VIDEO" title="最新動画" />
      {
        latestTop.length > 0 ? (
          <>
            <VideoList videos={latestTop} />
            <p class="more-link"><a href="/videos">動画をすべて見る →</a></p>
          </>
        ) : (
          <p class="placeholder-note">最新動画はまもなく表示されます。</p>
        )
      }
    </div>
  </section>

  {
    information.length > 0 && (
      <section class="lp-section" id="information">
        <div class="lp-inner lp-inner--info reveal">
          <SectionHead kicker="INFORMATION" title="お知らせ" />
          <ul class="info-grid">
            {information.slice(0, 3).map((item) => {
              const Tag = item.url ? 'a' : 'div';
              const linkProps = item.url ? { href: item.url, ...externalAttrs(item.url) } : {};
              return (
                <li class="info-card">
                  <Tag class="info-card__inner" {...linkProps}>
                    <span class="info-thumb">
                      {item.image ? (
                        <img src={item.image} alt="" loading="lazy" decoding="async" />
                      ) : (
                        <span class="info-thumb__ph">{item.category}</span>
                      )}
                    </span>
                    <span class="info-meta">
                      <time>{item.date}</time>
                      <span class="info-cat">{item.category}</span>
                    </span>
                    <span class="info-title">{item.title}</span>
                  </Tag>
                </li>
              );
            })}
          </ul>
          <div class="sec-cta">
            <a class="btn btn-ghost-dark sm" href="/news">過去のおしらせ一覧 →</a>
          </div>
        </div>
      </section>
    )
  }

  <section class="lp-section" id="gallery">
    <div class="lp-inner reveal">
      <SectionHead kicker="GALLERY" title="ギャラリー" />
      <p class="sec-lead">わたしの色んな姿や、みんなが描いてくれたファンアートをご紹介！</p>
      <div class="gallery-soon">Coming soon …</div>
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="goods">
    <div class="lp-inner reveal">
      <SectionHead kicker="STORE" title="ストア" />
      <p class="sec-lead">配信に使える自作のOBSウィジェットなどを BOOTH で販売中。オリジナルグッズも順次追加していく予定です。画像から BOOTH へ。</p>
      <a class="goods-banner" href={site.links.booth} rel="me noopener" target="_blank" aria-label="BOOTHストアを見る">
        <Image class="goods-banner__bg" src={keyVisual} widths={[480, 768, 1024]} sizes="(min-width: 760px) 760px, 100vw" alt="" loading="lazy" />
        <span class="goods-banner__text">
          <span class="goods-banner__en">OFFICIAL STORE</span>
          <span class="goods-banner__jp">和香松庵 STORE</span>
        </span>
        <span class="goods-banner__btn">BOOTH ▸</span>
      </a>
    </div>
  </section>

  <section class="lp-section" id="follow">
    <div class="lp-inner reveal">
      <SectionHead kicker="FOLLOW" title="フォロー" />
      <p class="sec-lead">配信のお知らせや日常は各SNSで。チャンネル登録・フォローで応援よろしくお願いします。</p>
      <div class="sns-banners">
        <a class="sns-banner sns-banner--yt" href={site.links.youtube} rel="me noopener" target="_blank">
          <span class="sns-banner__label">YouTube</span>
          <span class="sns-banner__sub">和香松庵 / 配信・アーカイブ</span>
        </a>
        <a class="sns-banner sns-banner--x" href={site.links.x} rel="me noopener" target="_blank">
          <span class="sns-banner__label">X (Twitter)</span>
          <span class="sns-banner__sub">お知らせ・日常をつぶやき中</span>
        </a>
        <a class="sns-banner sns-banner--marshmallow" href={site.links.marshmallow} rel="me noopener" target="_blank">
          <span class="sns-banner__label">マシュマロ</span>
          <span class="sns-banner__sub">気軽になんでも送っていいよ（匿名OK）</span>
        </a>
      </div>
    </div>
  </section>

  {/* 活動実績は中身が揃うまで一旦非表示（指示 2026-06-18）。掲載するときは false を true に戻す。 */}
  {false && (
    <section class="lp-section lp-section--tint" id="discography">
      <div class="lp-inner reveal">
        <SectionHead kicker="DISCOGRAPHY" title="活動実績" />
        <p class="sec-lead">これまでの活動実績・お仕事情報をこちらに掲載予定です。</p>
        <div class="gallery-soon">Coming soon …</div>
        <div class="sec-cta">
          <a class="btn btn-ghost-dark sm" href="/work">お仕事のご依頼はこちら →</a>
        </div>
      </div>
    </section>
  )}

  <section class="lp-section" id="guideline">
    <div class="lp-inner reveal">
      <SectionHead kicker="GUIDELINE" title="ガイドライン" />
      <p class="sec-lead sec-lead--guideline">みなさんに安心して楽しんでもらえるよう、二次創作・切り抜き・応援についてのお願いをまとめました。<br class="gl-br" />みんなで心地よく過ごすためのささやかな約束ごとです。</p>

      <div class="guide-block">
        <h3 class="guide-h">切り抜き動画</h3>
        <ul class="guide-points">
          <li>配信の切り抜きは原則OKです。</li>
          <li>元動画のリンクを概要欄に必ず記載してください。</li>
          <li>悪意のある編集・切り抜きはご遠慮ください。</li>
          <li>切り抜き動画の収益化はご遠慮ください。</li>
          <li>YouTube・X・niconico など、ご自由に投稿いただけます。</li>
          <li>ハッシュタグ：<strong>#庵のおかわり</strong></li>
        </ul>
      </div>

      <div class="guide-block">
        <h3 class="guide-h">二次創作・ファンアート</h3>
        <ul class="guide-points">
          <li>イラスト・音楽・小説など、基本的に大歓迎です。</li>
          <li>R-18 / R-18G 作品は苦手な方もいるため、ワンクッション挟むなどの配慮をお願いします。</li>
          <li>誰かが不快・悲しい気持ちになる作品の投稿はご遠慮ください。</li>
          <li>ハッシュタグ：<strong>#和香松庵</strong> ／ ファンアート用 <strong>#庵のお品書き</strong></li>
        </ul>
      </div>

      <div class="guide-block">
        <h3 class="guide-h">イラストのAI学習について</h3>
        <p class="guide-text">和香松庵が発信するイラストを、AIの学習データとして利用することは固くお断りしています。描いてくださったイラストレーターさんの権利を守るため、どうかご理解とご協力をお願いいたします。</p>
      </div>

      <div class="guide-block">
        <h3 class="guide-h">判断に迷ったら</h3>
        <p class="guide-text">ここに書かれていないことで迷った場合は、<a href={site.links.x} rel="me noopener" target="_blank">X</a> までお気軽にご連絡ください。</p>
      </div>
    </div>
  </section>

  <section class="lp-section lp-section--tint" id="work">
    <div class="lp-inner reveal">
      <SectionHead kicker="CONTACT" title="お仕事のご依頼" />
      <p class="sec-lead">コラボ・企業案件などのご相談を受け付けています。詳細・ご連絡方法はこちらから。</p>
      <div class="sec-cta">
        <a class="btn btn-ghost-dark sm" href="/work">依頼内容・ご連絡方法 →</a>
      </div>
    </div>
  </section>
</Base>

{/* ▼▼ 調整用パラメータ：ここの数値を変えると各サイズ・位置が変わります（手で動かせます） ▼▼ */}
<style is:global>
  :root {
    /* ヒーロー */
    --hero-h: clamp(440px, 80vh, 660px); /* ヒーローの高さ */
    --hero-name: clamp(3rem, 10vw, 5.2rem); /* 名前の大きさ */
    /* プロフィール（PCの横並び時に効く） */
    --pf-art: 660px; /* 立ち絵の最大幅 */
    --pf-drop: 3.75rem; /* 立ち絵の頭からプロフィールを下げる量 */
    --pf-gap: 1.5rem; /* 立ち絵⇄文章の間隔 */
    --pf-max: 1260px; /* プロフィール全体の最大幅 */
    --pf-heading: 3.5rem; /* 「ようこそ」見出し */
    --pf-lead: 1.44rem; /* 紹介文 */
    --pf-label: 1.26rem; /* プロフィール項目のラベル */
    --pf-value: 1.38rem; /* プロフィール項目の値 */
    /* 週間ボード（SCHEDULE） */
    --wb-max: 640px; /* 週間ボードの最大幅（位置はセクション中央） */
    --wb-pad: clamp(1.3rem, 3.2vw, 2.2rem); /* 週間ボードの内側余白 */
  }
</style>

<style>
  /* ===== ヒーロー（明るい上品トーン：グレー背景KV＋クリームの霞＋濃い金） ===== */
  .hero2 {
    --h-ink: #3a352d; /* 濃い文字 */
    --h-gold: #7a6c45; /* 濃い金（明るい背景でも読める） */
    --h-bg: #e9e6df; /* 画像読み込み前のフォールバック（グレー寄り） */
    position: relative;
    /* main の左右パディングと上パディングを打ち消してフルブリード＋ヘッダー直下に密着 */
    width: 100vw;
    margin: -1.75rem calc(50% - 50vw) 2.5rem;
    min-height: var(--hero-h);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--h-bg);
    isolation: isolate;
  }
  .hero2__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 18%; /* 顔（上部中央）が切れないよう上寄せ */
    transform-origin: 52% 18%; /* Ken Burnsで顔の方へ寄る */
    z-index: 0;
  }
  /* Ken Burns：背景がごくゆっくり微ズーム（映画的な「呼吸」）。
     ズームのみ＝モバイルでも顔が枠外に出ない。動きが苦手な設定では静止。 */
  @media (prefers-reduced-motion: no-preference) {
    /* 既定は停止。ヒーローが画面内のときだけ動かす（電池/INP配慮・WCAG 2.2.2） */
    .hero2__bg { animation: kenburns 26s ease-in-out infinite alternate; animation-play-state: paused; }
    .hero2.in-view .hero2__bg { animation-play-state: running; }
  }
  @keyframes kenburns {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }
  .hero2__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to top, rgba(250, 249, 246, 0.97) 0%, rgba(250, 249, 246, 0.84) 26%, rgba(250, 249, 246, 0.36) 52%, rgba(250, 249, 246, 0) 78%),
      linear-gradient(to right, rgba(250, 249, 246, 0.9) 0%, rgba(250, 249, 246, 0.42) 42%, rgba(250, 249, 246, 0) 66%);
  }
  .hero2__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4.5rem) clamp(1.25rem, 5vw, 4rem);
  }
  .hero2__text { max-width: 46rem; }
  /* 掛軸風の縦書きアクセント（広い画面のみ・左の余白に控えめに） */
  .hero2__vertical { display: none; }
  @media (min-width: 1000px) {
    .hero2__vertical {
      display: block;
      position: absolute;
      top: 50%;
      left: clamp(0.6rem, 2vw, 1.8rem);
      transform: translateY(-50%);
      z-index: 2;
      margin: 0;
      writing-mode: vertical-rl;
      font-family: var(--font-serif);
      font-size: 1.05rem;
      letter-spacing: 0.5em;
      color: rgba(58, 53, 45, 0.34);
      text-shadow: 0 1px 10px rgba(250, 249, 246, 0.85);
    }
  }
  .kicker {
    margin: 0 0 1rem;
    font-size: 0.86rem;
    letter-spacing: 0.3em;
    font-weight: 600;
    color: var(--h-gold);
    text-shadow: 0 1px 10px rgba(250, 249, 246, 0.95);
  }
  .hero2__name {
    font-family: var(--font-serif);
    color: var(--h-ink);
    font-size: var(--hero-name);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.08;
    margin: 0;
    text-shadow: 0 1px 18px rgba(250, 249, 246, 0.78);
  }
  .hero2__romaji {
    font-family: var(--font-logo); /* Cinzel：碑文体でロゴの格を上げる */
    margin: 0.55rem 0 1.25rem;
    font-size: 0.9rem;
    letter-spacing: 0.4em;
    color: rgba(58, 53, 45, 0.55);
  }
  .hero2__tag {
    margin: 0 0 1.7rem;
    font-size: clamp(1.05rem, 2.8vw, 1.32rem);
    line-height: 1.95;
    color: rgba(58, 53, 45, 0.92);
  }
  /* ヒーロー内カウントダウン（明るいカード） */
  .countdown {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.7rem;
    margin: 0 0 1.5rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid rgba(122, 108, 69, 0.38);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.72);
  }
  .cd-label { margin: 0; font-size: 0.78rem; letter-spacing: 0.1em; color: rgba(58, 53, 45, 0.7); }
  .cd-label--solo { margin: 0 0 1.6rem; font-size: 0.9rem; }
  .cd-time { font-size: 1.32rem; font-weight: 600; color: var(--h-gold); font-variant-numeric: tabular-nums; }
  .cd-next-title { width: 100%; font-size: 0.88rem; color: rgba(58, 53, 45, 0.82); }

  .hero2__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.82rem 1.7rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
  }
  .btn.sm { padding: 0.7rem 1.5rem; font-size: 1.05rem; }
  .btn-gold { position: relative; overflow: hidden; background: #6f6444; color: #faf9f6; }
  .btn-gold:hover { background: #847650; transform: translateY(-1px); }
  /* シャイン一閃：ホバーで斜めの光が一度サッと走る（マウス環境のみ） */
  @media (hover: hover) and (pointer: fine) {
    .btn-gold::before {
      content: '';
      position: absolute;
      top: 0;
      left: -60%;
      width: 40%;
      height: 100%;
      background: linear-gradient(100deg, transparent, rgba(255, 255, 255, 0.38), transparent);
      transform: skewX(-20deg);
      transition: left 0.6s ease;
      pointer-events: none;
    }
    .btn-gold:hover::before { left: 120%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn-gold::before { transition: none; }
  }
  .btn-ghost { border: 1px solid rgba(122, 108, 69, 0.55); color: var(--h-gold); background: rgba(255, 255, 255, 0.55); }
  .btn-ghost:hover { background: rgba(122, 108, 69, 0.12); transform: translateY(-1px); }
  .btn-ghost-dark { border: 1px solid var(--accent); color: var(--accent-strong); }
  .btn-ghost-dark:hover { background: rgba(156, 143, 107, 0.1); transform: translateY(-1px); }

  .kicker--dark { color: var(--accent-strong); text-shadow: none; }
  .welcome__lead { margin: 0.7rem 0 1.8rem; line-height: 2.05; font-size: var(--pf-lead); }

  /* プロフィール項目（VTuber定番・値は仮） */
  .profile-list { margin: 0 0 1.3rem; padding: 0; text-align: left; }
  .profile-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.3rem 1.4rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
  }
  .profile-row dt {
    margin: 0;
    position: relative;
    padding-left: 1.4rem;
    color: var(--muted);
    font-size: var(--pf-label);
    white-space: nowrap;
  }
  .profile-row dt::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 0.15em;
    color: var(--accent);
    font-size: 0.66rem;
  }
  .profile-row dd { margin: 0; font-size: var(--pf-value); }
  .welcome__lead strong { font-weight: 600; }
  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin: 0 0 1.3rem;
    padding: 0;
    list-style: none;
  }
  .chips li {
    padding: 0.5rem 1.45rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-size: 1.1rem;
    color: var(--accent-strong);
    background: rgba(156, 143, 107, 0.06);
  }

  /* スマホはプロフィール周りの文字を一段小さく・余白を詰めてサイト全体と馴染ませる。
     基底の .chips li 等より後ろに置き、確実に上書きする。 */
  @media (max-width: 640px) {
    :root {
      --pf-lead: 1rem;
      --pf-label: 0.86rem;
      --pf-value: 0.95rem;
    }
    .welcome__lead { line-height: 1.95; margin-bottom: 1.4rem; }
    .profile-row {
      grid-template-columns: 6.2rem 1fr;
      gap: 0.2rem 0.9rem;
      padding: 0.8rem 0;
    }
    .profile-row dt { padding-left: 1rem; }
    .chips { gap: 0.4rem; }
    .chips li { font-size: 0.84rem; padding: 0.36rem 1.05rem; }

    /* ===== ヒーロー：スマホ可読性 =====
       立ち絵に文字が重なると読みにくいので、上に顔を覗かせつつ
       下側をほぼ無地のオフホワイトにして文字をはっきり読めるようにする。 */
    .hero2 { align-items: stretch; }
    .hero2__bg { object-position: 50% 8%; } /* 顔を上に出す */
    .hero2__scrim {
      background: linear-gradient(
        to top,
        rgba(250, 249, 246, 0.99) 0%,
        rgba(250, 249, 246, 0.985) 50%,
        rgba(250, 249, 246, 0.88) 64%,
        rgba(250, 249, 246, 0.42) 82%,
        rgba(250, 249, 246, 0) 100%
      );
    }
    .hero2__content {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.5rem 1.4rem 2rem;
    }
    .kicker { letter-spacing: 0.16em; font-size: 0.74rem; margin-bottom: 0.7rem; }
    .hero2__romaji { margin: 0.45rem 0 1rem; letter-spacing: 0.34em; }
    .hero2__tag { font-size: 1rem; line-height: 1.8; margin-bottom: 1.3rem; }
    /* CTAは縦並び・全幅で揃え、左寄せの不揃いをなくす（カウントダウンカードと幅を合わせる） */
    .countdown { display: flex; width: 100%; }
    .hero2__cta { flex-direction: column; align-items: stretch; gap: 0.6rem; width: 100%; }
    .hero2__cta .btn { width: 100%; justify-content: center; padding: 0.85rem 1.4rem; }
  }

  .more-link { text-align: right; }
  .sched-foot { margin-top: 1.2rem; }
  /* 今週・来週ボード：広い画面では横並び、狭い画面では自動で縦積み */
  .sched-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    max-width: 1360px;
    margin-inline: auto;
    padding-inline: 1.1rem;
  }
  .sched-col {
    flex: 1 1 500px;
    min-width: 0;
    display: flex;
  }

  /* ===== プロフィール項目（立ち絵左＋表右・元のサイズに復元） ===== */
  .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding-inline: 1.25rem;
    text-align: center;
  }
  .profile__art { width: min(80%, 400px); }
  .profile__art :global(img) { width: 100%; height: auto; }
  .profile__body { width: 100%; max-width: 34rem; }
  .profile .profile-list { margin-inline: auto; }

  @media (min-width: 900px) {
    .profile {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      gap: var(--pf-gap);
      max-width: var(--pf-max);
      margin-inline: auto;
    }
    .profile__art { flex-shrink: 0; width: min(48%, var(--pf-art)); }
    .profile__body { flex: 1 1 0; min-width: 0; max-width: none; margin-top: var(--pf-drop); }
    .profile .chips { justify-content: flex-start; }
  }

  /* ===== ごあいさつ（ABOUT）：テキスト左＋立ち絵右（参考サイト風） ===== */
  .about {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
    margin-top: 2.8rem;
    padding-inline: 1.25rem;
    text-align: center;
  }
  .about__art { width: min(86%, 400px); }
  /* 足元をぼかして（下を透過グラデでフェード）大きく見せる */
  .about__art :global(img) {
    width: 100%;
    height: auto;
    -webkit-mask-image: linear-gradient(to bottom, #000 82%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 82%, transparent 100%);
  }

  /* キャッチコピー（金で強調・グローバルh2の下線/金タブ/上マージンを打ち消す） */
  .about__catch {
    margin: 0 0 0.4rem;
    padding: 0;
    border-bottom: none;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.7rem, 4.8vw, 2.7rem);
    line-height: 1.42;
    letter-spacing: 0.02em;
    color: var(--accent-strong);
  }
  .about__catch::after { content: none; }
  .about__catch-en {
    margin: 0 0 1rem;
    font-style: italic;
    font-size: clamp(0.82rem, 2.3vw, 1.02rem);
    letter-spacing: 0.06em;
    /* 読ませる英文サブコピー。クリーム地で淡い金だとAA未達(3.04)→濃い金でAA確保 */
    color: var(--accent-strong);
  }
  .about__rule {
    display: block;
    width: 3.2rem;
    height: 2px;
    margin: 0 auto 1.3rem;
    background: var(--accent);
  }
  /* 罫線ドロー：ABOUTが現れる時、金の罫が中央から左右へ伸びる（JS有効時のみ） */
  :global(html.js) .about.reveal .about__rule {
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) 0.15s;
  }
  :global(html.js) .about.reveal.is-visible .about__rule { transform: scaleX(1); }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .about.reveal .about__rule { transform: none; transition: none; }
  }
  .about__story { text-align: left; max-width: 34rem; }
  .about__story p {
    margin: 0 0 0.95rem;
    font-size: 1.04rem;
    line-height: 2;
    color: var(--muted);
  }
  .about__story p:last-child { margin-bottom: 0; }

  @media (min-width: 900px) {
    .about {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 3rem;
      max-width: 1080px;
      margin-inline: auto;
    }
    .about__body { flex: 1 1 0; min-width: 0; }
    .about__art { flex-shrink: 0; width: min(50%, 500px); }
    .about__rule { margin-left: 0; margin-right: auto; }
    .about__story { max-width: none; }
  }

  /* ===== PICK UP（おすすめ） ===== */
  .pickup-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.7rem 1.25rem;
    margin: 1.5rem auto 0;
    max-width: 1120px;
    padding-inline: 1.25rem;
    list-style: none;
  }
  @media (max-width: 680px) {
    .pickup-grid { grid-template-columns: 1fr; max-width: 520px; }
  }
  .pickup-card a { display: block; text-decoration: none; color: var(--text); }
  /* カードのリフト：ホバーでふわっと浮く＋柔らかい影（マウス環境のみ） */
  @media (hover: hover) and (pointer: fine) {
    .pickup-card a, .info-card a {
      transition: transform 0.25s ease, filter 0.25s ease;
    }
    .pickup-card a:hover, .info-card a:hover {
      transform: translateY(-4px);
      filter: drop-shadow(0 14px 26px rgba(58, 53, 45, 0.16));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pickup-card a, .info-card a { transition: none; }
    .pickup-card a:hover, .info-card a:hover { transform: none; filter: none; }
  }
  .pickup-bubble {
    position: relative;
    display: block;
    width: max-content;
    max-width: 100%;
    margin: 0 auto 0.8rem;
    padding: 0.42rem 1.05rem;
    background: var(--card);
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent-strong);
    text-align: center;
  }
  .pickup-bubble::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -7px;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: var(--card);
    border-right: 1px solid var(--accent);
    border-bottom: 1px solid var(--accent);
  }
  .pickup-thumb {
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
  }
  .pickup-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pickup-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.65rem;
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .pickup-arrow { color: var(--accent-strong); }

  /* ===== GALLERY / DISCOGRAPHY（準備中） =====
     破線の“工事中”感をやめ、SectionHeadと同じ金のひし形＋細罫で上品な準備中表示に。 */
  .gallery-soon {
    display: grid;
    place-items: center;
    gap: 0.55rem;
    margin-top: 1.3rem;
    min-height: clamp(150px, 24vw, 230px);
    border: 1px solid var(--line);
    border-radius: 14px;
    background:
      radial-gradient(64% 82% at 50% 28%, rgba(156, 143, 107, 0.07), transparent 70%),
      var(--card);
    color: var(--accent-strong);
    font-family: var(--font-serif);
    letter-spacing: 0.22em;
    font-size: clamp(0.95rem, 2.6vw, 1.25rem);
    text-transform: uppercase;
  }
  /* 文字の上に小さな金のひし形（SectionHeadの区切りと呼応） */
  .gallery-soon::before {
    content: '';
    display: block; /* grid子でblockify済みだが明示（width/height確実適用） */
    width: 7px;
    height: 7px;
    transform: rotate(45deg);
    background: var(--accent);
  }

  /* ===== GUIDELINE（要点） ===== */
  .guide-points {
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }
  .guide-points li {
    position: relative;
    padding: 0.85rem 1rem 0.85rem 2.2rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--card);
    font-size: 0.96rem;
    line-height: 1.6;
  }
  .guide-points li::before {
    content: '◆';
    position: absolute;
    left: 0.9rem;
    top: 0.85rem;
    color: var(--accent);
    font-size: 0.8rem;
  }
  .guide-points strong {
    color: var(--accent-strong);
    margin-right: 0.5rem;
  }
  .guide-block {
    max-width: 42rem;
    margin: 1.35rem auto 0;
    text-align: left;
  }
  .guide-block:first-of-type { margin-top: 0.9rem; }
  .guide-h {
    margin: 0 0 0.4rem;
    font-size: 1.12rem;
    color: var(--accent-strong);
  }
  .guide-block .guide-points { margin-top: 0.5rem; }
  .guide-text {
    margin: 0.5rem 0 0;
    font-size: 0.96rem;
    line-height: 1.75;
    color: var(--muted);
  }
  .guide-text a {
    color: var(--accent-strong);
    text-underline-offset: 2px;
  }

  /* ===== INFORMATION（お知らせ） ===== */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
    margin: 1.3rem 0 0;
    padding: 0;
    list-style: none;
  }
  @media (min-width: 600px) { .info-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 900px) { .info-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  /* お知らせは最新3枚を1行に並べたいので、この帯だけ内側幅を広げる */
  @media (min-width: 900px) { .lp-inner.lp-inner--info { max-width: 1040px; } }

  /* ヒーロー直下の「最新お知らせ」細いバー（押すと #information へ） */
  .newsbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 1040px;
    margin: 0 auto;
    padding: 0.62rem 1.25rem;
    border-top: 1px solid var(--line, rgba(58, 53, 45, 0.14));
    border-bottom: 1px solid var(--line, rgba(58, 53, 45, 0.14));
    background: #f4efe4;
    text-decoration: none;
    color: var(--text);
    font-size: 0.92rem;
  }
  .newsbar__tag { flex-shrink: 0; color: var(--accent-strong); font-weight: 600; letter-spacing: 0.08em; font-size: 0.8rem; }
  .newsbar__date { flex-shrink: 0; color: var(--muted); font-size: 0.8rem; }
  .newsbar__title { flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .newsbar__more { flex-shrink: 0; color: var(--accent-strong); font-size: 0.82rem; white-space: nowrap; }
  @media (hover: hover) { .newsbar:hover .newsbar__more { text-decoration: underline; text-underline-offset: 2px; } }
  @media (max-width: 640px) {
    .newsbar { font-size: 0.86rem; gap: 0.5rem; padding: 0.55rem 1rem; }
    .newsbar__date { display: none; }
    .newsbar__more { font-size: 0.78rem; }
  }
  .info-card__inner { display: block; text-decoration: none; color: var(--text); }
  .info-thumb {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: linear-gradient(150deg, #2a2118, #15110b);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
  }
  .info-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .info-thumb__ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-size: 1.05rem;
  }
  .info-meta {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    margin: 0.7rem 0 0.25rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .info-cat { color: var(--accent-strong); letter-spacing: 0.08em; text-transform: uppercase; }
  .info-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  /* ===== GOODS バナー ===== */
  .goods-banner {
    position: relative;
    display: block;
    margin-top: 1.2rem;
    border-radius: 14px;
    overflow: hidden;
    min-height: clamp(150px, 26vw, 240px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
    text-decoration: none;
  }
  .goods-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
    transition: transform 0.5s ease;
  }
  .goods-banner:hover .goods-banner__bg { transform: scale(1.04); }
  /* 動きが苦手な設定では拡大ズームを止める（サイト全体の配慮と統一） */
  @media (prefers-reduced-motion: reduce) {
    .goods-banner__bg { transition: none; }
    .goods-banner:hover .goods-banner__bg { transform: none; }
  }
  .goods-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(15, 12, 9, 0.85) 0%, rgba(15, 12, 9, 0.52) 45%, rgba(15, 12, 9, 0.12) 100%);
  }
  .goods-banner__text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: clamp(1.4rem, 4vw, 2.4rem);
  }
  .goods-banner__en { font-family: var(--font-logo); letter-spacing: 0.22em; font-size: 0.82rem; color: #e2c98e; }
  .goods-banner__jp { font-family: var(--font-serif); font-size: clamp(1.4rem, 4vw, 2.1rem); color: #fffdf8; font-weight: 700; }
  .goods-banner__btn {
    position: absolute;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 1;
    padding: 0.5rem 1.15rem;
    border-radius: 999px;
    background: #cda14e;
    color: #1b110a;
    font-weight: 700;
    font-size: 0.9rem;
  }

  /* ===== YouTube / X バナーカード ===== */
  .sns-banners {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.1rem;
    margin-top: 1.2rem;
  }
  .sns-banner {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.25rem;
    min-height: clamp(110px, 18vw, 150px);
    padding: clamp(1.1rem, 3vw, 1.7rem);
    border-radius: 12px;
    text-decoration: none;
    color: #fffdf8;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
  }
  .sns-banner--yt { background: linear-gradient(120deg, #7a1f1f, #b3352f); }
  .sns-banner--x { background: linear-gradient(120deg, #181818, #3a3a3a); }
  .sns-banner--marshmallow { background: linear-gradient(120deg, #ec6a9c, #f4a0c2); }
  .sns-banner__label {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .sns-banner__sub { font-size: 0.85rem; opacity: 0.9; }

  /* ===== LP（1ページ縦スクロール）のセクション土台 ===== */
  /* 各セクションはフルブリード。中身は .lp-inner で読みやすい幅に収める。
     交互に淡い帯（--tint）を敷いて縦のリズムを出す。 */
  .lp-section {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-block: clamp(2.1rem, 4.5vw, 3.25rem);
    scroll-margin-top: 1rem;
  }
  /* 帯セクション：淡い色＋琥珀色の灯りボケ（バーの照明感）。
     ボケは擬似要素(z-index:-1)に分離し、ゆっくり漂わせる（文字には重ねない）。 */
  .lp-section--tint {
    position: relative;
    overflow: clip;
    background-color: #f3f0e7;
  }
  .lp-section--tint::before {
    content: '';
    position: absolute;
    inset: -10%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(42% 55% at 14% 18%, rgba(201, 168, 105, 0.1), transparent 62%),
      radial-gradient(38% 50% at 86% 82%, rgba(201, 168, 105, 0.08), transparent 60%);
  }
  @media (prefers-reduced-motion: no-preference) {
    /* 既定は停止。その帯が画面内のときだけ漂わせる */
    .lp-section--tint::before { animation: bokehDrift 22s ease-in-out infinite alternate; animation-play-state: paused; }
    .lp-section--tint.in-view::before { animation-play-state: running; }
  }
  /* 和あしらい（控えめ）：署名セクション SCHEDULE だけ、対角の隅に極薄のコーナー飾り。
     セクション背景画像として配置＝文字の背面・base色(#f3f0e7)は維持。全帯には付けない（過剰回避）。 */
  #schedule.lp-section--tint {
    background-image: url('/ornaments/corner-tl.svg'), url('/ornaments/corner-br.svg');
    background-repeat: no-repeat, no-repeat;
    background-position: left 14px top 14px, right 14px bottom 14px;
    background-size: 60px, 60px;
  }
  @media (max-width: 640px) {
    #schedule.lp-section--tint {
      background-size: 38px, 38px;
      background-position: left 8px top 8px, right 8px bottom 8px;
    }
  }
  @keyframes bokehDrift {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(2.5%, -2%, 0) scale(1.08); }
  }
  .lp-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  /* PROFILE/ABOUT で単独で使う大英字キッカー（section-head 本体は components/SectionHead.astro に移設） */
  .section-kicker {
    margin: 0;
    font-family: var(--font-logo);
    font-size: clamp(2.6rem, 9vw, 4.6rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    line-height: 1;
    color: rgba(156, 143, 107, 0.55); /* 単色の金ウォーターマーク（可読性優先・箔グラデは廃止） */
  }

  .sec-lead { text-align: center; margin: 0 auto 0.9rem; max-width: 34rem; line-height: 1.7; }
  /* ガイドライン導入文：PC幅では1文ずつ＝2行に。スマホは自然折り返し（brは無効）。 */
  .sec-lead--guideline .gl-br { display: none; }
  @media (min-width: 900px) {
    .sec-lead--guideline { width: max-content; max-width: 92vw; }
    .sec-lead--guideline .gl-br { display: inline; }
  }
  .sec-cta { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.7rem; }

  /* ===== 控えめな登場アニメ（トップのみ・reduced-motionで無効） ===== */
  @media (prefers-reduced-motion: no-preference) {
    .hero2__text > * { animation: fadeUp 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
    .hero2__text > :nth-child(2) { animation-delay: 0.06s; }
    .hero2__text > :nth-child(3) { animation-delay: 0.12s; }
    .hero2__text > :nth-child(4) { animation-delay: 0.18s; }
    .hero2__text > :nth-child(5) { animation-delay: 0.24s; }
    .hero2__text > :nth-child(6) { animation-delay: 0.3s; }
    .hero2__text > :nth-child(7) { animation-delay: 0.36s; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* ===== スクロールで現れる（JS有効時のみ初期非表示／JS無効・クローラーでは内容そのまま） ===== */
  :global(html.js) .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  :global(html.js) .reveal.is-visible { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .reveal { opacity: 1; transform: none; transition: none; }
  }

  /* ===== ヒーローの金のきらめき（控えめ・reduced-motionでは消灯） ===== */
  .hero2__sparkles { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
  /* マウストレイル（金の軌跡）の粒。JSでヒーロー内に生成するため :global で当てる
     （Astroのスコープ付きCSSは動的生成要素にマッチしない）。アニメ後に自己削除。 */
  :global(.trail-spark) {
    position: absolute;
    z-index: 2; /* テキスト面と同層まで上げて確実に見える */
    width: 13px;
    height: 13px;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle, rgba(232, 207, 149, 0.98), rgba(201, 168, 105, 0.55) 38%, rgba(201, 168, 105, 0) 72%);
    filter: drop-shadow(0 0 5px rgba(201, 168, 105, 0.7));
    transform: translate(-50%, -50%);
  }
  /* リンクパネル：ホバーでふわっと浮くだけ（傾けすぎない・上品な浮き） */
  .goods-banner, .sns-banner { transition: transform 0.25s ease, box-shadow 0.25s ease; }
  .goods-banner:hover, .sns-banner:hover { transform: translateY(-6px); box-shadow: 0 22px 52px rgba(0, 0, 0, 0.26); }
  @media (prefers-reduced-motion: reduce) {
    .goods-banner, .sns-banner { transition: none; }
    .goods-banner:hover, .sns-banner:hover { transform: none; }
  }
  .spark {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201, 168, 105, 0.95) 0%, rgba(201, 168, 105, 0) 70%);
    opacity: 0;
  }
  .spark:nth-child(1) { left: 14%; top: 20%; }
  .spark:nth-child(2) { left: 78%; top: 16%; }
  .spark:nth-child(3) { left: 88%; top: 52%; }
  .spark:nth-child(4) { left: 24%; top: 70%; }
  .spark:nth-child(5) { left: 62%; top: 34%; }
  .spark:nth-child(6) { left: 46%; top: 12%; }
  @media (prefers-reduced-motion: no-preference) {
    .spark { animation: twinkle 4.5s ease-in-out infinite; animation-play-state: paused; }
    .hero2.in-view .spark { animation-play-state: running; }
    .spark:nth-child(2) { animation-delay: 0.7s; }
    .spark:nth-child(3) { animation-delay: 1.5s; }
    .spark:nth-child(4) { animation-delay: 2.2s; }
    .spark:nth-child(5) { animation-delay: 3s; }
    .spark:nth-child(6) { animation-delay: 3.8s; }
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 0.5; transform: scale(1); } /* 上品さ優先でピークを抑える */
  }
</style>

<script>
  // 次の配信開始までのカウントダウン（情報表示。1分ごとに更新）
  const el = document.querySelector<HTMLElement>('.countdown');
  const out = el?.querySelector<HTMLElement>('[data-cd]');
  const startMs = el?.dataset.start ? Date.parse(el.dataset.start) : NaN;
  let timer: ReturnType<typeof setInterval> | undefined;

  function render() {
    if (!out || Number.isNaN(startMs)) return;
    const diff = startMs - Date.now();
    if (diff <= 0) {
      out.textContent = 'まもなく';
      if (timer) clearInterval(timer); // 配信時刻を過ぎたら更新を止める
      return;
    }
    const days = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins = Math.floor((diff % 3_600_000) / 60_000);
    out.textContent = (days > 0 ? `${days}日 ` : '') + `${hours}時間 ${mins}分`;
  }

  render();
  timer = setInterval(render, 60_000);

  // スクロールで各セクションをふわっと表示（画面に入ったら is-visible を付与）
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if (revealEls.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    revealEls.forEach((el) => io.observe(el));
  }

  // 無限アニメ（Ken Burns・灯りボケ・スパークル）は画面内のときだけ動かす。
  // 画面外では一時停止＝モバイルのバッテリー/CPU/INP配慮、WCAG 2.2.2（動きの停止）。
  const animEls = document.querySelectorAll<HTMLElement>('.hero2, .lp-section--tint, .foot-brand');
  if (animEls.length && 'IntersectionObserver' in window) {
    const animIo = new IntersectionObserver(
      (entries) => {
        for (const e of entries) e.target.classList.toggle('in-view', e.isIntersecting);
      },
      { rootMargin: '0px 0px 100px 0px' },
    );
    animEls.forEach((el) => animIo.observe(el));
  }

  // マウス追従系（精密ポインタ＝マウス/トラックパッドがある時のみ・動きが苦手な設定では無効）。
  // any-* を使うとタッチ対応ノートPCでもマウスがあれば有効になる（hover/pointer だと主ポインタ依存で誤判定）。
  const finePointer = matchMedia('(any-hover: hover) and (any-pointer: fine)').matches;
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (finePointer && !reduceMotion) {
    // I. 金の軌跡：ヒーロー上でカーソルに金の粒が尾を引く
    const hero = document.querySelector<HTMLElement>('.hero2');
    if (hero) {
      let lastTrail = 0;
      hero.addEventListener('pointermove', (e) => {
        const now = performance.now();
        if (now - lastTrail < 22) return; // 間引き（負荷対策）
        lastTrail = now;
        const r = hero.getBoundingClientRect();
        const p = document.createElement('span');
        p.className = 'trail-spark';
        p.style.left = `${e.clientX - r.left}px`;
        p.style.top = `${e.clientY - r.top}px`;
        hero.appendChild(p);
        p.animate(
          [
            { opacity: 0.8, transform: 'translate(-50%, -50%) scale(1)' },
            { opacity: 0, transform: 'translate(-50%, -50%) scale(0.2) translateY(14px)' },
          ],
          { duration: 750, easing: 'ease-out' },
        ).onfinish = () => p.remove();
      });
    }
    // （リンクパネルの“浮き”はCSSの :hover で実装。傾きすぎ回避のためJSティルトは廃止）
  }
</script>

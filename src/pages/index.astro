---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ScheduleList from '../components/ScheduleList.astro';
import { site } from '../config/site';
import { loadSchedule } from '../lib/loadSchedule';
import { loadVideos } from '../lib/loadVideos';
import VideoList from '../components/VideoList.astro';
import LiveBadge from '../components/LiveBadge.astro';
import heroArt from '../assets/Wakamatsu_full_size.png';

const events = await loadSchedule();
const next = events[0] ?? null;
const next3 = events.slice(0, 3);
const { latest, live } = await loadVideos();
const latestTop = latest.slice(0, 6);
---

<Base>
  <section class="hero">
    <div class="hero-art-wrap">
      <Image
        class="hero-art"
        src={heroArt}
        widths={[300, 460, 680]}
        sizes="(min-width: 640px) 340px, 78vw"
        alt={`${site.name}の立ち絵`}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-info">
      <p class="hero-name">{site.name}</p>
      <p class="hero-romaji">WAKAMATSU IORI</p>
      <LiveBadge live={live} />
      {
        next ? (
          <div class="countdown" data-start={next.start.toISOString()}>
            <p class="cd-label">次の配信まで</p>
            <p class="cd-time" data-cd>—</p>
            <p class="cd-next-title">{next.title}</p>
          </div>
        ) : (
          <p class="cd-label">次の配信は調整中です</p>
        )
      }
    </div>
  </section>

  <h2>次の配信</h2>
  <ScheduleList events={next3} />
  <p class="more-link"><a href="/schedule">スケジュールをすべて見る →</a></p>

  <h2>最新動画</h2>
  <VideoList videos={latestTop} />
  <p class="more-link"><a href="/videos">動画をすべて見る →</a></p>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    padding: 1rem 0 1.5rem;
    overflow-x: clip; /* 背後グローの横滲みでページが横スクロールしないように（縦は通常表示） */
  }
  .hero-art-wrap {
    position: relative;
    display: flex;
    justify-content: center;
  }
  /* 立ち絵の背後にやわらかな光だまり（静止＝prefers-reduced-motionでも安全）。
     透過PNGの周囲ににじむ金の光で、主役感と奥行きを出す。 */
  .hero-art-wrap::before {
    content: '';
    position: absolute;
    inset: -6% -10% 2%;
    z-index: 0;
    background: radial-gradient(
      ellipse 58% 46% at 50% 36%,
      rgba(156, 143, 107, 0.22) 0%,
      rgba(156, 143, 107, 0.09) 40%,
      transparent 72%
    );
    pointer-events: none;
  }
  .hero-art {
    position: relative;
    z-index: 1;
    width: min(76%, 300px);
    height: auto;
  }
  .hero-info {
    width: 100%;
  }
  .hero-name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    margin: 0 0 0.15rem;
  }
  .hero-romaji {
    margin: 0 0 1rem;
    font-family: var(--font-serif);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.36em;
    text-indent: 0.36em; /* 字間ぶんの右寄りを視覚的に中央へ補正 */
    color: var(--muted);
  }
  .countdown {
    display: inline-block;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.9rem 1.7rem;
    box-shadow: 0 1px 4px rgba(66, 63, 56, 0.04);
  }
  .cd-label {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .cd-time {
    margin: 0.15rem 0;
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }
  .cd-next-title {
    margin: 0;
    font-size: 0.95rem;
  }
  .more-link {
    text-align: right;
  }
  @media (min-width: 640px) {
    .hero {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      text-align: left;
      gap: 2.5rem;
    }
    .hero-info {
      width: auto;
    }
    .hero-art {
      width: min(40vw, 340px);
    }
    .hero-romaji {
      text-indent: 0; /* 左寄せ時はインデント不要 */
    }
  }
</style>

<script>
  // 次の配信開始までのカウントダウン（情報表示。1分ごとに更新）
  const el = document.querySelector<HTMLElement>('.countdown');
  const out = el?.querySelector<HTMLElement>('[data-cd]');
  const startMs = el?.dataset.start ? Date.parse(el.dataset.start) : NaN;
  let timer: ReturnType<typeof setInterval> | undefined;

  function render() {
    if (!out || Number.isNaN(startMs)) return;
    const diff = startMs - Date.now();
    if (diff <= 0) {
      out.textContent = 'まもなく';
      if (timer) clearInterval(timer); // 配信時刻を過ぎたら更新を止める
      return;
    }
    const days = Math.floor(diff / 86_400_000);
    const hours = Math.floor((diff % 86_400_000) / 3_600_000);
    const mins = Math.floor((diff % 3_600_000) / 60_000);
    out.textContent = (days > 0 ? `${days}日 ` : '') + `${hours}時間 ${mins}分`;
  }

  render();
  timer = setInterval(render, 60_000);
</script>

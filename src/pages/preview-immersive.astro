---
/**
 * 【プレビュー専用・noindex・使い捨て】没入シネマ×グロー の形を 2トーンで見比べるためのモック。
 * 本番トップ(index.astro)・静/動ブランチには影響しない独立ルート。
 * ?form=cream（明クリーム×金・世界観キープ） / ?form=dark（黒×金・耽美の新トーン）で切替。
 * 採用が決まったら本実装へ昇格し、このファイルと配線は削除する。
 */
import { Image } from 'astro:assets';
import { site } from '../config/site';
import { loadSchedule } from '../lib/loadSchedule';
import { groupByJstDay, jstTime } from '../lib/schedule';
import keyVisual from '../assets/IMG_5833.png';
import standArt from '../assets/Wakamatsu_full_size.png';
import barArt from '../assets/wakamatsusan_.png';
import { intro, profile } from '../config/profile';
import { information } from '../config/information';
import { loadVideos } from '../lib/loadVideos';
import { featuredLabels } from '../config/featured';
import type { Video } from '../lib/youtube';

const events = await loadSchedule();
const days = groupByJstDay(events).slice(0, 4);

// ヘッダーナビ＝本番(Base.astro)と同じ並び・同じセクションへのページ内アンカー。
const nav = [
  { href: '#profile', label: 'プロフィール' },
  { href: '#schedule', label: 'スケジュール' },
  { href: '#videos', label: '動画' },
  { href: '#goods', label: 'ストア' },
  { href: '#work', label: 'お仕事依頼' },
];

// 動画（YouTube）。本番=実データのみ。取得失敗でもトップ全体は落とさない（index.astro と同じ作法）。
let latestTop: Video[] = [];
let featured: Video[] = [];
try {
  const v = await loadVideos();
  latestTop = v.latest.slice(0, 6); // リールは多めに6本
  featured = v.featured; // おすすめ＝固定指定(featuredVideoIds) or 最新上位3本
} catch (err) {
  console.warn('[preview-immersive] 動画取得に失敗。動画枠は準備中表示で継続:', err instanceof Error ? err.message : err);
}
// dev かつ実データが空のときだけ、レイアウト確認用のサンプルを出す（本番では出ない）。
const mkSample = (id: string, title: string): Video => ({ id, title, url: site.links.youtube, thumbnailUrl: '', publishedAt: null });
const sampleFeatured: Video[] = [
  mkSample('s-f1', '夜のカフェタイム雑談（サンプル）'),
  mkSample('s-f2', '歌ってみた・歌枠アーカイブ（サンプル）'),
  mkSample('s-f3', 'ゲーム実況 #3（サンプル）'),
];
const sampleLatest: Video[] = [
  mkSample('s-l1', '【雑談】夜のカフェタイム（サンプル）'),
  mkSample('s-l2', '【ゲーム】〇〇 初見プレイ #3（サンプル）'),
  mkSample('s-l3', '【歌枠】まったり弾き語り（サンプル）'),
  mkSample('s-l4', '【コラボ】〇〇さんと（サンプル）'),
  mkSample('s-l5', '【作業】もくもく作業配信（サンプル）'),
  mkSample('s-l6', '【記念】登録者ありがとう枠（サンプル）'),
];
const useSample = import.meta.env.DEV;
const pickList: Video[] = featured.length ? featured : useSample ? sampleFeatured : [];
const reelList: Video[] = latestTop.length ? latestTop : useSample ? sampleLatest : [];
---

<!doctype html>
<html lang="ja" data-form="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>没入プレビュー | {site.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Marcellus&family=Shippori+Mincho:wght@500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Zen+Old+Mincho:wght@600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // ?form=dark で黒×金トーン（既定=cream）。エディタの保存値(localStorage)も先読みして
      // 描画前に反映（チラつき防止）。使い捨ての調整用配線。
      (function () {
        try {
          var q = new URLSearchParams(location.search).get('form');
          var f = q || localStorage.getItem('immersive-form') || 'dark';
          document.documentElement.dataset.form = f === 'dark' ? 'dark' : 'cream';
          var saved = JSON.parse(localStorage.getItem('immersive-editor') || '{}');
          for (var k in saved) document.documentElement.style.setProperty(k, saved[k]);
        } catch (e) {
          document.documentElement.dataset.form = 'cream';
        }
      })();
    </script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --serif: 'Shippori Mincho', 'Zen Old Mincho', 'Hiragino Mincho ProN', 'Yu Mincho', serif;
        --logo: 'Cinzel', 'Marcellus', serif;
        --gothic: 'Zen Kaku Gothic New', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', system-ui, sans-serif;
        /* ▼ 調整パネルのスライダーで動かす値（既定）。localStorage に保存される。 */
        --art-scale: 1;
        --spotlight: 0.4;
        --vignette: 0.2;
        --glow-strength: 0;
        /* 弧状ラジアルグラデーション装飾（見本帳#58）＝ページ全体の上方アーク光の強さ */
        --arc-strength: 0.9;
      }

      /* ===== トーン①：明クリーム×金（世界観キープ） ===== */
      html[data-form='cream'] {
        --bg: #faf9f6;
        --bg-2: #f3efe6;
        --ink: #3a352d;
        --ink-soft: rgba(58, 53, 45, 0.82);
        --muted: #6e6855;
        --gold: #9c8f6b;
        --gold-strong: #6f6444;
        --gold-bright: #c9a86a;
        --glow: rgba(201, 168, 105, 0.42);
        --glow-2: rgba(232, 207, 149, 0.5);
        --arc-1: rgba(214, 184, 120, 0.42);
        --arc-2: rgba(201, 168, 105, 0.16);
        --nav-bg: rgba(250, 249, 246, 0.62);
        --nav-line: rgba(156, 143, 107, 0.34);
        --card-bg: rgba(255, 255, 255, 0.55);
        --card-line: rgba(156, 143, 107, 0.28);
        --scrim: linear-gradient(
            to top,
            rgba(250, 249, 246, 0.97) 0%,
            rgba(250, 249, 246, 0.8) 28%,
            rgba(250, 249, 246, 0.34) 54%,
            rgba(250, 249, 246, 0) 80%
          ),
          linear-gradient(to right, rgba(250, 249, 246, 0.9) 0%, rgba(250, 249, 246, 0.3) 46%, rgba(250, 249, 246, 0) 70%);
        --blend: screen;
      }
      /* ===== トーン②：黒×金・耽美（新トーン） ===== */
      html[data-form='dark'] {
        --bg: #14100b;
        --bg-2: #1b140d;
        --ink: #f3e7cf;
        --ink-soft: rgba(243, 231, 207, 0.86);
        --muted: #b8a888;
        --gold: #c9a86a;
        --gold-strong: #e8cf95;
        --gold-bright: #f0d99a;
        --glow: rgba(232, 207, 149, 0.4);
        --glow-2: rgba(201, 168, 105, 0.5);
        --arc-1: rgba(240, 214, 156, 0.58);
        --arc-2: rgba(201, 168, 105, 0.22);
        --nav-bg: rgba(18, 13, 8, 0.5);
        --nav-line: rgba(201, 168, 105, 0.3);
        --card-bg: rgba(40, 30, 19, 0.5);
        --card-line: rgba(201, 168, 105, 0.26);
        --scrim: linear-gradient(
            to top,
            rgba(12, 9, 6, 0.95) 0%,
            rgba(12, 9, 6, 0.78) 30%,
            rgba(12, 9, 6, 0.34) 56%,
            rgba(12, 9, 6, 0) 82%
          ),
          linear-gradient(to right, rgba(12, 9, 6, 0.85) 0%, rgba(12, 9, 6, 0.3) 48%, rgba(12, 9, 6, 0) 72%);
        --blend: screen;
      }

      html { overflow-x: clip; scroll-behavior: smooth; color-scheme: light; }
      body { background: var(--bg); color: var(--ink); font-family: var(--gothic); line-height: 1.8; }
      /* ===== 全体のライト：弧状ラジアルグラデーション装飾（見本帳#58） =====
         画面上端の外（50% -60%）を光源に、上方から金の光がページ全体へ降りる。
         position:fixed なのでスクロールしても常に上から照らす“ステージ照明”になる。 */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 3;
        pointer-events: none;
        mix-blend-mode: var(--blend);
        opacity: var(--arc-strength);
        background:
          radial-gradient(circle at 50% -60%, var(--arc-1) 0%, var(--arc-2) 35%, transparent 62%);
      }
      @media (prefers-reduced-motion: reduce) {
        body::before { opacity: calc(var(--arc-strength) * 0.7); }
      }

      /* ===== ガラス質ナビ ===== */
      .inav {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 60;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.85rem clamp(1rem, 4vw, 2.6rem);
        background: var(--nav-bg);
        -webkit-backdrop-filter: blur(16px) saturate(1.25);
        backdrop-filter: blur(16px) saturate(1.25);
        border-bottom: 1px solid var(--nav-line);
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .inav__brand {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }
      .inav__brand .en {
        font-family: var(--logo);
        font-size: 0.6rem;
        letter-spacing: 0.42em;
        color: var(--gold-strong);
        text-transform: uppercase;
        margin-bottom: 0.22rem; /* 肩書きと名前にひと呼吸の余白 */
      }
      .inav__brand .jp {
        font-family: var(--serif);
        font-size: 1.16rem;
        letter-spacing: 0.26em;
        color: var(--ink);
        font-weight: 600;
      }
      .inav__links {
        display: flex;
        gap: clamp(0.8rem, 2vw, 1.7rem);
        align-items: center;
      }
      .inav__links a {
        font-family: var(--serif);
        font-size: 0.92rem;
        letter-spacing: 0.08em;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .inav__links a:hover { color: var(--gold-strong); }
      .inav__toggle {
        font-family: var(--gothic);
        font-size: 0.76rem;
        letter-spacing: 0.06em;
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--nav-line);
        border-radius: 999px;
        padding: 0.34rem 0.85rem;
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.2s ease, color 0.2s ease;
      }
      .inav__toggle:hover { border-color: var(--gold); color: var(--gold-strong); }
      /* ハンバーガー（スマホのみ）。PCでは隠す */
      .inav__burger { display: none; }
      @media (max-width: 720px) {
        .inav__burger {
          display: inline-grid; gap: 4px; place-content: center;
          width: 42px; height: 38px; margin-left: auto; padding: 0 9px;
          background: transparent; border: 1px solid var(--nav-line); border-radius: 10px; cursor: pointer;
        }
        .inav__burger span { display: block; width: 22px; height: 2px; background: var(--gold-strong); border-radius: 2px; transition: transform 0.25s ease, opacity 0.2s ease; }
        .inav.nav-open .inav__burger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
        .inav.nav-open .inav__burger span:nth-child(2) { opacity: 0; }
        .inav.nav-open .inav__burger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
        /* リンク群はドロップダウン化（閉じ時は隠す） */
        .inav__links {
          position: absolute; top: 100%; left: 0; right: 0;
          flex-direction: column; align-items: stretch; gap: 0;
          padding: 0.2rem clamp(1rem, 4vw, 2.6rem) 0.7rem;
          background: var(--nav-bg);
          -webkit-backdrop-filter: blur(16px) saturate(1.25); backdrop-filter: blur(16px) saturate(1.25);
          border-bottom: 1px solid var(--nav-line);
          display: none;
        }
        .inav.nav-open .inav__links { display: flex; }
        .inav__links a { padding: 0.72rem 0.1rem; font-size: 1rem; border-top: 1px solid var(--nav-line); }
        .inav__links a:first-child { border-top: 0; }
        /* プレビュー専用トーン切替はスマホで小さく（昇格時に撤去される要素） */
        .inav__toggle { font-size: 0.66rem; padding: 0.3rem 0.6rem; }
      }

      /* ===== 没入ヒーロー ===== */
      .ihero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: flex-end;
        overflow: hidden;
        isolation: isolate;
        background: var(--bg);
      }
      .ihero__kv {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 54% 16%;
        z-index: 0;
        transform-origin: 54% 16%;
      }
      @media (prefers-reduced-motion: no-preference) {
        .ihero__kv { animation: kvZoom 24s ease-in-out infinite alternate; }
      }
      @keyframes kvZoom { from { transform: scale(1); } to { transform: scale(1.07); } }
      .ihero__scrim { position: absolute; inset: 0; z-index: 1; background: var(--scrim); }
      .ihero__glow {
        position: absolute;
        inset: -10%;
        z-index: 1;
        pointer-events: none;
        mix-blend-mode: var(--blend);
        opacity: var(--glow-strength);
        background:
          radial-gradient(38% 46% at 50% 38%, var(--glow-2), transparent 66%),
          radial-gradient(40% 50% at 80% 24%, var(--glow), transparent 64%);
      }
      @media (prefers-reduced-motion: no-preference) {
        .ihero__glow { animation: glowDrift 18s ease-in-out infinite alternate; }
      }
      @keyframes glowDrift {
        from { transform: translate3d(0, 0, 0) scale(1); }
        to { transform: translate3d(2%, -1.6%, 0) scale(1.08); }
      }
      .ihero__content {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: clamp(2rem, 8vw, 6rem) clamp(1.3rem, 5vw, 4rem) clamp(3rem, 9vw, 6.5rem);
      }
      .ihero__inner { max-width: 50rem; }
      .ihero__kicker {
        font-family: var(--gothic);
        font-size: 0.84rem;
        letter-spacing: 0.34em;
        color: var(--gold-strong);
        margin-bottom: 1.1rem;
      }
      .ihero__name {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(3rem, 11vw, 6.4rem);
        letter-spacing: 0.1em;
        line-height: 1.04;
        color: var(--ink);
      }
      .ihero__romaji {
        font-family: var(--logo);
        font-size: clamp(0.8rem, 2.4vw, 1.05rem);
        letter-spacing: 0.42em;
        color: var(--muted);
        margin: 0.7rem 0 1.5rem;
      }
      .ihero__tag {
        font-size: clamp(1.02rem, 2.6vw, 1.3rem);
        line-height: 1.95;
        color: var(--ink-soft);
        margin-bottom: 2rem;
      }
      .ihero__cta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; }
      /* YouTubeライブ中バッジ：検知時に heroReveal（ブラー＋translateY 複合入場）で点灯 */
      .ilive {
        position: absolute;
        top: clamp(4.4rem, 11vh, 7rem);
        left: clamp(1.3rem, 5vw, 4rem);
        z-index: 4;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        max-width: min(86vw, 30rem);
        padding: 0.45rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        background: rgba(28, 16, 14, 0.66);
        border: 1px solid rgba(229, 90, 90, 0.6);
        color: #ffe3de;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.4);
      }
      .ilive[hidden] { display: none; } /* [hidden]を確実に優先 */
      .ilive.is-live { animation: heroReveal 0.85s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
      .ilive__dot { flex-shrink: 0; width: 0.62rem; height: 0.62rem; border-radius: 50%; background: #ff5252; box-shadow: 0 0 0 0 rgba(255, 82, 82, 0.6); animation: livePulse 1.8s ease-out infinite; }
      .ilive__now { flex-shrink: 0; color: #ff8a80; }
      .ilive__title { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: var(--ink-soft); font-weight: 500; }
      @keyframes heroReveal { from { opacity: 0; transform: translateY(-16px); filter: blur(10px); } to { opacity: 1; transform: none; filter: none; } }
      @keyframes livePulse { 0% { box-shadow: 0 0 0 0 rgba(255, 82, 82, 0.55); } 70% { box-shadow: 0 0 0 0.5rem rgba(255, 82, 82, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 82, 82, 0); } }
      @media (prefers-reduced-motion: reduce) {
        .ilive__dot { animation: none; }
        .ilive.is-live { animation: none; }
      }
      .ibtn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.85rem 1.8rem;
        border-radius: 999px;
        font-size: 0.98rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.18s ease, background 0.2s ease, border-color 0.2s ease;
      }
      .ibtn--solid { background: var(--gold-strong); color: var(--bg); border: 1px solid var(--gold-strong); }
      .ibtn--solid:hover { transform: translateY(-2px); }
      .ibtn--ghost { background: transparent; color: var(--gold-strong); border: 1px solid var(--gold); }
      .ibtn--ghost:hover { transform: translateY(-2px); border-color: var(--gold-strong); }
      /* §37 テキストロール＋矢印回転（ヒーローCTA）：ホバーで文字が巻き上がり、矢印が -45°→0° に立つ */
      .ibtn--roll { overflow: hidden; }
      .ibtn__roll { display: block; overflow: hidden; height: 1.2em; }
      .ibtn__rollinner { display: flex; flex-direction: column; transition: transform 0.42s cubic-bezier(0.22, 1, 0.36, 1); }
      .ibtn__rollinner > span { height: 1.2em; line-height: 1.2em; white-space: nowrap; }
      .ibtn--roll:hover .ibtn__rollinner, .ibtn--roll:focus-visible .ibtn__rollinner { transform: translateY(-50%); }
      .ibtn__arrow { display: inline-block; transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1); transform: rotate(-45deg); }
      .ibtn--roll:hover .ibtn__arrow, .ibtn--roll:focus-visible .ibtn__arrow { transform: rotate(0deg); }
      .ibtn__yt { width: 1.15em; height: 1.15em; flex-shrink: 0; fill: #ff4d4d; }
      .ibtn--yt:hover { border-color: #ff6a6a; }
      @media (prefers-reduced-motion: reduce) {
        .ibtn__rollinner, .ibtn__arrow { transition: none; }
      }
      .ihero__scrollcue {
        position: absolute;
        left: 50%;
        bottom: 1.2rem;
        z-index: 2;
        transform: translateX(-50%);
        font-family: var(--logo);
        font-size: 0.62rem;
        letter-spacing: 0.36em;
        color: var(--muted);
        text-transform: uppercase;
      }

      /* ===== 没入セクション（スケジュール） ===== */
      .isec {
        position: relative;
        padding: clamp(3.5rem, 9vw, 7rem) clamp(1.3rem, 5vw, 4rem);
        background: var(--bg);
        overflow: clip;
      }
      .isec::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(36% 44% at 16% 24%, var(--glow), transparent 62%),
          radial-gradient(40% 50% at 86% 78%, var(--glow), transparent 64%);
        opacity: calc(0.5 * var(--glow-strength));
      }
      .isec__inner { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; }
      .ihead { text-align: center; margin-bottom: clamp(1.8rem, 4vw, 3rem); }
      .ihead__kicker {
        font-family: var(--logo);
        font-size: clamp(2.2rem, 7vw, 3.8rem);
        font-weight: 500;
        letter-spacing: 0.1em;
        color: var(--gold);
        opacity: 0.85;
        line-height: 1;
      }
      .ihead__title {
        font-family: var(--serif);
        font-size: clamp(1.15rem, 3vw, 1.5rem);
        letter-spacing: 0.14em;
        color: var(--ink);
        margin-top: 0.4rem;
      }
      .ihead__rule {
        display: block;
        width: 3.4rem;
        height: 1px;
        margin: 1rem auto 0;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
      }
      .icards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.1rem;
        margin-top: 2rem;
      }
      .icard {
        position: relative;
        border-radius: 16px;
        padding: 1.3rem 1.4rem;
        background: var(--card-bg);
        border: 1px solid var(--card-line);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34);
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
        overflow: hidden;
      }
      .icard__day {
        font-family: var(--serif);
        font-size: 1.05rem;
        letter-spacing: 0.1em;
        color: var(--gold-strong);
        margin-bottom: 0.7rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid var(--card-line);
      }
      .icard__row { display: flex; gap: 0.7rem; align-items: baseline; padding: 0.3rem 0; }
      .icard__time { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--gold-strong); flex-shrink: 0; }
      .icard__title { color: var(--ink-soft); font-size: 0.98rem; }
      .icard__off { color: var(--muted); font-size: 0.95rem; }
      .isec__note { text-align: center; margin-top: 1.6rem; font-size: 0.86rem; color: var(--muted); }

      /* ===== フッター（薄く） ===== */
      /* ===== 一番下：浮遊アイコンの帯（プラスアルファの装飾・floatSlow） ===== */
      .iconband {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: clamp(1.4rem, 6vw, 3.6rem);
        padding: clamp(2.6rem, 7vw, 4.8rem) 1.2rem clamp(1.4rem, 4vw, 2.6rem);
      }
      .iconband__i { color: var(--gold); opacity: 0.5; }
      .iconband__i:nth-child(odd) { color: var(--gold-strong); opacity: 0.62; }
      .iconband__i:nth-child(3n) { margin-top: -0.8rem; }
      .iconband__i:nth-child(3n + 2) { margin-top: 0.7rem; }
      .iconband__i svg { width: clamp(26px, 4.4vw, 38px); height: clamp(26px, 4.4vw, 38px); display: block; }
      @media (prefers-reduced-motion: no-preference) {
        .iconband__i { animation: floatSlow 5.6s ease-in-out infinite; }
        .iconband__i:nth-child(2) { animation-delay: -0.9s; }
        .iconband__i:nth-child(3) { animation-delay: -1.9s; }
        .iconband__i:nth-child(4) { animation-delay: -2.8s; }
        .iconband__i:nth-child(5) { animation-delay: -3.7s; }
        .iconband__i:nth-child(6) { animation-delay: -4.5s; }
      }
      .ifoot {
        text-align: center;
        padding: 2.6rem 1rem 3.2rem;
        background: var(--bg-2);
        border-top: 1px solid var(--nav-line);
      }
      .ifoot__brand { font-family: var(--serif); font-size: 1.4rem; letter-spacing: 0.3em; color: var(--ink); }
      .ifoot__en { font-family: var(--logo); font-size: 0.6rem; letter-spacing: 0.4em; color: var(--muted); text-transform: uppercase; margin-top: 0.4rem; }

      /* ===== 登場演出（ブラー＋立ち上がり） ===== */
      .reveal { opacity: 0; transform: translateY(30px); filter: blur(10px); transition: opacity 0.85s ease, transform 0.85s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.85s ease; }
      .reveal.is-visible { opacity: 1; transform: none; filter: none; }
      /* 最も基本的な映画的入場：ラベル→見出し→説明文が0.2秒刻みで順に立ち上がる（軽量＝blurなし） */
      /* ロード画面が明けてから再生（裏で再生し終わるのを防ぐ）＝html.intro-go で起動 */
      .intro > * { opacity: 0; transform: translateY(24px); animation: introRise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) both; animation-play-state: paused; }
      html.intro-go .intro > * { animation-play-state: running; }
      .intro > :nth-child(2), .intro > :nth-child(3) { animation-delay: 0.2s; } /* 見出し＋ローマ字 */
      .intro > :nth-child(4) { animation-delay: 0.4s; } /* 説明文 */
      .intro > :nth-child(5) { animation-delay: 0.6s; } /* CTA */
      @keyframes introRise { to { opacity: 1; transform: none; } }

      /* ===== PROFILE ===== */
      .isec--alt { background: var(--bg-2); }
      .iprofile { display: flex; flex-direction: column; align-items: center; gap: 1.6rem; }
      .iprofile__art { width: calc(min(70%, 360px) * var(--art-scale)); }
      .iprofile__art :global(img) { width: 100%; height: auto; }
      .iprofile__body { width: 100%; max-width: 36rem; }
      .iprofile__list { margin: 0 0 1.2rem; }
      .iprofile__row {
        display: grid;
        grid-template-columns: 6.6rem 1fr;
        align-items: baseline;
        gap: 0.3rem 1.1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--card-line);
      }
      .iprofile__row dt { position: relative; margin: 0; padding-left: 1.15rem; color: var(--muted); font-size: 0.82rem; letter-spacing: 0.08em; white-space: nowrap; }
      .iprofile__row dt::before { content: '◆'; position: absolute; left: 0; top: 0.2em; color: var(--gold); font-size: 0.52rem; }
      .iprofile__row dd { margin: 0; color: var(--ink); font-size: 1.04rem; line-height: 1.5; }
      /* プロフィール項目：リスト段差出現（ブロックが画面に入ったら1項目ずつ立ち上がる） */
      .iprofile__row { opacity: 0; transform: translateY(12px); transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.2, 0.7, 0.2, 1); }
      .iprofile.is-visible .iprofile__row { opacity: 1; transform: none; }
      .iprofile.is-visible .iprofile__row:nth-child(1) { transition-delay: 0.08s; }
      .iprofile.is-visible .iprofile__row:nth-child(2) { transition-delay: 0.16s; }
      .iprofile.is-visible .iprofile__row:nth-child(3) { transition-delay: 0.24s; }
      .iprofile.is-visible .iprofile__row:nth-child(4) { transition-delay: 0.32s; }
      .iprofile.is-visible .iprofile__row:nth-child(5) { transition-delay: 0.4s; }
      .iprofile.is-visible .iprofile__row:nth-child(6) { transition-delay: 0.48s; }
      .iprofile.is-visible .iprofile__row:nth-child(7) { transition-delay: 0.56s; }
      .iprofile.is-visible .iprofile__row:nth-child(8) { transition-delay: 0.64s; }
      .iprofile.is-visible .iprofile__row:nth-child(9) { transition-delay: 0.72s; }
      .iprofile__chips { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; }
      .iprofile__chips li {
        padding: 0.4rem 1.2rem;
        border: 1px solid var(--gold);
        border-radius: 999px;
        color: var(--gold-strong);
        font-size: 0.92rem;
        background: var(--card-bg);
      }
      @media (min-width: 860px) {
        .iprofile { flex-direction: row; align-items: flex-start; gap: 3rem; max-width: 1080px; margin: 0 auto; }
        .iprofile__art { flex-shrink: 0; width: calc(min(48%, 462px) * var(--art-scale)); }
        .iprofile__body { flex: 1 1 0; min-width: 0; max-width: 30rem; margin-top: 1rem; }
      }

      /* ===== ABOUT（ごあいさつ） ===== */
      .iabout { display: flex; flex-direction: column; align-items: center; gap: 1.6rem; text-align: center; }
      .iabout__art { width: calc(min(76%, 360px) * var(--art-scale)); }
      .iabout__art :global(img) {
        width: 100%;
        height: auto;
        -webkit-mask-image: linear-gradient(to bottom, #000 84%, transparent 100%);
        mask-image: linear-gradient(to bottom, #000 84%, transparent 100%);
      }
      .iabout__catch { font-family: var(--serif); font-weight: 700; font-size: clamp(1.7rem, 4.6vw, 2.6rem); line-height: 1.42; color: var(--gold-strong); margin: 0 0 0.4rem; }
      /* §67 revealLine：catchを1行ずつ clip-path で左から拭って出す。既存 .reveal→.is-visible のトリガに同乗（JS不要）。本文は読みやすさ優先でワイプしない */
      .iabout__catchline { display: block; clip-path: inset(0 100% 0 0); }
      .iabout.is-visible .iabout__catchline { animation: revealLine 1s cubic-bezier(0.77, 0, 0.18, 1) forwards; }
      .iabout.is-visible .iabout__catchline:nth-child(1) { animation-delay: 0.05s; }
      .iabout.is-visible .iabout__catchline:nth-child(2) { animation-delay: 0.28s; }
      @keyframes revealLine { from { clip-path: inset(0 100% 0 0); } to { clip-path: inset(0 0% 0 0); } }
      @media (prefers-reduced-motion: reduce) {
        .iabout__catchline { clip-path: inset(0 0 0 0); }
        .iabout.is-visible .iabout__catchline { animation: none; }
      }
      .iabout__en { font-style: italic; font-size: clamp(0.82rem, 2.2vw, 1rem); color: var(--muted); margin: 0 0 1rem; }
      .iabout__rule { display: block; width: 3.2rem; height: 1px; margin: 0 auto 1.2rem; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
      .iabout__story { text-align: left; max-width: 34rem; margin: 0 auto; }
      .iabout__story p { margin: 0 0 0.9rem; font-size: 1rem; line-height: 2; color: var(--ink-soft); }
      .iabout__story p:last-child { margin-bottom: 0; }
      @media (min-width: 860px) {
        .iabout { flex-direction: row; align-items: center; gap: 3rem; text-align: left; max-width: 1040px; margin: 0 auto; }
        .iabout__body { flex: 1 1 0; min-width: 0; }
        .iabout__art { flex-shrink: 0; width: calc(min(50%, 470px) * var(--art-scale)); }
        .iabout__rule { margin-left: 0; margin-right: auto; }
        .iabout__story { max-width: none; }
      }

      /* ===== 残りセクション共通 ===== */
      .isec__lead { text-align: center; max-width: 40rem; margin: 0 auto 1.7rem; color: var(--ink-soft); line-height: 1.9; text-wrap: balance; word-break: auto-phrase; }
      /* 文の区切り（。）で折り返す保険：日本語の不自然な改行（「す。」だけ落ちる/「順次」が割れる）を防ぐ */
      .isec__lead .nb { display: inline-block; }
      .isec__inner--narrow { max-width: 640px; }

      /* ===== PICK UP（おすすめ）：横並びカード（吹き出しラベル付き） ===== */
      .ipick { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 1.7rem 1.3rem; max-width: 1000px; margin: 0 auto; }
      .ipick__card { display: block; text-decoration: none; color: var(--ink-soft); }
      .ipick__pick { position: relative; display: block; width: max-content; max-width: 100%; margin: 0 auto 0.85rem; padding: 0.34rem 1rem; border-radius: 999px; background: var(--gold-bright); color: #14100b; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em; text-align: center; }
      .ipick__pick::after { content: ''; position: absolute; left: 50%; bottom: -5px; width: 10px; height: 10px; background: var(--gold-bright); transform: translateX(-50%) rotate(45deg); }
      .ipick__thumb { display: grid; place-items: center; aspect-ratio: 16 / 9; border-radius: 12px; overflow: hidden; background: linear-gradient(150deg, #2a2014, #14100a); border: 1px solid var(--card-line); color: var(--gold); font-size: 1.6rem; box-shadow: 0 12px 28px rgba(0, 0, 0, 0.4); transition: transform 0.25s ease; }
      .ipick__card:hover .ipick__thumb { transform: translateY(-4px); }
      .ipick__title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-top: 0.6rem; font-size: 0.92rem; line-height: 1.5; }

      /* ===== VIDEO（最新動画）：オートスクロールのリール（フィルムロール風・端フェード） ===== */
      .ireel { position: relative; overflow: hidden; max-width: 1180px; margin: 0 auto; -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent); }
      .ireel__track { display: flex; width: max-content; }
      .ireel__card { flex: 0 0 clamp(232px, 26vw, 290px); margin-right: 1.2rem; text-decoration: none; color: var(--ink-soft); }
      .ireel__thumb { display: grid; place-items: center; aspect-ratio: 16 / 9; border-radius: 12px; overflow: hidden; background: linear-gradient(150deg, #2a2014, #14100a); border: 1px solid var(--card-line); color: var(--gold); font-size: 1.6rem; box-shadow: 0 12px 28px rgba(0, 0, 0, 0.4); }
      .ireel__title { display: block; margin-top: 0.55rem; font-size: 0.9rem; line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      /* 実データのサムネ画像（あればグリフ▶の代わりに敷く） */
      .ipick__thumb img, .ireel__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
      @media (prefers-reduced-motion: no-preference) and (min-width: 641px) {
        .ireel__track { animation: reelRoll 34s linear infinite; }
        .ireel:hover .ireel__track { animation-play-state: paused; }
      }
      @keyframes reelRoll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
      /* 動きが苦手な設定・スマホ：自動スクロールを止めて手スワイプの横スクロールに（複製カードは隠す／スナップ付き） */
      @media (prefers-reduced-motion: reduce), (max-width: 640px) {
        .ireel { overflow-x: auto; scroll-snap-type: x proximity; -webkit-overflow-scrolling: touch; }
        .ireel__track { animation: none; }
        .ireel__card { scroll-snap-align: start; }
        .ireel__card[aria-hidden='true'] { display: none; }
      }

      /* ===== 各セクションの「すべて見る →」導線 ===== */
      .isec__more { max-width: 1000px; margin: 1.2rem auto 0; text-align: right; }
      .isec__more a { color: var(--gold-strong); text-decoration: none; font-size: 0.92rem; letter-spacing: 0.04em; }
      .isec__more a:hover { text-decoration: underline; text-underline-offset: 3px; }

      /* ===== ヒーロー直下：最新お知らせ1行バー ===== */
      .inewsbar { display: flex; align-items: center; gap: 0.8rem; max-width: 1100px; margin: 0 auto; padding: 0.7rem clamp(1.2rem, 4vw, 2rem); border-top: 1px solid var(--card-line); border-bottom: 1px solid var(--card-line); background: rgba(20, 14, 9, 0.55); text-decoration: none; color: var(--ink-soft); font-size: 0.9rem; }
      .inewsbar__tag { flex-shrink: 0; color: var(--gold-strong); font-weight: 700; letter-spacing: 0.08em; font-size: 0.78rem; }
      .inewsbar__date { flex-shrink: 0; color: var(--muted); font-size: 0.78rem; font-variant-numeric: tabular-nums; }
      .inewsbar__title { flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
      .inewsbar__more { flex-shrink: 0; color: var(--gold-strong); font-size: 0.8rem; white-space: nowrap; }
      .inewsbar:hover .inewsbar__more { text-decoration: underline; text-underline-offset: 2px; }
      @media (max-width: 640px) { .inewsbar { font-size: 0.84rem; gap: 0.55rem; } .inewsbar__date { display: none; } }

      /* ===== GALLERY（準備中）：金のひし形＋細罫で上品に ===== */
      .igallery-soon { display: grid; place-items: center; gap: 0.55rem; max-width: 1000px; margin: 1.3rem auto 0; min-height: clamp(150px, 24vw, 230px); border: 1px solid var(--card-line); border-radius: 16px; background: radial-gradient(64% 82% at 50% 28%, rgba(201, 168, 105, 0.08), transparent 70%), var(--card-bg); color: var(--gold-strong); font-family: var(--serif); letter-spacing: 0.22em; font-size: clamp(0.95rem, 2.6vw, 1.25rem); text-transform: uppercase; }
      .igallery-soon::before { content: ''; width: 7px; height: 7px; transform: rotate(45deg); background: var(--gold); }

      /* INFORMATION */
      .inews { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.2rem; max-width: 1000px; margin: 0 auto; }
      /* お知らせ：ネオモーフィズム（暗地に二方向シャドウで浮き出す立体感） */
      .inews__card {
        display: block;
        text-decoration: none;
        color: var(--ink);
        background: linear-gradient(145deg, #1f1810, #130f09);
        border: 1px solid rgba(201, 168, 105, 0.1);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 7px 7px 16px rgba(0, 0, 0, 0.6), -6px -6px 14px rgba(120, 100, 64, 0.1);
        transition: box-shadow 0.28s ease, transform 0.28s ease;
      }
      .inews__card:hover {
        transform: translateY(-3px);
        box-shadow: 10px 10px 24px rgba(0, 0, 0, 0.64), -7px -7px 16px rgba(120, 100, 64, 0.14);
      }
      .inews__thumb { display: block; position: relative; aspect-ratio: 16 / 9; background: linear-gradient(150deg, #2a2014, #15100a); }
      .inews__thumb img { width: 100%; height: 100%; object-fit: cover; }
      .inews__ph { position: absolute; inset: 0; display: grid; place-items: center; color: var(--gold); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem; }
      .inews__meta { display: flex; gap: 0.7rem; padding: 0.7rem 0.9rem 0; font-size: 0.74rem; color: var(--muted); }
      .inews__cat { color: var(--gold-strong); text-transform: uppercase; letter-spacing: 0.08em; }
      .inews__title { display: block; padding: 0.3rem 0.9rem 0.9rem; font-size: 0.96rem; line-height: 1.5; }

      /* STORE（SpotlightBorder：カーソル追従の光る枠） */
      .ispot {
        --spot-x: -9999px;
        --spot-y: -9999px;
        --spot-size: 300px;
        position: relative; max-width: 760px; margin: 0 auto; border-radius: 18px; padding: 1.5px;
        background: linear-gradient(135deg, rgba(201, 168, 105, 0.22), rgba(201, 168, 105, 0.05));
      }
      .ispot::before {
        content: ''; position: absolute; inset: 0; border-radius: 18px; padding: 1.5px;
        background: radial-gradient(circle var(--spot-size) at var(--spot-x) var(--spot-y), var(--gold-bright), transparent 60%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
      }
      .istore { position: relative; display: block; width: 100%; border-radius: 16.5px; overflow: hidden; min-height: clamp(150px, 24vw, 230px); box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4); text-decoration: none; }
      .istore__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 28%; }
      .istore::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(10, 8, 5, 0.86), rgba(10, 8, 5, 0.42) 60%, transparent); }
      .istore__text { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 0.3rem; padding: clamp(1.4rem, 4vw, 2.2rem); }
      .istore__en { font-family: var(--logo); letter-spacing: 0.22em; font-size: 0.8rem; color: var(--gold-strong); }
      .istore__jp { font-family: var(--serif); font-size: clamp(1.4rem, 4vw, 2rem); color: #fffdf8; font-weight: 700; }
      .istore__btn { position: absolute; right: clamp(1rem, 3vw, 2rem); bottom: clamp(1rem, 3vw, 2rem); z-index: 1; padding: 0.5rem 1.15rem; border-radius: 999px; background: var(--gold-bright); color: #14100b; font-weight: 700; font-size: 0.88rem; }

      /* FOLLOW */
      .ifollow { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; max-width: 820px; margin: 0 auto; }
      /* §15 グロービューカード（blur45px＋グラデ枠）に寄せる：太いグラデ枠＋背後の上方オーラ＋上にSNSアイコン */
      .ifollow__card {
        position: relative; isolation: isolate;
        display: flex; flex-direction: column; gap: 0.3rem;
        padding: 1.55rem 1.45rem; border-radius: 16px; text-decoration: none;
        border: 1.5px solid transparent;
        background:
          linear-gradient(#1a130b, #1a130b) padding-box,
          linear-gradient(140deg, var(--gc1, var(--gold)), var(--gc2, var(--gold-strong))) border-box;
        box-shadow: inset 0 1px 0 rgba(232, 207, 149, 0.06);
        transition: transform 0.2s ease, box-shadow 0.25s ease;
      }
      .ifollow__card::before {
        content: ''; position: absolute; inset: -10px 10px auto 10px; height: 56%; z-index: -1; border-radius: 30px;
        background: linear-gradient(140deg, var(--gc1, var(--gold)), var(--gc2, var(--gold-strong)));
        filter: blur(44px); opacity: 0.22; transition: opacity 0.25s ease; pointer-events: none;
      }
      .ifollow__card:hover { transform: translateY(-3px); }
      .ifollow__card:hover::before { opacity: 0.36; }
      /* くすませた上品トーン（原色をやめ、深く落ち着いた色味に） */
      .ifollow--yt { --gc1: #c2645a; --gc2: #6b332e; }
      .ifollow--x { --gc1: #93a6bf; --gc2: #3a4658; }
      .ifollow--ma { --gc1: #cf94ac; --gc2: #8f5870; }
      .ifollow__icon { display: inline-flex; width: 1.9rem; height: 1.9rem; margin-bottom: 0.4rem; }
      .ifollow__icon svg { width: 100%; height: 100%; fill: var(--gc1, var(--gold)); }
      .ifollow__label { font-family: var(--serif); font-size: 1.18rem; font-weight: 700; color: var(--gold-strong); }
      .ifollow__sub { font-size: 0.82rem; color: var(--muted); }

      /* GUIDELINE */
      .iguide { max-width: 640px; margin: 0 auto; display: grid; gap: 1.3rem; }
      .iguide__block h3 { font-size: 1.05rem; color: var(--gold-strong); margin: 0 0 0.5rem; font-family: var(--serif); letter-spacing: 0.04em; }
      .iguide__block ul { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.5rem; }
      .iguide__block li { position: relative; padding-left: 1.3rem; color: var(--ink-soft); font-size: 0.95rem; line-height: 1.65; }
      .iguide__block li::before { content: '◆'; position: absolute; left: 0; top: 0.2em; color: var(--gold); font-size: 0.56rem; }
      .iguide__block p { margin: 0; color: var(--ink-soft); font-size: 0.95rem; line-height: 1.75; }
      .iguide__block a { color: var(--gold-strong); }

      /* CONTACT（自作フォーム・黒×金） */
      .iform { max-width: 560px; margin: 0 auto; display: grid; gap: 1rem; }
      .iform__field { display: grid; gap: 0.35rem; }
      .iform__field > span { font-size: 0.82rem; color: var(--muted); letter-spacing: 0.04em; }
      .iform__field input, .iform__field select, .iform__field textarea {
        width: 100%; font: inherit; font-size: 0.98rem; color: var(--ink);
        background: rgba(255, 255, 255, 0.04); border: 1px solid var(--card-line); border-radius: 10px;
        padding: 0.7rem 0.85rem; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
      }
      .iform__field input::placeholder, .iform__field textarea::placeholder { color: rgba(184, 168, 136, 0.55); }
      .iform__field input:focus, .iform__field select:focus, .iform__field textarea:focus { outline: none; border-color: var(--gold); }
      .iform__field textarea { resize: vertical; }
      .iform__field select option { color: #14100b; }
      .iform__send { justify-self: start; padding: 0.85rem 2.1rem; border-radius: 999px; border: none; cursor: pointer; font: inherit; font-weight: 600; background: var(--gold-strong); color: var(--bg); transition: transform 0.18s ease; }
      .iform__send:hover { transform: translateY(-2px); }
      .iform__note { font-size: 0.78rem; color: var(--muted); margin: 0; }

      /* ===== 奥行き演出（黒地に光のプール／立ち絵の浮かび上がり） ===== */
      .iprofile__art, .iabout__art { position: relative; }
      .iprofile__art::before, .iabout__art::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 48%;
        width: 122%;
        height: 96%;
        transform: translate(-50%, -50%);
        z-index: 0;
        pointer-events: none;
        background: radial-gradient(50% 50% at 50% 50%, var(--glow-2), transparent 68%);
        opacity: var(--spotlight);
      }
      .iprofile__art :global(img), .iabout__art :global(img) { position: relative; z-index: 1; }
      .iprofile__art :global(img) { filter: drop-shadow(0 26px 44px rgba(0, 0, 0, 0.55)); }
      /* 立ち絵のふわふわ（artFloat）は重いので【保留＝停止中】。復活させるなら下のコメントを外す
      @media (prefers-reduced-motion: no-preference) {
        .iprofile__art :global(img), .iabout__art :global(img) { animation: artFloat 7.5s ease-in-out infinite alternate; }
      }
      @keyframes artFloat { from { transform: translateY(2px); } to { transform: translateY(-10px); } }
      */
      /* 黒トーン：帯と画面の縁を落として中央に視線を集める（奥行き） */
      html[data-form='dark'] .isec { box-shadow: inset 0 0 160px 30px rgba(0, 0, 0, 0.45); }
      html[data-form='dark'] .ihero::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        box-shadow: inset 0 0 220px 60px rgba(0, 0, 0, 0.5);
      }

      /* ===== モバイル軽量化 ===== */
      @media (max-width: 640px) {
        .ihero__glow { display: none; }
        .isec::before { opacity: 0.32; }
        .icard { -webkit-backdrop-filter: none; backdrop-filter: none; }
      }
      /* ===== 動きが苦手な設定：静止 ===== */
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; filter: none; transition: none; }
        .intro > * { opacity: 1; transform: none; filter: none; animation: none; }
        .iprofile__row { opacity: 1; transform: none; transition: none; }
        .ihero__kv, .ihero__glow { animation: none; }
        html { scroll-behavior: auto; }
      }
      /* ===== ロード画面（Type Motion: RISE） ===== */
      .iload { position: fixed; inset: 0; z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.9rem; background: radial-gradient(120% 100% at 50% 38%, #241b10, #0b0805 76%); }
      .iload.is-done { opacity: 0; visibility: hidden; transition: opacity 0.8s ease, visibility 0s 0.8s; }
      .iload__name { display: flex; gap: 0.06em; margin: 0; font-family: var(--serif); font-weight: 600; font-size: clamp(2.4rem, 9vw, 4.2rem); letter-spacing: 0.22em; color: #e8cf95; }
      .iload__name span { display: inline-block; opacity: 0; transform: translateY(0.9em); animation: riseChar 0.72s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
      .iload__name span:nth-child(2) { animation-delay: 0.1s; }
      .iload__name span:nth-child(3) { animation-delay: 0.2s; }
      .iload__name span:nth-child(4) { animation-delay: 0.3s; }
      .iload__en { margin: 0; font-family: var(--logo); font-size: clamp(0.7rem, 2.5vw, 0.92rem); letter-spacing: 0.42em; text-transform: uppercase; color: rgba(232, 207, 149, 0.62); opacity: 0; transform: translateY(0.8em); animation: riseChar 0.7s ease 0.46s both; }
      @keyframes riseChar { to { opacity: 1; transform: none; } }
      @media (prefers-reduced-motion: reduce) {
        .iload__name span, .iload__en { animation: none; opacity: 1; transform: none; }
        .iload.is-done { transition: opacity 0.3s ease; }
      }

      /* ===== フロストガラス丸CTA（ヒーローYouTube） ===== */
      /* §59 フロストガラスCTAアイコン円：bg-white/80 + blur → ホバーでソリッド */
      .ibtn-icon { display: inline-grid; place-items: center; width: 56px; height: 56px; flex-shrink: 0; border-radius: 50%; color: #1c140b; background: rgba(255, 255, 255, 0.8); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.55); box-shadow: 0 6px 18px rgba(0, 0, 0, 0.28); transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease; }
      .ibtn-icon:hover { background: #fff; border-color: #fff; color: #0a0a0a; }
      .ibtn-icon svg { width: 26px; height: 26px; fill: currentColor; }

      /* ===== 浮遊アイコン（floatSlow） ===== */
      @media (prefers-reduced-motion: no-preference) {
        .floaty { animation: floatSlow 5.5s ease-in-out infinite; }
      }
      @keyframes floatSlow { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

      /* ===== 調整パネル（プレビュー専用・LPエディタ風・使い捨て） ===== */
      .ed {
        position: fixed;
        right: 14px;
        bottom: 14px;
        z-index: 90;
        width: 272px;
        max-width: calc(100vw - 28px);
        font-family: var(--gothic);
        color: #f3ecdd;
        background: rgba(18, 14, 9, 0.93);
        border: 1px solid rgba(201, 168, 105, 0.42);
        border-radius: 12px;
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        box-shadow: 0 16px 44px rgba(0, 0, 0, 0.5);
        overflow: hidden;
      }
      .ed__handle {
        width: 100%;
        text-align: left;
        font: inherit;
        font-size: 0.84rem;
        letter-spacing: 0.04em;
        color: #e8cf95;
        background: rgba(201, 168, 105, 0.14);
        border: none;
        border-bottom: 1px solid rgba(201, 168, 105, 0.28);
        padding: 0.6rem 0.85rem;
        cursor: pointer;
      }
      .ed__body { padding: 0.7rem 0.85rem 0.85rem; display: grid; gap: 0.62rem; }
      .ed.is-closed .ed__body { display: none; }
      .ed__tones { display: flex; gap: 0.4rem; }
      .ed__tone {
        flex: 1;
        font: inherit;
        font-size: 0.78rem;
        color: #d8c7a0;
        background: transparent;
        border: 1px solid rgba(201, 168, 105, 0.4);
        border-radius: 7px;
        padding: 0.34rem;
        cursor: pointer;
      }
      .ed__tone.is-on { background: rgba(201, 168, 105, 0.3); color: #fff8ec; }
      .ed__field { display: grid; gap: 0.22rem; }
      .ed__lab { font-size: 0.75rem; color: #d8c7a0; display: flex; justify-content: space-between; align-items: baseline; }
      .ed__lab b { color: #e8cf95; font-weight: 600; }
      .ed__u { color: #9c8f6b; }
      .ed__field input[type='range'] { width: 100%; accent-color: #c9a86a; cursor: pointer; }
      .ed__btns { display: flex; gap: 0.4rem; margin-top: 0.15rem; }
      .ed__btn {
        flex: 1;
        font: inherit;
        font-size: 0.78rem;
        color: #d8c7a0;
        background: transparent;
        border: 1px solid rgba(201, 168, 105, 0.4);
        border-radius: 7px;
        padding: 0.42rem;
        cursor: pointer;
      }
      .ed__btn--p { color: #14100b; background: #cda14e; border-color: #cda14e; font-weight: 600; }
      .ed__msg { font-size: 0.72rem; color: #9bc77f; min-height: 1em; margin: 0; word-break: break-word; }
      @media (max-width: 640px) { .ed { width: 210px; right: 8px; bottom: 8px; } }

      /* 配置編集：ドラッグで移動・ホイールで拡縮（保存され通常表示にも反映） */
      [data-edit] { transform: translate(var(--ex, 0px), var(--ey, 0px)) scale(var(--es, 1)); }
      /* ▼ 本人が調整した配置を既定に焼き込み（デスクトップのみ。モバイルは縦並びのため無補正） */
      @media (min-width: 860px) {
        /* 屋号の左シフトは幅で段階調整（下の min-width:1100/1300/1440 で上書き）。狭い画面は弱めて見切れ防止 */
        [data-edit='hero'] { --ex: -12px; --ey: -46px; --es: 1.04; }
        [data-edit='art-prof'] { --ex: -156px; --ey: -75px; --es: 1.24; }
        [data-edit='txt-prof'] { --ex: -4px; --ey: 125px; --es: 1.36; }
        [data-edit='txt-about'] { --ex: -95px; --ey: -45px; --es: 1.12; }
        [data-edit='art-about'] { --ex: 175px; --ey: 29px; --es: 1.36; }
      }
      /* 屋号の左シフトを幅で段階強化（実測した余裕の内側＝見切れ防止／広い画面≥1440は調整値−157pxを維持） */
      @media (min-width: 1100px) { [data-edit='hero'] { --ex: -28px; } }
      @media (min-width: 1280px) { [data-edit='hero'] { --ex: -75px; } }
      @media (min-width: 1440px) { [data-edit='hero'] { --ex: -157px; } }
      html.is-editing [data-edit] { outline: 1px dashed rgba(201, 168, 105, 0.6); outline-offset: 5px; cursor: grab; }
      html.is-editing [data-edit]:hover { outline-color: #e8cf95; }
      html.is-editing [data-edit].is-grab { cursor: grabbing; }
      .ed__edit { width: 100%; }
      .ed__edit.is-on { background: #cda14e; color: #14100b; border-color: #cda14e; font-weight: 600; }
    </style>
  </head>
  <body>
    <div class="iload" id="iload" aria-hidden="true">
      <p class="iload__name"><span>和</span><span>香</span><span>松</span><span>庵</span></p>
      <p class="iload__en">Official Site</p>
    </div>
    <noscript>
      <style>
        .iload { display: none !important; } /* JS無効：ロード画面で全面が隠れないように */
        .intro > * { animation: none !important; opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    <header class="inav">
      <a href="#top" class="inav__brand" style="text-decoration:none">
        <span class="en">Indie VTuber</span>
        <span class="jp">{site.name}</span>
      </a>
      <nav class="inav__links" id="inav-links">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <button class="inav__burger" type="button" aria-label="メニューを開閉" aria-expanded="false" aria-controls="inav-links">
        <span></span><span></span><span></span>
      </button>
      <button class="inav__toggle" type="button" data-toggle>トーン切替（明⇄黒金）</button>
    </header>

    <section class="ihero" id="top">
      <Image
        class="ihero__kv"
        src={keyVisual}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        quality={88}
        alt={`${site.name}のキービジュアル`}
        loading="eager"
        fetchpriority="high"
      />
      <div class="ihero__scrim" aria-hidden="true"></div>
      <div class="ihero__glow" aria-hidden="true"></div>
      <a class="ilive" href={site.links.youtube} rel="noopener" target="_blank" hidden>
        <span class="ilive__dot" aria-hidden="true"></span>
        <span class="ilive__now">配信中</span>
        <span class="ilive__title"></span>
      </a>
      <div class="ihero__content">
        <div class="ihero__inner intro" data-edit="hero">
          <p class="ihero__kicker">Cafe &amp; Bar の店長 ・ 個人勢VTuber</p>
          <h1 class="ihero__name">{site.name}</h1>
          <p class="ihero__romaji">WAKAMATSU IORI</p>
          <p class="ihero__tag">雑談とゲームを肴に、ゆるりと楽しい夜を。<br />ようこそ、隠れ家カフェ＆バーへ。</p>
          <div class="ihero__cta">
            <a class="ibtn ibtn--solid ibtn--roll" href="#schedule">
              <span class="ibtn__roll"><span class="ibtn__rollinner"><span>今夜の品書きを見る</span><span aria-hidden="true">今夜の品書きを見る</span></span></span>
              <span class="ibtn__arrow" aria-hidden="true">→</span>
            </a>
            <a class="ibtn ibtn--ghost ibtn--roll ibtn--yt" href={site.links.youtube} rel="me noopener" target="_blank" aria-label="YouTubeチャンネルへ">
              <svg class="ibtn__yt" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              <span class="ibtn__roll"><span class="ibtn__rollinner"><span>YouTube</span><span aria-hidden="true">YouTube</span></span></span>
              <span class="ibtn__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
      <span class="ihero__scrollcue" aria-hidden="true">scroll</span>
    </section>

    {
      information.length > 0 && (
        <a class="inewsbar" href="#information">
          <span class="inewsbar__tag">✦ NEW</span>
          <time class="inewsbar__date">{information[0]?.date}</time>
          <span class="inewsbar__title">{information[0]?.title}</span>
          <span class="inewsbar__more">お知らせへ <span aria-hidden="true">→</span></span>
        </a>
      )
    }

    <section class="isec isec--alt" id="profile">
      <div class="isec__inner">
        <div class="ihead reveal">
          <p class="ihead__kicker">PROFILE</p>
          <span class="ihead__rule" aria-hidden="true"></span>
        </div>
        <div class="iprofile reveal">
          <div class="iprofile__art" data-edit="art-prof">
            <Image
              src={standArt}
              widths={[440, 660, 920, 1280]}
              sizes="(min-width: 860px) 600px, 80vw"
              quality={90}
              alt={`${site.name}の立ち絵`}
              loading="lazy"
            />
          </div>
          <div class="iprofile__body" data-edit="txt-prof">
            <dl class="iprofile__list">
              {profile.rows.map((row) => (
                <div class="iprofile__row">
                  <dt>{row.label}</dt>
                  <dd>{row.value}</dd>
                </div>
              ))}
            </dl>
            <ul class="iprofile__chips">
              {profile.chips.map((chip) => <li>{chip}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="isec" id="about">
      <div class="isec__inner">
        <div class="iabout reveal">
          <div class="iabout__body" data-edit="txt-about">
            <h2 class="iabout__catch">{intro.catchLines.map((line) => (<span class="iabout__catchline">{line}</span>))}</h2>
            <p class="iabout__en">{intro.catchEn}</p>
            <span class="iabout__rule" aria-hidden="true"></span>
            <div class="iabout__story">
              {intro.story.map((para) => <p>{para}</p>)}
            </div>
          </div>
          <div class="iabout__art" data-edit="art-about">
            <Image
              src={barArt}
              widths={[440, 680, 960, 1320]}
              sizes="(min-width: 860px) 660px, 80vw"
              quality={90}
              alt={`${site.name}の立ち絵（カクテルをお届け）`}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="isec" id="schedule">
      <div class="isec__inner">
        <div class="ihead reveal">
          <p class="ihead__kicker">SCHEDULE</p>
          <p class="ihead__title">今週の品書き</p>
          <span class="ihead__rule" aria-hidden="true"></span>
        </div>
        {
          days.length === 0 ? (
            <p class="isec__note reveal">直近の配信予定はまだありません。</p>
          ) : (
            <div class="icards reveal">
              {days.map((day) => (
                <article class="icard">
                  <p class="icard__day">{day.label}</p>
                  {day.events.length === 0 ? (
                    <p class="icard__off">— 休業 —</p>
                  ) : (
                    day.events.map((ev) => (
                      <div class="icard__row">
                        <span class="icard__time">{jstTime(ev.start)}</span>
                        <span class="icard__title">{ev.title}</span>
                      </div>
                    ))
                  )}
                </article>
              ))}
            </div>
          )
        }
        <p class="isec__more reveal"><a href="/schedule">スケジュールをすべて見る →</a></p>
      </div>
    </section>

    {
      pickList.length > 0 && (
        <section class="isec isec--alt" id="pickup">
          <div class="isec__inner">
            <div class="ihead reveal"><p class="ihead__kicker">PICK UP</p><p class="ihead__title">おすすめ</p><span class="ihead__rule" aria-hidden="true"></span></div>
            <p class="isec__lead reveal">いま観てほしい配信をピックアップ。</p>
            <div class="ipick reveal">
              {pickList.map((v, i) => (
                <a class="ipick__card" href={v.url} target="_blank" rel="noopener">
                  <span class="ipick__pick">{featuredLabels[i] ?? 'おすすめ！'}</span>
                  <span class="ipick__thumb">
                    {v.thumbnailUrl ? (
                      <img src={v.thumbnailUrl} alt="" loading="lazy" decoding="async" />
                    ) : (
                      <span class="ipick__ph" aria-hidden="true">▶</span>
                    )}
                  </span>
                  <span class="ipick__title">{v.title}</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section class="isec" id="videos">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">VIDEO</p><p class="ihead__title">最新動画</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <p class="isec__lead reveal">最新の配信アーカイブはこちら。公開後はここに自動で並びます。</p>
        {
          reelList.length > 0 ? (
            <div class="ireel reveal">
              <div class="ireel__track">
                {[0, 1].flatMap((dup) =>
                  reelList.map((v) => (
                    <a
                      class="ireel__card"
                      href={v.url}
                      target="_blank"
                      rel="noopener"
                      aria-hidden={dup === 1 ? 'true' : undefined}
                      tabindex={dup === 1 ? -1 : undefined}
                    >
                      <span class="ireel__thumb">
                        {v.thumbnailUrl ? (
                          <img src={v.thumbnailUrl} alt="" loading="lazy" decoding="async" />
                        ) : (
                          <span class="ireel__ph" aria-hidden="true">▶</span>
                        )}
                      </span>
                      <span class="ireel__title">{v.title}</span>
                    </a>
                  ))
                )}
              </div>
            </div>
          ) : (
            <p class="isec__note reveal">最新動画はまもなく表示されます。</p>
          )
        }
        <p class="isec__more reveal"><a href="/videos">動画をすべて見る →</a></p>
      </div>
    </section>

    <section class="isec isec--alt" id="information">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">INFORMATION</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <div class="inews reveal">
          {
            information.slice(0, 3).map((item) => {
              const Tag = item.url ? 'a' : 'div';
              const props = item.url ? { href: item.url } : {};
              return (
                <Tag class="inews__card" {...props}>
                  <span class="inews__thumb">
                    {item.image ? <img src={item.image} alt="" loading="lazy" /> : <span class="inews__ph">{item.category}</span>}
                  </span>
                  <span class="inews__meta"><time>{item.date}</time><span class="inews__cat">{item.category}</span></span>
                  <span class="inews__title">{item.title}</span>
                </Tag>
              );
            })
          }
        </div>
        <p class="isec__more reveal"><a href="/news">過去のお知らせ一覧 →</a></p>
      </div>
    </section>

    <section class="isec" id="gallery">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">GALLERY</p><p class="ihead__title">ギャラリー</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <p class="isec__lead reveal">わたしの色んな姿や、みんなが描いてくれたファンアートをご紹介！</p>
        <div class="igallery-soon reveal">Coming soon …</div>
      </div>
    </section>

    <section class="isec isec--alt" id="goods">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">STORE</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <p class="isec__lead reveal"><span class="nb">配信に使える自作の OBS ウィジェットなどを BOOTH で販売中。</span><wbr /><span class="nb">オリジナルグッズも順次追加していきます。</span></p>
        <div class="ispot reveal" data-spot>
          <a class="istore" href={site.links.booth} target="_blank" rel="me noopener" aria-label="BOOTHストアを見る">
            <Image class="istore__bg" src={keyVisual} widths={[480, 768, 1024, 1520]} sizes="(min-width: 760px) 760px, 100vw" alt="" loading="lazy" />
            <span class="istore__text"><span class="istore__en">OFFICIAL STORE</span><span class="istore__jp">和香松庵 STORE</span></span>
            <span class="istore__btn">BOOTH ▸</span>
          </a>
        </div>
      </div>
    </section>

    <section class="isec" id="follow">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">FOLLOW</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <p class="isec__lead reveal"><span class="nb">配信のお知らせや日常は各SNSで。</span><wbr /><span class="nb">フォロー・チャンネル登録で応援よろしくお願いします。</span></p>
        <div class="ifollow reveal">
          <a class="ifollow__card ifollow--yt" href={site.links.youtube} target="_blank" rel="me noopener"><span class="ifollow__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span><span class="ifollow__label">YouTube</span><span class="ifollow__sub">配信・アーカイブ</span></a>
          <a class="ifollow__card ifollow--x" href={site.links.x} target="_blank" rel="me noopener"><span class="ifollow__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></span><span class="ifollow__label">X (Twitter)</span><span class="ifollow__sub">お知らせ・日常</span></a>
          <a class="ifollow__card ifollow--ma" href={site.links.marshmallow} target="_blank" rel="me noopener"><span class="ifollow__icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg></span><span class="ifollow__label">マシュマロ</span><span class="ifollow__sub">匿名でメッセージ</span></a>
        </div>
      </div>
    </section>

    <section class="isec isec--alt" id="guideline">
      <div class="isec__inner">
        <div class="ihead reveal"><p class="ihead__kicker">GUIDELINE</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <div class="iguide reveal">
          <div class="iguide__block">
            <h3>切り抜き動画</h3>
            <ul><li>配信の切り抜きは原則OKです（元動画リンクを概要欄に記載）。</li><li>悪意ある編集・収益化はご遠慮ください。</li><li>ハッシュタグ：#庵のおかわり</li></ul>
          </div>
          <div class="iguide__block">
            <h3>二次創作・ファンアート</h3>
            <ul><li>イラスト・音楽・小説など基本的に大歓迎です。</li><li>R-18 / R-18G はワンクッションのご配慮を。</li><li>ハッシュタグ：#和香松庵 ／ #庵のお品書き</li></ul>
          </div>
          <div class="iguide__block">
            <h3>イラストのAI学習について</h3>
            <p>発信するイラストを AI の学習データとして利用することは固くお断りしています。</p>
          </div>
          <div class="iguide__block">
            <h3>判断に迷ったら</h3>
            <p>ここに書かれていないことで迷ったら、<a href={site.links.x} target="_blank" rel="me noopener">X</a> までお気軽にご連絡ください。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="isec" id="work">
      <div class="isec__inner isec__inner--narrow">
        <div class="ihead reveal"><p class="ihead__kicker">CONTACT</p><span class="ihead__rule" aria-hidden="true"></span></div>
        <p class="isec__lead reveal">コラボ・企業案件などのご相談を受け付けています。下記フォームよりお気軽にどうぞ。</p>
        <form class="iform reveal">
          <label class="iform__field"><span>お名前 / 会社名</span><input type="text" placeholder="例：〇〇株式会社 ご担当者様" /></label>
          <label class="iform__field"><span>メールアドレス</span><input type="email" placeholder="you@example.com" /></label>
          <label class="iform__field"><span>ご用件</span>
            <select><option>コラボのご相談</option><option>企業案件・PR</option><option>取材・出演</option><option>その他</option></select>
          </label>
          <label class="iform__field"><span>内容</span><textarea rows="5" placeholder="ご相談内容をご記入ください"></textarea></label>
          <button class="iform__send" type="button">送信する</button>
          <p class="iform__note">※これは見た目のプレビューです。送信の繋ぎ（メール / Discord 等）は後で決めます。</p>
        </form>
      </div>
    </section>

    <aside class="ed" id="ed" aria-label="プレビュー調整パネル">
      <button class="ed__handle" type="button" data-ed-toggle aria-expanded="true">⚙ 調整パネル（あなたが調整できます）</button>
      <div class="ed__body">
        <button class="ed__btn ed__edit" type="button" data-ed-edit aria-pressed="false">🖐 配置を動かす（ドラッグ＝移動 / ホイール＝拡縮）</button>
        <div class="ed__tones">
          <button class="ed__tone" type="button" data-tone="cream">明クリーム</button>
          <button class="ed__tone" type="button" data-tone="dark">黒×金</button>
        </div>
        <label class="ed__field">
          <span class="ed__lab">立ち絵の大きさ <b data-out="--art-scale">1.00</b></span>
          <input type="range" min="0.7" max="1.5" step="0.02" value="1" data-var="--art-scale" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">光のプール（立ち絵） <b data-out="--spotlight">0.40</b></span>
          <input type="range" min="0" max="1.6" step="0.05" value="0.4" data-var="--spotlight" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">全体のライト（上から） <b data-out="--arc-strength">0.90</b></span>
          <input type="range" min="0" max="1.4" step="0.05" value="0.9" data-var="--arc-strength" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">縁の暗さ（黒トーン） <b data-out="--vignette">0.20</b></span>
          <input type="range" min="0" max="0.85" step="0.05" value="0.2" data-var="--vignette" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">全体グロー <b data-out="--glow-strength">0.00</b></span>
          <input type="range" min="0" max="1.8" step="0.05" value="0" data-var="--glow-strength" />
        </label>
        <div class="ed__btns">
          <button class="ed__btn ed__btn--p" type="button" data-ed-copy>設定をコピー</button>
          <button class="ed__btn" type="button" data-ed-reset>リセット</button>
        </div>
        <p class="ed__msg" data-ed-msg aria-live="polite"></p>
      </div>
    </aside>

    <div class="iconband" aria-hidden="true">
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2" /><path d="M14 2v2" /><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1" /><path d="M6 2v2" /></svg></span>
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12 4.207 4.207A.707.707 0 0 1 4.707 3h14.586a.707.707 0 0 1 .5 1.207z" /><path d="M12 12v10" /><path d="M7 22h10" /></svg></span>
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" /></svg></span>
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719" /></svg></span>
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" /><path d="M20 2v4" /><path d="M22 4h-4" /><circle cx="4" cy="20" r="2" /></svg></span>
      <span class="iconband__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401" /></svg></span>
    </div>

    <footer class="ifoot">
      <p class="ifoot__brand">{site.name}</p>
      <p class="ifoot__en">Official Web Site — preview</p>
    </footer>

    <script is:inline>
      // ===== ロード画面（同一セッションでは1回だけ・RISE） =====
      // ロードが明けた瞬間にヒーロー入場（intro-go）を起動＝演出を裏で再生し終えない
      (function () {
        const html = document.documentElement;
        const goIntro = () => html.classList.add('intro-go');
        const load = document.getElementById('iload');
        if (!load) { goIntro(); return; }
        let seen = false;
        try { seen = !!sessionStorage.getItem('iori-loaded'); sessionStorage.setItem('iori-loaded', '1'); } catch (e) {}
        if (seen) {
          load.classList.add('is-done');
          goIntro();
        } else {
          const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduce) {
            setTimeout(() => { load.classList.add('is-done'); goIntro(); }, 200);
          } else {
            // ロード画面が薄れてから入場開始＝動きが画面で見えるようにする
            setTimeout(() => { load.classList.add('is-done'); setTimeout(goIntro, 450); }, 1900);
          }
        }
      })();

      // ===== 調整パネル（LPエディタ風・あなたが値を動かせる） =====
      const EDITOR_KEYS = ['--art-scale', '--spotlight', '--arc-strength', '--vignette', '--glow-strength'];
      const edRead = () => {
        try { return JSON.parse(localStorage.getItem('immersive-editor') || '{}'); } catch (e) { return {}; }
      };
      const edFmt = (v, unit) => (unit ? String(Math.round(parseFloat(v))) : parseFloat(v).toFixed(2));

      function setTone(tone) {
        const t = tone === 'dark' ? 'dark' : 'cream';
        document.documentElement.dataset.form = t;
        try { localStorage.setItem('immersive-form', t); } catch (e) {}
        document.querySelectorAll('[data-tone]').forEach((b) => b.classList.toggle('is-on', b.dataset.tone === t));
      }
      setTone(document.documentElement.dataset.form);
      document.querySelectorAll('[data-tone]').forEach((b) => b.addEventListener('click', () => setTone(b.dataset.tone)));
      // ナビ右上の切替ボタンはトーンを反転
      document.querySelector('[data-toggle]')?.addEventListener('click', () => {
        setTone(document.documentElement.dataset.form === 'dark' ? 'cream' : 'dark');
      });

      // スライダー → CSS変数（即反映＋localStorage保存）
      const edSaved = edRead();
      document.querySelectorAll('.ed__field input[type=range]').forEach((input) => {
        const key = input.dataset.var;
        const unit = input.dataset.unit || '';
        if (edSaved[key] != null) input.value = parseFloat(edSaved[key]);
        const out = document.querySelector(`[data-out="${key}"]`);
        const apply = () => {
          const val = input.value + unit;
          document.documentElement.style.setProperty(key, val);
          if (out) out.textContent = edFmt(input.value, unit);
          const cur = edRead();
          cur[key] = val;
          try { localStorage.setItem('immersive-editor', JSON.stringify(cur)); } catch (e) {}
        };
        if (out) out.textContent = edFmt(input.value, unit);
        input.addEventListener('input', apply);
      });

      // 開閉・コピー・リセット
      document.querySelector('[data-ed-toggle]')?.addEventListener('click', (e) => {
        const ed = document.getElementById('ed');
        const closed = ed.classList.toggle('is-closed');
        e.currentTarget.setAttribute('aria-expanded', String(!closed));
      });
      document.querySelector('[data-ed-copy]')?.addEventListener('click', () => {
        const cs = getComputedStyle(document.documentElement);
        const lines = EDITOR_KEYS.map((k) => `${k}: ${cs.getPropertyValue(k).trim()};`);
        lines.push('form: ' + document.documentElement.dataset.form);
        const lay = layRead();
        Object.keys(lay).forEach((k) => { const s = lay[k]; lines.push('[' + k + '] x:' + (s.x || 0) + ' y:' + (s.y || 0) + ' scale:' + (s.s || 1)); });
        const text = lines.join('\n');
        const msg = document.querySelector('[data-ed-msg]');
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(
            () => { if (msg) msg.textContent = 'コピーしました。私に貼ってください'; },
            () => { if (msg) msg.textContent = text; }
          );
        } else if (msg) { msg.textContent = text; }
      });
      document.querySelector('[data-ed-reset]')?.addEventListener('click', () => {
        try { localStorage.removeItem('immersive-editor'); localStorage.removeItem('immersive-layout'); } catch (e) {}
        location.reload();
      });

      // ===== 配置編集（ドラッグ移動／ホイール拡縮・保存） =====
      const LAYOUT_KEY = 'immersive-layout';
      const layRead = () => { try { return JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}'); } catch (e) { return {}; } };
      const laySave = (o) => { try { localStorage.setItem(LAYOUT_KEY, JSON.stringify(o)); } catch (e) {} };
      const layout = layRead();
      const editables = document.querySelectorAll('[data-edit]');
      const applyEl = (el, st) => {
        el.style.setProperty('--ex', (st.x || 0) + 'px');
        el.style.setProperty('--ey', (st.y || 0) + 'px');
        el.style.setProperty('--es', st.s || 1);
      };
      editables.forEach((el) => { const k = el.dataset.edit; if (layout[k]) applyEl(el, layout[k]); });

      let editing = false;
      const editBtn = document.querySelector('[data-ed-edit]');
      editBtn?.addEventListener('click', () => {
        editing = !editing;
        document.documentElement.classList.toggle('is-editing', editing);
        editBtn.classList.toggle('is-on', editing);
        editBtn.setAttribute('aria-pressed', String(editing));
      });

      let drag = null;
      editables.forEach((el) => {
        el.addEventListener('pointerdown', (e) => {
          if (!editing) return;
          e.preventDefault();
          const csd = getComputedStyle(el);
          const st = layout[el.dataset.edit] || {
            x: parseFloat(csd.getPropertyValue('--ex')) || 0,
            y: parseFloat(csd.getPropertyValue('--ey')) || 0,
            s: parseFloat(csd.getPropertyValue('--es')) || 1,
          };
          layout[el.dataset.edit] = st;
          drag = { el, sx: e.clientX, sy: e.clientY, ox: st.x || 0, oy: st.y || 0, st };
          el.classList.add('is-grab');
          try { el.setPointerCapture && el.setPointerCapture(e.pointerId); } catch (err) {}
        });
        el.addEventListener('pointermove', (e) => {
          if (!drag || drag.el !== el) return;
          drag.st.x = Math.round(drag.ox + (e.clientX - drag.sx));
          drag.st.y = Math.round(drag.oy + (e.clientY - drag.sy));
          applyEl(el, drag.st);
        });
        const endDrag = () => { if (drag && drag.el === el) { laySave(layout); el.classList.remove('is-grab'); drag = null; } };
        el.addEventListener('pointerup', endDrag);
        el.addEventListener('pointercancel', endDrag);
        el.addEventListener('wheel', (e) => {
          if (!editing) return;
          e.preventDefault();
          const csw = getComputedStyle(el);
          const st = layout[el.dataset.edit] || {
            x: parseFloat(csw.getPropertyValue('--ex')) || 0,
            y: parseFloat(csw.getPropertyValue('--ey')) || 0,
            s: parseFloat(csw.getPropertyValue('--es')) || 1,
          };
          st.s = Math.round(Math.min(2.6, Math.max(0.4, (st.s || 1) + (e.deltaY < 0 ? 0.04 : -0.04))) * 100) / 100;
          layout[el.dataset.edit] = st;
          applyEl(el, st);
          laySave(layout);
        }, { passive: false });
      });

      // スクロール登場（ブラー＋立ち上がり）
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // ナビのガラス濃度をスクロールで上げる
      const nav = document.querySelector('.inav');
      const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 40);
      onScroll();
      addEventListener('scroll', onScroll, { passive: true });

      // SpotlightBorder：カーソル追従の光る枠（ストアバナー等 [data-spot]）
      document.querySelectorAll('[data-spot]').forEach((wrap) => {
        wrap.addEventListener('pointermove', (e) => {
          const r = wrap.getBoundingClientRect();
          wrap.style.setProperty('--spot-x', e.clientX - r.left + 'px');
          wrap.style.setProperty('--spot-y', e.clientY - r.top + 'px');
        });
        wrap.addEventListener('pointerleave', () => {
          wrap.style.setProperty('--spot-x', '-9999px');
          wrap.style.setProperty('--spot-y', '-9999px');
        });
      });

      // YouTubeライブ中の検知 → ライブ中バッジを heroReveal で点灯（本番 /api/live と同契約）
      (function () {
        const badge = document.querySelector('.ilive');
        if (!badge) return;
        const titleEl = badge.querySelector('.ilive__title');
        const show = (url, title) => {
          if (url) badge.href = url;
          if (titleEl) titleEl.textContent = title || ''; // 外部由来タイトルは textContent で挿入＝XSS回避
          badge.hidden = false;
          badge.classList.add('is-live');
        };
        // プレビュー確認用：?live=1 で強制点灯（本番では /api/live の判定で表示）
        if (new URLSearchParams(location.search).get('live') === '1') {
          show(badge.href, '【プレビュー】ただいま配信中！まったり雑談しています');
          return;
        }
        fetch('/api/live', { headers: { accept: 'application/json' } })
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            const live = d && d.isLive === true && d.liveVideo && typeof d.liveVideo.url === 'string' ? d.liveVideo : null;
            if (live) show(live.url, live.title);
          })
          .catch(() => {});
      })();

      // ハンバーガーメニュー（スマホ）：開閉・リンクで閉じる・外側/Escで閉じる
      (function () {
        const nav = document.querySelector('.inav');
        const burger = nav && nav.querySelector('.inav__burger');
        const links = nav && nav.querySelector('.inav__links');
        if (!nav || !burger || !links) return;
        const setOpen = (open) => {
          nav.classList.toggle('nav-open', open);
          burger.setAttribute('aria-expanded', open ? 'true' : 'false');
        };
        burger.addEventListener('click', (e) => { e.stopPropagation(); setOpen(!nav.classList.contains('nav-open')); });
        links.addEventListener('click', (e) => { if (e.target.closest('a')) setOpen(false); });
        document.addEventListener('click', (e) => { if (nav.classList.contains('nav-open') && !nav.contains(e.target)) setOpen(false); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
      })();

    </script>
  </body>
</html>

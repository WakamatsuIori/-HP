---
/**
 * 【プレビュー専用・noindex・使い捨て】没入シネマ×グロー の形を 2トーンで見比べるためのモック。
 * 本番トップ(index.astro)・静/動ブランチには影響しない独立ルート。
 * ?form=cream（明クリーム×金・世界観キープ） / ?form=dark（黒×金・耽美の新トーン）で切替。
 * 採用が決まったら本実装へ昇格し、このファイルと配線は削除する。
 */
import { Image } from 'astro:assets';
import { site } from '../config/site';
import { loadSchedule } from '../lib/loadSchedule';
import { groupByJstDay, jstTime } from '../lib/schedule';
import keyVisual from '../assets/IMG_5833.png';
import standArt from '../assets/Wakamatsu_full_size.png';
import barArt from '../assets/wakamatsusan_.png';
import { intro, profile } from '../config/profile';

const events = await loadSchedule();
const days = groupByJstDay(events).slice(0, 4);

const nav = ['プロフィール', 'スケジュール', '動画', 'ストア', 'お仕事依頼'];
---

<!doctype html>
<html lang="ja" data-form="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>没入プレビュー | {site.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Marcellus&family=Shippori+Mincho:wght@500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Zen+Old+Mincho:wght@600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // ?form=dark で黒×金トーン（既定=cream）。エディタの保存値(localStorage)も先読みして
      // 描画前に反映（チラつき防止）。使い捨ての調整用配線。
      (function () {
        try {
          var q = new URLSearchParams(location.search).get('form');
          var f = q || localStorage.getItem('immersive-form') || 'dark';
          document.documentElement.dataset.form = f === 'dark' ? 'dark' : 'cream';
          var saved = JSON.parse(localStorage.getItem('immersive-editor') || '{}');
          for (var k in saved) document.documentElement.style.setProperty(k, saved[k]);
        } catch (e) {
          document.documentElement.dataset.form = 'cream';
        }
      })();
    </script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --serif: 'Shippori Mincho', 'Zen Old Mincho', 'Hiragino Mincho ProN', 'Yu Mincho', serif;
        --logo: 'Cinzel', 'Marcellus', serif;
        --gothic: 'Zen Kaku Gothic New', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', system-ui, sans-serif;
        /* ▼ 調整パネルのスライダーで動かす値（既定）。localStorage に保存される。 */
        --art-scale: 1;
        --spotlight: 0.3;
        --cursor-size: 170px;
        --vignette: 0.25;
        --glow-strength: 0.85;
      }

      /* ===== トーン①：明クリーム×金（世界観キープ） ===== */
      html[data-form='cream'] {
        --bg: #faf9f6;
        --bg-2: #f3efe6;
        --ink: #3a352d;
        --ink-soft: rgba(58, 53, 45, 0.82);
        --muted: #6e6855;
        --gold: #9c8f6b;
        --gold-strong: #6f6444;
        --gold-bright: #c9a86a;
        --glow: rgba(201, 168, 105, 0.42);
        --glow-2: rgba(232, 207, 149, 0.5);
        --nav-bg: rgba(250, 249, 246, 0.62);
        --nav-line: rgba(156, 143, 107, 0.34);
        --card-bg: rgba(255, 255, 255, 0.55);
        --card-line: rgba(156, 143, 107, 0.28);
        --scrim: linear-gradient(
            to top,
            rgba(250, 249, 246, 0.97) 0%,
            rgba(250, 249, 246, 0.8) 28%,
            rgba(250, 249, 246, 0.34) 54%,
            rgba(250, 249, 246, 0) 80%
          ),
          linear-gradient(to right, rgba(250, 249, 246, 0.9) 0%, rgba(250, 249, 246, 0.3) 46%, rgba(250, 249, 246, 0) 70%);
        --blend: screen;
      }
      /* ===== トーン②：黒×金・耽美（新トーン） ===== */
      html[data-form='dark'] {
        --bg: #14100b;
        --bg-2: #1b140d;
        --ink: #f3e7cf;
        --ink-soft: rgba(243, 231, 207, 0.86);
        --muted: #b8a888;
        --gold: #c9a86a;
        --gold-strong: #e8cf95;
        --gold-bright: #f0d99a;
        --glow: rgba(232, 207, 149, 0.4);
        --glow-2: rgba(201, 168, 105, 0.5);
        --nav-bg: rgba(18, 13, 8, 0.5);
        --nav-line: rgba(201, 168, 105, 0.3);
        --card-bg: rgba(40, 30, 19, 0.5);
        --card-line: rgba(201, 168, 105, 0.26);
        --scrim: linear-gradient(
            to top,
            rgba(12, 9, 6, 0.95) 0%,
            rgba(12, 9, 6, 0.78) 30%,
            rgba(12, 9, 6, 0.34) 56%,
            rgba(12, 9, 6, 0) 82%
          ),
          linear-gradient(to right, rgba(12, 9, 6, 0.85) 0%, rgba(12, 9, 6, 0.3) 48%, rgba(12, 9, 6, 0) 72%);
        --blend: screen;
      }

      html { overflow-x: clip; scroll-behavior: smooth; color-scheme: light; }
      body { background: var(--bg); color: var(--ink); font-family: var(--gothic); line-height: 1.8; }

      /* ===== ガラス質ナビ ===== */
      .inav {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 60;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.85rem clamp(1rem, 4vw, 2.6rem);
        background: var(--nav-bg);
        -webkit-backdrop-filter: blur(16px) saturate(1.25);
        backdrop-filter: blur(16px) saturate(1.25);
        border-bottom: 1px solid var(--nav-line);
        transition: background 0.3s ease, border-color 0.3s ease;
      }
      .inav__brand {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
      }
      .inav__brand .en {
        font-family: var(--logo);
        font-size: 0.6rem;
        letter-spacing: 0.42em;
        color: var(--gold-strong);
        text-transform: uppercase;
      }
      .inav__brand .jp {
        font-family: var(--serif);
        font-size: 1.16rem;
        letter-spacing: 0.26em;
        color: var(--ink);
        font-weight: 600;
      }
      .inav__links {
        display: flex;
        gap: clamp(0.8rem, 2vw, 1.7rem);
        align-items: center;
      }
      .inav__links a {
        font-family: var(--serif);
        font-size: 0.92rem;
        letter-spacing: 0.08em;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .inav__links a:hover { color: var(--gold-strong); }
      .inav__toggle {
        font-family: var(--gothic);
        font-size: 0.76rem;
        letter-spacing: 0.06em;
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--nav-line);
        border-radius: 999px;
        padding: 0.34rem 0.85rem;
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.2s ease, color 0.2s ease;
      }
      .inav__toggle:hover { border-color: var(--gold); color: var(--gold-strong); }
      @media (max-width: 720px) {
        .inav__links a { display: none; }
      }

      /* ===== 没入ヒーロー ===== */
      .ihero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: flex-end;
        overflow: hidden;
        isolation: isolate;
        background: var(--bg);
      }
      .ihero__kv {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 54% 16%;
        z-index: 0;
        transform-origin: 54% 16%;
      }
      @media (prefers-reduced-motion: no-preference) {
        .ihero__kv { animation: kvZoom 24s ease-in-out infinite alternate; }
      }
      @keyframes kvZoom { from { transform: scale(1); } to { transform: scale(1.07); } }
      .ihero__scrim { position: absolute; inset: 0; z-index: 1; background: var(--scrim); }
      .ihero__glow {
        position: absolute;
        inset: -10%;
        z-index: 1;
        pointer-events: none;
        mix-blend-mode: var(--blend);
        opacity: var(--glow-strength);
        background:
          radial-gradient(38% 46% at 50% 38%, var(--glow-2), transparent 66%),
          radial-gradient(40% 50% at 80% 24%, var(--glow), transparent 64%);
      }
      @media (prefers-reduced-motion: no-preference) {
        .ihero__glow { animation: glowDrift 18s ease-in-out infinite alternate; }
      }
      @keyframes glowDrift {
        from { transform: translate3d(0, 0, 0) scale(1); }
        to { transform: translate3d(2%, -1.6%, 0) scale(1.08); }
      }
      .ihero__content {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: clamp(2rem, 8vw, 6rem) clamp(1.3rem, 5vw, 4rem) clamp(3rem, 9vw, 6.5rem);
      }
      .ihero__inner { max-width: 50rem; }
      .ihero__kicker {
        font-family: var(--gothic);
        font-size: 0.84rem;
        letter-spacing: 0.34em;
        color: var(--gold-strong);
        margin-bottom: 1.1rem;
      }
      .ihero__name {
        font-family: var(--serif);
        font-weight: 600;
        font-size: clamp(3rem, 11vw, 6.4rem);
        letter-spacing: 0.1em;
        line-height: 1.04;
        color: var(--ink);
      }
      .ihero__romaji {
        font-family: var(--logo);
        font-size: clamp(0.8rem, 2.4vw, 1.05rem);
        letter-spacing: 0.42em;
        color: var(--muted);
        margin: 0.7rem 0 1.5rem;
      }
      .ihero__tag {
        font-size: clamp(1.02rem, 2.6vw, 1.3rem);
        line-height: 1.95;
        color: var(--ink-soft);
        margin-bottom: 2rem;
      }
      .ihero__cta { display: flex; flex-wrap: wrap; gap: 0.8rem; }
      .ibtn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.85rem 1.8rem;
        border-radius: 999px;
        font-size: 0.98rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.18s ease, background 0.2s ease, border-color 0.2s ease;
      }
      .ibtn--solid { background: var(--gold-strong); color: var(--bg); border: 1px solid var(--gold-strong); }
      .ibtn--solid:hover { transform: translateY(-2px); }
      .ibtn--ghost { background: transparent; color: var(--gold-strong); border: 1px solid var(--gold); }
      .ibtn--ghost:hover { transform: translateY(-2px); border-color: var(--gold-strong); }
      .ihero__scrollcue {
        position: absolute;
        left: 50%;
        bottom: 1.2rem;
        z-index: 2;
        transform: translateX(-50%);
        font-family: var(--logo);
        font-size: 0.62rem;
        letter-spacing: 0.36em;
        color: var(--muted);
        text-transform: uppercase;
      }

      /* ===== カーソル光（PCのみ・JSで座標更新） ===== */
      .cursorglow {
        position: fixed;
        top: 0;
        left: 0;
        width: var(--cursor-size);
        height: var(--cursor-size);
        border-radius: 50%;
        pointer-events: none;
        z-index: 4;
        opacity: 0;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, var(--glow-2), transparent 62%);
        mix-blend-mode: var(--blend);
        transition: opacity 0.4s ease;
        will-change: transform;
      }

      /* ===== 没入セクション（スケジュール） ===== */
      .isec {
        position: relative;
        padding: clamp(3.5rem, 9vw, 7rem) clamp(1.3rem, 5vw, 4rem);
        background: var(--bg);
        overflow: clip;
      }
      .isec::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(36% 44% at 16% 24%, var(--glow), transparent 62%),
          radial-gradient(40% 50% at 86% 78%, var(--glow), transparent 64%);
        opacity: calc(0.5 * var(--glow-strength));
      }
      .isec__inner { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; }
      .ihead { text-align: center; margin-bottom: clamp(1.8rem, 4vw, 3rem); }
      .ihead__kicker {
        font-family: var(--logo);
        font-size: clamp(2.2rem, 7vw, 3.8rem);
        font-weight: 500;
        letter-spacing: 0.1em;
        color: var(--gold);
        opacity: 0.85;
        line-height: 1;
      }
      .ihead__title {
        font-family: var(--serif);
        font-size: clamp(1.15rem, 3vw, 1.5rem);
        letter-spacing: 0.14em;
        color: var(--ink);
        margin-top: 0.4rem;
      }
      .ihead__rule {
        display: block;
        width: 3.4rem;
        height: 1px;
        margin: 1rem auto 0;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
      }
      .icards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.1rem;
        margin-top: 2rem;
      }
      .icard {
        position: relative;
        border-radius: 16px;
        padding: 1.3rem 1.4rem;
        background: var(--card-bg);
        border: 1px solid var(--card-line);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.34);
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
        overflow: hidden;
      }
      .icard__day {
        font-family: var(--serif);
        font-size: 1.05rem;
        letter-spacing: 0.1em;
        color: var(--gold-strong);
        margin-bottom: 0.7rem;
        padding-bottom: 0.55rem;
        border-bottom: 1px solid var(--card-line);
      }
      .icard__row { display: flex; gap: 0.7rem; align-items: baseline; padding: 0.3rem 0; }
      .icard__time { font-variant-numeric: tabular-nums; font-weight: 600; color: var(--gold-strong); flex-shrink: 0; }
      .icard__title { color: var(--ink-soft); font-size: 0.98rem; }
      .icard__off { color: var(--muted); font-size: 0.95rem; }
      .isec__note { text-align: center; margin-top: 1.6rem; font-size: 0.86rem; color: var(--muted); }

      /* ===== フッター（薄く） ===== */
      .ifoot {
        text-align: center;
        padding: 2.6rem 1rem 3.2rem;
        background: var(--bg-2);
        border-top: 1px solid var(--nav-line);
      }
      .ifoot__brand { font-family: var(--serif); font-size: 1.4rem; letter-spacing: 0.3em; color: var(--ink); }
      .ifoot__en { font-family: var(--logo); font-size: 0.6rem; letter-spacing: 0.4em; color: var(--muted); text-transform: uppercase; margin-top: 0.4rem; }

      /* ===== 登場演出（ブラー＋立ち上がり） ===== */
      .reveal { opacity: 0; transform: translateY(30px); filter: blur(10px); transition: opacity 0.85s ease, transform 0.85s cubic-bezier(0.2, 0.7, 0.2, 1), filter 0.85s ease; }
      .reveal.is-visible { opacity: 1; transform: none; filter: none; }
      .intro > * { opacity: 0; transform: translateY(22px); filter: blur(8px); animation: introRise 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
      .intro > :nth-child(2) { animation-delay: 0.12s; }
      .intro > :nth-child(3) { animation-delay: 0.22s; }
      .intro > :nth-child(4) { animation-delay: 0.34s; }
      .intro > :nth-child(5) { animation-delay: 0.46s; }
      @keyframes introRise { to { opacity: 1; transform: none; filter: none; } }

      /* ===== PROFILE ===== */
      .isec--alt { background: var(--bg-2); }
      .iprofile { display: flex; flex-direction: column; align-items: center; gap: 1.6rem; }
      .iprofile__art { width: calc(min(70%, 360px) * var(--art-scale)); }
      .iprofile__art :global(img) { width: 100%; height: auto; }
      .iprofile__body { width: 100%; max-width: 36rem; }
      .iprofile__list { margin: 0 0 1.2rem; }
      .iprofile__row {
        display: grid;
        grid-template-columns: 6.6rem 1fr;
        align-items: baseline;
        gap: 0.3rem 1.1rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--card-line);
      }
      .iprofile__row dt { position: relative; margin: 0; padding-left: 1.15rem; color: var(--muted); font-size: 0.82rem; letter-spacing: 0.08em; white-space: nowrap; }
      .iprofile__row dt::before { content: '◆'; position: absolute; left: 0; top: 0.2em; color: var(--gold); font-size: 0.52rem; }
      .iprofile__row dd { margin: 0; color: var(--ink); font-size: 1.04rem; line-height: 1.5; }
      .iprofile__chips { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; }
      .iprofile__chips li {
        padding: 0.4rem 1.2rem;
        border: 1px solid var(--gold);
        border-radius: 999px;
        color: var(--gold-strong);
        font-size: 0.92rem;
        background: var(--card-bg);
      }
      @media (min-width: 860px) {
        .iprofile { flex-direction: row; align-items: flex-start; gap: 3rem; max-width: 1080px; margin: 0 auto; }
        .iprofile__art { flex-shrink: 0; width: calc(min(48%, 462px) * var(--art-scale)); }
        .iprofile__body { flex: 1 1 0; min-width: 0; max-width: 30rem; margin-top: 1rem; }
      }

      /* ===== ABOUT（ごあいさつ） ===== */
      .iabout { display: flex; flex-direction: column; align-items: center; gap: 1.6rem; text-align: center; }
      .iabout__art { width: calc(min(76%, 360px) * var(--art-scale)); }
      .iabout__art :global(img) {
        width: 100%;
        height: auto;
        -webkit-mask-image: linear-gradient(to bottom, #000 84%, transparent 100%);
        mask-image: linear-gradient(to bottom, #000 84%, transparent 100%);
      }
      .iabout__catch { font-family: var(--serif); font-weight: 700; font-size: clamp(1.7rem, 4.6vw, 2.6rem); line-height: 1.42; color: var(--gold-strong); margin: 0 0 0.4rem; }
      .iabout__en { font-style: italic; font-size: clamp(0.82rem, 2.2vw, 1rem); color: var(--muted); margin: 0 0 1rem; }
      .iabout__rule { display: block; width: 3.2rem; height: 1px; margin: 0 auto 1.2rem; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
      .iabout__story { text-align: left; max-width: 34rem; margin: 0 auto; }
      .iabout__story p { margin: 0 0 0.9rem; font-size: 1rem; line-height: 2; color: var(--ink-soft); }
      .iabout__story p:last-child { margin-bottom: 0; }
      @media (min-width: 860px) {
        .iabout { flex-direction: row; align-items: center; gap: 3rem; text-align: left; max-width: 1040px; margin: 0 auto; }
        .iabout__body { flex: 1 1 0; min-width: 0; }
        .iabout__art { flex-shrink: 0; width: calc(min(50%, 470px) * var(--art-scale)); }
        .iabout__rule { margin-left: 0; margin-right: auto; }
        .iabout__story { max-width: none; }
      }

      /* ===== 奥行き演出（黒地に光のプール／立ち絵の浮かび上がり） ===== */
      .iprofile__art, .iabout__art { position: relative; }
      .iprofile__art::before, .iabout__art::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 48%;
        width: 122%;
        height: 96%;
        transform: translate(-50%, -50%);
        z-index: 0;
        pointer-events: none;
        background: radial-gradient(50% 50% at 50% 50%, var(--glow-2), transparent 68%);
        opacity: var(--spotlight);
      }
      .iprofile__art :global(img), .iabout__art :global(img) { position: relative; z-index: 1; }
      .iprofile__art :global(img) { filter: drop-shadow(0 26px 44px rgba(0, 0, 0, 0.55)); }
      @media (prefers-reduced-motion: no-preference) {
        .iprofile__art :global(img), .iabout__art :global(img) { animation: artFloat 7.5s ease-in-out infinite alternate; }
      }
      @keyframes artFloat { from { transform: translateY(2px); } to { transform: translateY(-10px); } }
      /* 黒トーン：帯と画面の縁を落として中央に視線を集める（奥行き） */
      html[data-form='dark'] .isec { box-shadow: inset 0 0 160px 30px rgba(0, 0, 0, 0.45); }
      html[data-form='dark'] .ihero::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        box-shadow: inset 0 0 220px 60px rgba(0, 0, 0, 0.5);
      }

      /* ===== モバイル軽量化 ===== */
      @media (max-width: 640px) {
        .ihero__glow { display: none; }
        .cursorglow { display: none; }
        .isec::before { opacity: 0.32; }
        .icard { -webkit-backdrop-filter: none; backdrop-filter: none; }
      }
      /* ===== 動きが苦手な設定：静止 ===== */
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; filter: none; transition: none; }
        .intro > * { opacity: 1; transform: none; filter: none; animation: none; }
        .ihero__kv, .ihero__glow { animation: none; }
        .cursorglow { display: none; }
        html { scroll-behavior: auto; }
      }
      /* ===== 調整パネル（プレビュー専用・LPエディタ風・使い捨て） ===== */
      .ed {
        position: fixed;
        right: 14px;
        bottom: 14px;
        z-index: 90;
        width: 272px;
        max-width: calc(100vw - 28px);
        font-family: var(--gothic);
        color: #f3ecdd;
        background: rgba(18, 14, 9, 0.93);
        border: 1px solid rgba(201, 168, 105, 0.42);
        border-radius: 12px;
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        box-shadow: 0 16px 44px rgba(0, 0, 0, 0.5);
        overflow: hidden;
      }
      .ed__handle {
        width: 100%;
        text-align: left;
        font: inherit;
        font-size: 0.84rem;
        letter-spacing: 0.04em;
        color: #e8cf95;
        background: rgba(201, 168, 105, 0.14);
        border: none;
        border-bottom: 1px solid rgba(201, 168, 105, 0.28);
        padding: 0.6rem 0.85rem;
        cursor: pointer;
      }
      .ed__body { padding: 0.7rem 0.85rem 0.85rem; display: grid; gap: 0.62rem; }
      .ed.is-closed .ed__body { display: none; }
      .ed__tones { display: flex; gap: 0.4rem; }
      .ed__tone {
        flex: 1;
        font: inherit;
        font-size: 0.78rem;
        color: #d8c7a0;
        background: transparent;
        border: 1px solid rgba(201, 168, 105, 0.4);
        border-radius: 7px;
        padding: 0.34rem;
        cursor: pointer;
      }
      .ed__tone.is-on { background: rgba(201, 168, 105, 0.3); color: #fff8ec; }
      .ed__field { display: grid; gap: 0.22rem; }
      .ed__lab { font-size: 0.75rem; color: #d8c7a0; display: flex; justify-content: space-between; align-items: baseline; }
      .ed__lab b { color: #e8cf95; font-weight: 600; }
      .ed__u { color: #9c8f6b; }
      .ed__field input[type='range'] { width: 100%; accent-color: #c9a86a; cursor: pointer; }
      .ed__btns { display: flex; gap: 0.4rem; margin-top: 0.15rem; }
      .ed__btn {
        flex: 1;
        font: inherit;
        font-size: 0.78rem;
        color: #d8c7a0;
        background: transparent;
        border: 1px solid rgba(201, 168, 105, 0.4);
        border-radius: 7px;
        padding: 0.42rem;
        cursor: pointer;
      }
      .ed__btn--p { color: #14100b; background: #cda14e; border-color: #cda14e; font-weight: 600; }
      .ed__msg { font-size: 0.72rem; color: #9bc77f; min-height: 1em; margin: 0; word-break: break-word; }
      @media (max-width: 640px) { .ed { width: 210px; right: 8px; bottom: 8px; } }

      /* 配置編集：ドラッグで移動・ホイールで拡縮（保存され通常表示にも反映） */
      [data-edit] { transform: translate(var(--ex, 0px), var(--ey, 0px)) scale(var(--es, 1)); }
      /* ▼ 本人が調整した配置を既定に焼き込み（デスクトップのみ。モバイルは縦並びのため無補正） */
      @media (min-width: 860px) {
        [data-edit='hero'] { --ex: -157px; --ey: -46px; --es: 1.04; }
        [data-edit='art-prof'] { --ex: -156px; --ey: -75px; --es: 1.24; }
        [data-edit='txt-prof'] { --ex: 6px; --ey: 107px; --es: 1.48; }
        [data-edit='txt-about'] { --ex: -89px; --ey: -50px; --es: 1.36; }
        [data-edit='art-about'] { --es: 1.04; }
      }
      html.is-editing [data-edit] { outline: 1px dashed rgba(201, 168, 105, 0.6); outline-offset: 5px; cursor: grab; }
      html.is-editing [data-edit]:hover { outline-color: #e8cf95; }
      html.is-editing [data-edit].is-grab { cursor: grabbing; }
      .ed__edit { width: 100%; }
      .ed__edit.is-on { background: #cda14e; color: #14100b; border-color: #cda14e; font-weight: 600; }
    </style>
  </head>
  <body>
    <span class="cursorglow" aria-hidden="true"></span>

    <header class="inav">
      <a href="#top" class="inav__brand" style="text-decoration:none">
        <span class="en">Cafe &amp; Bar</span>
        <span class="jp">{site.name}</span>
      </a>
      <nav class="inav__links">
        {nav.map((n) => <a href="#">{n}</a>)}
      </nav>
      <button class="inav__toggle" type="button" data-toggle>トーン切替（明⇄黒金）</button>
    </header>

    <section class="ihero" id="top">
      <Image
        class="ihero__kv"
        src={keyVisual}
        widths={[768, 1280, 1920]}
        sizes="100vw"
        alt={`${site.name}のキービジュアル`}
        loading="eager"
        fetchpriority="high"
      />
      <div class="ihero__scrim" aria-hidden="true"></div>
      <div class="ihero__glow" aria-hidden="true"></div>
      <div class="ihero__content">
        <div class="ihero__inner intro" data-edit="hero">
          <p class="ihero__kicker">Cafe &amp; Bar の店長 ・ 個人勢VTuber</p>
          <h1 class="ihero__name">{site.name}</h1>
          <p class="ihero__romaji">WAKAMATSU IORI</p>
          <p class="ihero__tag">雑談とゲームを肴に、ゆるりと楽しい夜を。<br />ようこそ、隠れ家カフェ＆バーへ。</p>
          <div class="ihero__cta">
            <a class="ibtn ibtn--solid" href="#schedule">今夜の品書きを見る</a>
            <a class="ibtn ibtn--ghost" href={site.links.youtube} rel="me noopener" target="_blank">YouTubeへ</a>
          </div>
        </div>
      </div>
      <span class="ihero__scrollcue" aria-hidden="true">scroll</span>
    </section>

    <section class="isec isec--alt" id="profile">
      <div class="isec__inner">
        <div class="ihead reveal">
          <p class="ihead__kicker">PROFILE</p>
          <span class="ihead__rule" aria-hidden="true"></span>
        </div>
        <div class="iprofile reveal">
          <div class="iprofile__art" data-edit="art-prof">
            <Image
              src={standArt}
              widths={[360, 540, 760]}
              sizes="(min-width: 860px) 420px, 70vw"
              alt={`${site.name}の立ち絵`}
              loading="lazy"
            />
          </div>
          <div class="iprofile__body" data-edit="txt-prof">
            <dl class="iprofile__list">
              {profile.rows.map((row) => (
                <div class="iprofile__row">
                  <dt>{row.label}</dt>
                  <dd>{row.value}</dd>
                </div>
              ))}
            </dl>
            <ul class="iprofile__chips">
              {profile.chips.map((chip) => <li>{chip}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="isec" id="about">
      <div class="isec__inner">
        <div class="iabout reveal">
          <div class="iabout__body" data-edit="txt-about">
            <h2 class="iabout__catch">{intro.catchLines.map((line, i) => (<>{i > 0 && <br />}{line}</>))}</h2>
            <p class="iabout__en">{intro.catchEn}</p>
            <span class="iabout__rule" aria-hidden="true"></span>
            <div class="iabout__story">
              {intro.story.map((para) => <p>{para}</p>)}
            </div>
          </div>
          <div class="iabout__art" data-edit="art-about">
            <Image
              src={barArt}
              widths={[360, 540, 760]}
              sizes="(min-width: 860px) 440px, 76vw"
              alt={`${site.name}の立ち絵（カクテルをお届け）`}
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="isec" id="schedule">
      <div class="isec__inner">
        <div class="ihead reveal">
          <p class="ihead__kicker">SCHEDULE</p>
          <p class="ihead__title">今週の品書き</p>
          <span class="ihead__rule" aria-hidden="true"></span>
        </div>
        {
          days.length === 0 ? (
            <p class="isec__note reveal">直近の配信予定はまだありません。</p>
          ) : (
            <div class="icards reveal">
              {days.map((day) => (
                <article class="icard">
                  <p class="icard__day">{day.label}</p>
                  {day.events.length === 0 ? (
                    <p class="icard__off">— 休業 —</p>
                  ) : (
                    day.events.map((ev) => (
                      <div class="icard__row">
                        <span class="icard__time">{jstTime(ev.start)}</span>
                        <span class="icard__title">{ev.title}</span>
                      </div>
                    ))
                  )}
                </article>
              ))}
            </div>
          )
        }
        <p class="isec__note reveal">※これは「没入シネマ×グロー」の形を見るためのプレビューです（{site.name}）。</p>
      </div>
    </section>

    <aside class="ed" id="ed" aria-label="プレビュー調整パネル">
      <button class="ed__handle" type="button" data-ed-toggle aria-expanded="true">⚙ 調整パネル（あなたが調整できます）</button>
      <div class="ed__body">
        <button class="ed__btn ed__edit" type="button" data-ed-edit aria-pressed="false">🖐 配置を動かす（ドラッグ＝移動 / ホイール＝拡縮）</button>
        <div class="ed__tones">
          <button class="ed__tone" type="button" data-tone="cream">明クリーム</button>
          <button class="ed__tone" type="button" data-tone="dark">黒×金</button>
        </div>
        <label class="ed__field">
          <span class="ed__lab">立ち絵の大きさ <b data-out="--art-scale">1.00</b></span>
          <input type="range" min="0.7" max="1.5" step="0.02" value="1" data-var="--art-scale" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">光のプール（立ち絵） <b data-out="--spotlight">0.30</b></span>
          <input type="range" min="0" max="1.6" step="0.05" value="0.3" data-var="--spotlight" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">カーソルの光 <b data-out="--cursor-size">170</b><span class="ed__u">px</span></span>
          <input type="range" min="120" max="520" step="10" value="170" data-var="--cursor-size" data-unit="px" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">縁の暗さ（黒トーン） <b data-out="--vignette">0.25</b></span>
          <input type="range" min="0" max="0.85" step="0.05" value="0.25" data-var="--vignette" />
        </label>
        <label class="ed__field">
          <span class="ed__lab">全体グロー <b data-out="--glow-strength">0.85</b></span>
          <input type="range" min="0" max="1.8" step="0.05" value="0.85" data-var="--glow-strength" />
        </label>
        <div class="ed__btns">
          <button class="ed__btn ed__btn--p" type="button" data-ed-copy>設定をコピー</button>
          <button class="ed__btn" type="button" data-ed-reset>リセット</button>
        </div>
        <p class="ed__msg" data-ed-msg aria-live="polite"></p>
      </div>
    </aside>

    <footer class="ifoot">
      <p class="ifoot__brand">{site.name}</p>
      <p class="ifoot__en">Official Web Site — preview</p>
    </footer>

    <script is:inline>
      // ===== 調整パネル（LPエディタ風・あなたが値を動かせる） =====
      const EDITOR_KEYS = ['--art-scale', '--spotlight', '--cursor-size', '--vignette', '--glow-strength'];
      const edRead = () => {
        try { return JSON.parse(localStorage.getItem('immersive-editor') || '{}'); } catch (e) { return {}; }
      };
      const edFmt = (v, unit) => (unit ? String(Math.round(parseFloat(v))) : parseFloat(v).toFixed(2));

      function setTone(tone) {
        const t = tone === 'dark' ? 'dark' : 'cream';
        document.documentElement.dataset.form = t;
        try { localStorage.setItem('immersive-form', t); } catch (e) {}
        document.querySelectorAll('[data-tone]').forEach((b) => b.classList.toggle('is-on', b.dataset.tone === t));
      }
      setTone(document.documentElement.dataset.form);
      document.querySelectorAll('[data-tone]').forEach((b) => b.addEventListener('click', () => setTone(b.dataset.tone)));
      // ナビ右上の切替ボタンはトーンを反転
      document.querySelector('[data-toggle]')?.addEventListener('click', () => {
        setTone(document.documentElement.dataset.form === 'dark' ? 'cream' : 'dark');
      });

      // スライダー → CSS変数（即反映＋localStorage保存）
      const edSaved = edRead();
      document.querySelectorAll('.ed__field input[type=range]').forEach((input) => {
        const key = input.dataset.var;
        const unit = input.dataset.unit || '';
        if (edSaved[key] != null) input.value = parseFloat(edSaved[key]);
        const out = document.querySelector(`[data-out="${key}"]`);
        const apply = () => {
          const val = input.value + unit;
          document.documentElement.style.setProperty(key, val);
          if (out) out.textContent = edFmt(input.value, unit);
          const cur = edRead();
          cur[key] = val;
          try { localStorage.setItem('immersive-editor', JSON.stringify(cur)); } catch (e) {}
        };
        if (out) out.textContent = edFmt(input.value, unit);
        input.addEventListener('input', apply);
      });

      // 開閉・コピー・リセット
      document.querySelector('[data-ed-toggle]')?.addEventListener('click', (e) => {
        const ed = document.getElementById('ed');
        const closed = ed.classList.toggle('is-closed');
        e.currentTarget.setAttribute('aria-expanded', String(!closed));
      });
      document.querySelector('[data-ed-copy]')?.addEventListener('click', () => {
        const cs = getComputedStyle(document.documentElement);
        const lines = EDITOR_KEYS.map((k) => `${k}: ${cs.getPropertyValue(k).trim()};`);
        lines.push('form: ' + document.documentElement.dataset.form);
        const lay = layRead();
        Object.keys(lay).forEach((k) => { const s = lay[k]; lines.push('[' + k + '] x:' + (s.x || 0) + ' y:' + (s.y || 0) + ' scale:' + (s.s || 1)); });
        const text = lines.join('\n');
        const msg = document.querySelector('[data-ed-msg]');
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(
            () => { if (msg) msg.textContent = 'コピーしました。私に貼ってください'; },
            () => { if (msg) msg.textContent = text; }
          );
        } else if (msg) { msg.textContent = text; }
      });
      document.querySelector('[data-ed-reset]')?.addEventListener('click', () => {
        try { localStorage.removeItem('immersive-editor'); localStorage.removeItem('immersive-layout'); } catch (e) {}
        location.reload();
      });

      // ===== 配置編集（ドラッグ移動／ホイール拡縮・保存） =====
      const LAYOUT_KEY = 'immersive-layout';
      const layRead = () => { try { return JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}'); } catch (e) { return {}; } };
      const laySave = (o) => { try { localStorage.setItem(LAYOUT_KEY, JSON.stringify(o)); } catch (e) {} };
      const layout = layRead();
      const editables = document.querySelectorAll('[data-edit]');
      const applyEl = (el, st) => {
        el.style.setProperty('--ex', (st.x || 0) + 'px');
        el.style.setProperty('--ey', (st.y || 0) + 'px');
        el.style.setProperty('--es', st.s || 1);
      };
      editables.forEach((el) => { const k = el.dataset.edit; if (layout[k]) applyEl(el, layout[k]); });

      let editing = false;
      const editBtn = document.querySelector('[data-ed-edit]');
      editBtn?.addEventListener('click', () => {
        editing = !editing;
        document.documentElement.classList.toggle('is-editing', editing);
        editBtn.classList.toggle('is-on', editing);
        editBtn.setAttribute('aria-pressed', String(editing));
      });

      let drag = null;
      editables.forEach((el) => {
        el.addEventListener('pointerdown', (e) => {
          if (!editing) return;
          e.preventDefault();
          const csd = getComputedStyle(el);
          const st = layout[el.dataset.edit] || {
            x: parseFloat(csd.getPropertyValue('--ex')) || 0,
            y: parseFloat(csd.getPropertyValue('--ey')) || 0,
            s: parseFloat(csd.getPropertyValue('--es')) || 1,
          };
          layout[el.dataset.edit] = st;
          drag = { el, sx: e.clientX, sy: e.clientY, ox: st.x || 0, oy: st.y || 0, st };
          el.classList.add('is-grab');
          try { el.setPointerCapture && el.setPointerCapture(e.pointerId); } catch (err) {}
        });
        el.addEventListener('pointermove', (e) => {
          if (!drag || drag.el !== el) return;
          drag.st.x = Math.round(drag.ox + (e.clientX - drag.sx));
          drag.st.y = Math.round(drag.oy + (e.clientY - drag.sy));
          applyEl(el, drag.st);
        });
        const endDrag = () => { if (drag && drag.el === el) { laySave(layout); el.classList.remove('is-grab'); drag = null; } };
        el.addEventListener('pointerup', endDrag);
        el.addEventListener('pointercancel', endDrag);
        el.addEventListener('wheel', (e) => {
          if (!editing) return;
          e.preventDefault();
          const csw = getComputedStyle(el);
          const st = layout[el.dataset.edit] || {
            x: parseFloat(csw.getPropertyValue('--ex')) || 0,
            y: parseFloat(csw.getPropertyValue('--ey')) || 0,
            s: parseFloat(csw.getPropertyValue('--es')) || 1,
          };
          st.s = Math.round(Math.min(2.6, Math.max(0.4, (st.s || 1) + (e.deltaY < 0 ? 0.04 : -0.04))) * 100) / 100;
          layout[el.dataset.edit] = st;
          applyEl(el, st);
          laySave(layout);
        }, { passive: false });
      });

      // スクロール登場（ブラー＋立ち上がり）
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // ナビのガラス濃度をスクロールで上げる
      const nav = document.querySelector('.inav');
      const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 40);
      onScroll();
      addEventListener('scroll', onScroll, { passive: true });

      // カーソル光（精密ポインタ＋動きOKのときだけ）
      const fine = matchMedia('(any-hover: hover) and (any-pointer: fine)').matches;
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (fine && !reduce) {
        const glow = document.querySelector('.cursorglow');
        if (glow) {
          addEventListener('pointermove', (e) => {
            glow.style.transform = `translate(${e.clientX}px, ${e.clientY}px) translate(-50%, -50%)`;
            glow.style.opacity = '1';
          });
          addEventListener('pointerleave', () => (glow.style.opacity = '0'));
        }
      }
    </script>
  </body>
</html>
